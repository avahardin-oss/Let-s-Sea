{% liquid
    assign video_type = section.settings.video_type
    assign video_cdn = section.settings.video
    assign video_youtube = section.settings.youtube_url
    assign accessibility_text = section.settings.accessibility_text
%}

{% if video_cdn != blank or video_youtube != blank %}
  <div class="FullBleedVideo">
    {% if video_type == 'shopify' %}
      <div class="FullBleedVideo-overlay js-full-bleed-video-overlay">
        {% render 'svg-play-button' %}
      </div>

      {{ video_cdn | video_tag: image_size: '1200x', autoplay: false, loop: false, muted: true, controls: true }}
      <div class="sr-only">
        {{ accessibility_text }}
      </div>
    {% else %}
      {% assign videoId = video_youtube | split: '?v=' %}

      <iframe
        width="100%"
        height="100%"
        src="https://www.youtube.com/embed/{{ videoId[1] }}"
        frameborder="0"
        allow="autoplay; encrypted-media"
        allowfullscreen></iframe>

        <div class="sr-only">
          {{ accessibility_text }}
        </div>
    {% endif %}
  </div>
{% endif %}

{% schema %}
  {
    "name": "Full Bleed Video",
    "class": "FullBleedVideo-section",
    "settings": [
      {
        "type": "header",
        "content": "Video Settings"
      }, {
        "type": "select",
        "id": "video_type",
        "label": "Video Type",
        "options": [
          {
            "value": "youtube",
            "label": "Youtube/Vimeo"
          }, {
            "value": "shopify",
            "label": "Shopify Files"
          }
        ],
        "default": "shopify",
        "info": "You can toggle between a video link for Youtube or a video hosted in Shopify"
      }, {
        "type": "video",
        "id": "video",
        "label": "Video"
      }, {
        "type": "video_url",
        "id": "youtube_url",
        "label": "Youtube URL",
        "accept": ["youtube"]
      }, {
        "type": "text",
        "id": "accessibility_text",
        "label": "Accessibility Text, describe what is the video about",
        "placeholder": "This is a video about...",
        "default": "Video"
      }
    ],
    "presets": [
      {
        "name": "Full Bleed Video",
        "settings": {}
      }
    ]
  }
{% endschema %}
