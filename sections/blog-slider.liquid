{%- liquid
  assign featuredImage = section.settings.featuredCardImage
  assign featuredHeading = section.settings.featuredCardHeading
  assign link = section.settings.link | default: '' | strip
  assign button_text = section.settings.cta
  assign featuredSubHeading = section.settings.featuredCardSubHeading
  assign featured_card_sr_text = section.settings.featured_card_sr_text
  capture featured_image_sizes
    render 'print-image-sizes' with image: featuredImage
  endcapture
-%}
<div class="mod_blog_slider_5ctVMW_BlogSlider__wrapper">
  <div class="mod_blog_slider_5ctVMW_BlogSlider__featuredCard__wrapper">
    <div class="mod_blog_slider_5ctVMW_BlogSlider__featuredCard">
      <div
        class="mod_blog_slider_5ctVMW_BlogSlider__featuredCard__background {% if featuredImage != blank %}lazyload{% endif %}"
        data-bgset="{{ featured_image_sizes }}"
        data-sizes="auto"
      ></div>
      <div
        class="mod_blog_slider_5ctVMW_BlogSlider__featuredCard__dimmer"
        {% if section.settings.featured_overlay_color != blank %}
          style="background-color: {{ section.settings.featured_overlay_color | color_modify: 'alpha', section.settings.featured_overlay_opacity }}"
        {% endif %}
      >
        {% if featured_card_sr_text != blank %}
          <p class="sr-only">{{ featured_card_sr_text }}</p>
        {% endif %}
      </div>
      <div class="mod_blog_slider_5ctVMW_BlogSlider__featuredCard__content">
        <h3 class="mod_blog_slider_5ctVMW_BlogSlider__featuredCard__title">{{ featuredHeading }}</h3>
        <p class="u-showMd">{{ featuredSubHeading }}</p>
        {%- if link != '' and button_text != blank -%}
          <a href="{{ link }}" class="btn"> {{ button_text }} </a>
        {%- endif -%}
      </div>
    </div>
  </div>

  <div class="mod_blog_slider_5ctVMW_BlogSlider__featuredSlider" role="region" aria-label="blog featured carousel">
    <div role="region" aria-label="carousel" class="swiper articleSlider js-article-slider" carousel>
      <p class="sr-only">This is a carousel with scrollable slides. Use Next and Previous buttons to navigate.</p>

      <div class="swiper-wrapper">
        {%- for block in section.blocks -%}
          {%- liquid
            assign articleImage = block.settings.articleimage
            assign articleTitle = block.settings.articletitle
            assign articleSubtitle = block.settings.articlesubtitle
            assign articleLink = block.settings.articlelink
            assign articleSrText = block.settings.sr_text
            capture article_image_sizes
              render 'print-image-sizes' with image: articleImage
            endcapture
            assign articleAlt = articleTitle
            if articleImage != blank and articleImage.alt != blank
              assign articleAlt = articleImage.alt
            endif
          -%}
          <div class="swiper-slide mod_blog_slider_5ctVMW_BlogSlider__featuredSlider__article" aria-hidden="true" tabindex="-1">
            <div
              class="mod_blog_slider_5ctVMW_BlogSlider__featuredSlider__article__background {% if articleImage != blank %}lazyload{% endif %}"
              data-bgset="{{ article_image_sizes }}"
              data-sizes="auto"
              data-alt="{{ articleAlt | escape }}"
              role="img"
              aria-label="{{ articleSrText | default: articleAlt | escape }}"
            ></div>
            <div
              class="mod_blog_slider_5ctVMW_BlogSlider__featuredSlider__article__dimmer"
              {% if block.settings.article_overlay_color != blank %}
                style="background-color: {{ block.settings.article_overlay_color | color_modify: 'alpha', block.settings.article_overlay_opacity }}"
              {% endif %}
            >
              {% if articleSrText != blank %}
                <p class="sr-only">{{ articleSrText }}</p>
              {% else %}
                <p class="sr-only">{{ articleAlt | escape }}</p>
              {% endif %}
            </div>
            {%- if articleLink != blank and articleTitle != blank -%}
              <div class="mod_blog_slider_5ctVMW_BlogSlider__featuredSlider__article__title_block">
                <a
                  href="{{ articleLink }}"
                  class="mod_blog_slider_5ctVMW_BlogSlider__featuredSlider__article__title"
                  title="{{ articleTitle | escape }}"
                  tabindex="-1"
                >
                  {{- articleTitle -}}
                </a>

                {%- if articleSubtitle != blank -%}
                  <a
                    href="{{ articleLink }}"
                    class="mod_blog_slider_5ctVMW_BlogSlider__featuredSlider__article__subtitle u-showMd"
                    title="{{ articleSubtitle | escape }}"
                    tabindex="-1"
                  >
                    {{- articleSubtitle -}}
                  </a>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
      <div class="mod_blog_slider_5ctVMW_BlogSlider__featuredSlider__carousel__actions">
        <div class="mod_blog_slider_5ctVMW_BlogSlider__featuredSlider__carousel__scrollbar__wrapper">
          <div class="swiper-scrollbar"></div>
        </div>
        <button aria-label="Previous slide" class="swiper-button-prev">{%- render 'icon-arrow-prev' -%}</button>
        <button aria-label="Next slide" class="swiper-button-next">{%- render 'icon-arrow-next' -%}</button>
      </div>
    </div>
  </div>
</div>

<style>
  .BlogSlider {
    --mod_blog_slider_5ctVMW_text-color: {{ section.settings.text_color }};
    --mod_blog_slider_5ctVMW_arrows-color: {{ settings.arrows_color | default: '#000000' }};
    --mod_blog_slider_5ctVMW_scrollbar-color: {{ section.settings.scrollbar_color }};
    --mod_blog_slider_5ctVMW_scrollbar-bg-color: {{ section.settings.scrollbar_background_color }};
  }
</style>

