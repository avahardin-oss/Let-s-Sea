>
  {%- comment -%} Content Panel (Left - Carousel for text) {%- endcomment -%}
  <div class="mod_steps_carousel_iW5fla_StepsCarousel__content">
    {%- comment -%} Text Content Carousel (fade between blocks) {%- endcomment -%}
    <div
      class="swiper js-steps-swiper mod_steps_carousel_iW5fla_StepsCarousel__textCarousel"
      data-slide-count="{{ section.blocks.size }}"
    >
      <div class="swiper-wrapper">
        {%- for block in section.blocks -%}
          <div class="swiper-slide mod_steps_carousel_iW5fla_StepsCarousel__textSlide" {{ block.shopify_attributes }}>
            <div class="mod_steps_carousel_iW5fla_StepsCarousel__textContent">
              {%- if subheading != blank -%}
                <p class="mod_steps_carousel_iW5fla_StepsCarousel__subheading">
                  {{- subheading | escape -}}
                </p>
              {%- endif -%}

              {%- if block.settings.heading != blank -%}
                <h2 class="mod_steps_carousel_iW5fla_StepsCarousel__heading">
                  {{- block.settings.heading | escape -}}
                </h2>
              {%- endif -%}

              {%- if block.settings.description != blank -%}
                <p class="mod_steps_carousel_iW5fla_StepsCarousel__description">
                  {{- block.settings.description | escape -}}
                </p>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>

    {%- comment -%} Step Indicators {%- endcomment -%}
    <div class="mod_steps_carousel_iW5fla_StepsCarousel__steps">
      {%- for block in section.blocks -%}
        <button
          type="button"
          class="mod_steps_carousel_iW5fla_StepsCarousel__step js-step-indicator{% if forloop.first %} is-active{% endif %}"
          data-slide-index="{{ forloop.index0 }}"
          aria-label="Go to step {{ forloop.index }}"
        >
          {{ forloop.index }}
        </button>
      {%- endfor -%}
    </div>
  </div>

