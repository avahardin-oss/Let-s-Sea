{%- liquid
  assign compareTableHeader = section.settings.header | default: 'Compare'

  assign masterMetaobject = product.metafields.product.compare_table.value

  assign masterProductTitle = masterMetaobject.product_title
  assign masterProductImage = masterMetaobject.product_image

  assign masterProductBenefits = masterMetaobject.product_benefits.value
  assign masterFeatures = ''
  assign masterFeaturesValues = ''

  for feature in masterProductBenefits
    assign featureName = feature | split: ' || ' | first
    assign masterFeatures = masterFeatures | append: ' || ' | append: featureName
  endfor

  for value in masterProductBenefits
    assign featureValue = value | split: ' || ' | last
    assign masterFeaturesValues = masterFeaturesValues | append: ' || ' | append: featureValue
  endfor

  assign masterFeatures = masterFeatures | split: ' || '
  assign masterFeaturesValues = masterFeaturesValues | split: ' || '

  assign compareProductsList = masterMetaobject.compare_products.value
-%}

{% if masterMetaobject != blank %}
  <div id="pdp_compare_table" class="mod_compare_table_S2P0Xa_CompareProdTable">
    <h2 class="mod_compare_table_S2P0Xa_CompareProdTable-mobileTitle">{{ compareTableHeader }}</h2>
    <div
      class="mod_compare_table_S2P0Xa_CompareProdTable-wrapper js-compare-carousel swiper"
      slider-identifier="{{ section.id | strip | handleize }}"
    >
      <div class="mod_compare_table_S2P0Xa_CompareProdTable-table swiper-wrapper">
        <!-- Feature names column (hidden on mobile, visible on desktop) -->
        <div class="mod_compare_table_S2P0Xa_CompareProdTable-column swiper-slide">
          <div class="mod_compare_table_S2P0Xa_CompareProdTable-imgBlock mod_compare_table_S2P0Xa_CompareProdTable-titleBlock">
            <h2 class="mod_compare_table_S2P0Xa_CompareProdTable-title">{{ compareTableHeader }}</h2>
          </div>
          <div class="mod_compare_table_S2P0Xa_CompareProdTable-featuresTitles">
            {% for featureTitle in masterFeatures offset: 1 %}
              <div class="mod_compare_table_S2P0Xa_CompareProdTable-featureTitle">
                {{ featureTitle }}
              </div>
            {% endfor %}
          </div>
        </div>

        <!-- Master product column -->
        <div
          class="mod_compare_table_S2P0Xa_CompareProdTable-column swiper-slide"
          role="columnheader"
          aria-label="{{ masterProductTitle }}"
        >
          <a href="{{ product.url }}" class="mod_compare_table_S2P0Xa_CompareProdTable-imgBlock">
            <img
              class=""
              src="{{ masterProductImage | img_url: '900x' }}"
              alt="Image of {{ masterProductTitle }}"
            >
            <h3 class="mod_compare_table_S2P0Xa_CompareProdTable-prodTitle">{{ masterProductTitle }}</h3>
          </a>
          <div class="mod_compare_table_S2P0Xa_CompareProdTable-featuresTitles">
            {% for featureValue in masterFeaturesValues offset: 1 %}
              <div
                class="mod_compare_table_S2P0Xa_CompareProdTable-featureValue"
                role="cell"
                tabindex="0"
                aria-label="{{ masterFeatures[forloop.index] }}: {% if featureValue == 'true' %}Yes{% elsif featureValue == 'false' or featureValue == 'X' or featureValue == 'x' %}No{% else %}{{ featureValue }}{% endif %}"
              >
                {% if featureValue == 'true' %}
                  {% render 'svg-checkmark', title: 'Yes' %}
                {% elsif featureValue == 'false' or featureValue == 'X' or featureValue == 'x' %}
                  {% render 'svg-x', title: 'No' %}
                {% else %}
                  {{ featureValue }}
                {% endif %}
                <span class="mod_compare_table_S2P0Xa_CompareProdTable-inCellTitle">{{ masterFeatures[forloop.index] }}</span>
              </div>
            {% endfor %}
          </div>
        </div>

        <!-- Compared product columns -->
        {% for item in compareProductsList %}
          {% liquid
            assign compareMasterMetaobject = item.metafields.product.compare_table.value
            assign itemProductTitle = compareMasterMetaobject.product_title
            assign itemProductImage = compareMasterMetaobject.product_image
            assign itemProductBenefits = compareMasterMetaobject.product_benefits.value

            assign itemFeaturesValues = ''
            for masterFeature in masterProductBenefits
              assign masterTitle = masterFeature | split: ' || ' | first
              assign matched = false
              for feature in itemProductBenefits
                assign checkTitle = feature | split: ' || ' | first
                assign checkValue = feature | split: ' || ' | last
                if masterTitle == checkTitle
                  assign itemFeaturesValues = itemFeaturesValues | append: ' || ' | append: checkValue
                  assign matched = true
                  break
                endif
              endfor
              if matched != true
                assign itemFeaturesValues = itemFeaturesValues | append: ' || ' | append: 'false'
              endif
            endfor
            assign itemFeaturesValues = itemFeaturesValues | split: ' || '
          %}
          <div
            class="mod_compare_table_S2P0Xa_CompareProdTable-column swiper-slide"
            role="columnheader"
            aria-label="{{ itemProductTitle }}"
          >
            <a href="{{ item.url }}" class="mod_compare_table_S2P0Xa_CompareProdTable-imgBlock">
              <img
                class=""
                src="{{ itemProductImage | img_url: '900x' }}"
                alt="Image of {{ itemProductTitle }}"
              >
              <h3 class="mod_compare_table_S2P0Xa_CompareProdTable-prodTitle">{{ itemProductTitle }}</h3>
            </a>
            <div class="mod_compare_table_S2P0Xa_CompareProdTable-featuresTitles">
              {% for featureValue in itemFeaturesValues offset: 1 %}
                <div
                  class="mod_compare_table_S2P0Xa_CompareProdTable-featureValue"
                  role="cell"
                  tabindex="0"
                  aria-label="{{ masterFeatures[forloop.index] }}: {% if featureValue == 'true' %}Yes{% elsif featureValue == 'false' or featureValue == 'X' or featureValue == 'x' %}No{% else %}{{ featureValue }}{% endif %}"
                >
                  {% if featureValue == 'true' %}
                    {% render 'svg-checkmark', title: 'Yes' %}
                  {% elsif featureValue == 'false' or featureValue == 'X' or featureValue == 'x' %}
                    {% render 'svg-x', title: 'No' %}
                  {% else %}
                    {{ featureValue }}
                  {% endif %}
                  <span class="mod_compare_table_S2P0Xa_CompareProdTable-inCellTitle">{{ masterFeatures[forloop.index] }}</span>
                </div>
              {% endfor %}
            </div>
          </div>
        {% endfor %}
      </div>
      <div class="mod_compare_table_S2P0Xa_CompareProdTable-carousel__actions">
        <div class="mod_compare_table_S2P0Xa_CompareProdTable-carousel__scrollbar__wrapper">
          <div class="swiper-scrollbar" aria-hidden="true"></div>
        </div>
        <button
          aria-label="Previous slide"
          class="ctb-swiper-button-prev"
        >
          {%- render 'svg-arrow-prev' -%}
        </button>
        <button
          aria-label="Next slide"
          class="ctb-swiper-button-next"
        >
          {%- render 'svg-arrow-next' -%}
        </button>
      </div>
    </div>
  </div>
{% endif %}

