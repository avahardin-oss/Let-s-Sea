{%- liquid
  assign payment_info = section.settings.payment_info | default: ''
  assign hide_free_shipping_tracker = section.settings.hide_free_shipping_tracker
  assign free_shipping_text = section.settings.free_shipping_text | default: ''
  assign free_shipping_unlock_text = section.settings.free_shipping_unlock_text | default: ''
  assign free_shipping_value = section.settings.free_shipping_value | default: 0 | times: 100
  assign hidden_free_shipping = section.settings.hidden_free_shipping | default: false
  assign hidden_free_shipping_amount = section.settings.hidden_free_shipping_amount | default: 0 | times: 100

  assign empty_header = section.settings.empty_header | default: ''
  assign empty_text = section.settings.empty_text | default: 'Your cart is empty'
  assign empty_description = section.settings.empty_description | default: 'Wherever life takes you we hope you take us with you.'
  assign empty_cta = section.settings.empty_cta | default: 'Checkout our best sellers'
  assign empty_url = section.settings.empty_url | default: '/collections/all'
  assign gamification_type = section.settings.gamification_type
  assign current_market_handle = localization.market.handle
-%}

{%- comment -%}
  Determine which threshold blocks to output for the current market.
  If any blocks carry a market_handle matching the current market, use only
  those. Otherwise fall back to blocks with a blank market_handle (global
  defaults), preserving backwards-compatibility for stores that have not yet
  added per-market blocks.
{%- endcomment -%}
{%- assign market_threshold_count = 0 -%}
{%- for block in section.blocks -%}
  {%- if block.type == 'threshold' and block.settings.market_handle == current_market_handle -%}
    {%- assign market_threshold_count = market_threshold_count | plus: 1 -%}
  {%- endif -%}
{%- endfor -%}

<script id="js-ajax-cart-json" type="application/json">
  {
    "payment_info": {{ payment_info | json }},
    "hide_free_shipping_tracker": {{ hide_free_shipping_tracker | json }},
    "free_shipping_text": {{ free_shipping_text | json }},
    "free_shipping_unlock_text": {{ free_shipping_unlock_text | json }},
    "free_shipping_value": {{ free_shipping_value | json }},
    "hidden_free_shipping": {{ hidden_free_shipping | json }},
    "hidden_free_shipping_amount": {{ hidden_free_shipping_amount | json }},
    "empty_header": {{ empty_header | json }},
    "empty_text": {{ empty_text | json }},
    "empty_description": {{ empty_description | json }},
    "empty_cta": {{ empty_cta | json }},
    "empty_url": {{ empty_url | json }},
    "gamification_type": {{ gamification_type | json }},
    "gamification":[
        {%- assign gamification_rendered = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'threshold' -%}
            {%- assign include_block = false -%}
            {%- if market_threshold_count > 0 and block.settings.market_handle == current_market_handle -%}
              {%- assign include_block = true -%}
            {%- elsif market_threshold_count == 0 and block.settings.market_handle == blank -%}
              {%- assign include_block = true -%}
            {%- endif -%}
            {%- if include_block -%}
              {%- if gamification_rendered > 0 -%},{%- endif -%}
              {"threshold": {{ block.settings.value | json }}, "message": {{ block.settings.title | json }}}
              {%- assign gamification_rendered = gamification_rendered | plus: 1 -%}
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
    ]
  }
</script>

{%- schema %}
{
  "name": "Side Cart",
  "settings": [
    {
      "type": "header",
      "content": "Info"
    },
    {
      "type": "checkbox",
      "id": "hide_free_shipping_tracker",
      "label": "Hide free shipping tracker",
      "default": false
    },
    {
      "type": "text",
      "id": "free_shipping_text",
      "label": "Free shipping text",
      "info": "Use # where should be money value"
    },
    {
      "type": "text",
      "id": "free_shipping_unlock_text",
      "label": "Free shipping unlock text",
      "default": "You unlocked free shipping!"
    },
    {
      "type": "text",
      "id": "free_shipping_value",
      "label": "Max threshold value",
      "info": "Please use the bigest threshold value, i.e. if last step is reached at $150, add 150 here"
    },
    {
      "type": "checkbox",
      "id": "hidden_free_shipping",
      "label": "Inline Free Shipping Message",
      "default": true
    },
    {
      "type": "text",
      "id": "hidden_free_shipping_amount",
      "label": "Hidden Free Shipping Amount"
    },
    {
      "type": "header",
      "content": "Empty Box"
    },
    {
      "type": "text",
      "id": "empty_header",
      "label": "Cart empty header",
      "default": "Shopping Cart"
    },
    {
      "type": "text",
      "id": "empty_text",
      "label": "Empty cart box title",
      "default": "Your cart is empty"
    },
    {
      "type": "text",
      "id": "empty_description",
      "label": "Cart empty description",
      "default": "Wherever life takes you we hope you take us with you."
    },
    {
      "type": "text",
      "id": "empty_cta",
      "label": "Button Label",
      "default": "Checkout our best sellers"
    },
    {
      "type": "url",
      "id": "empty_url",
      "label": "Empty Button Link"
    },
    {
      "type": "radio",
      "id": "gamification_type",
      "label": "Gamification type",
      "options": [
        { "value": "regular", "label": "Regular" },
        { "value": "steps", "label": "With thresholds" }
      ],
      "default": "steps"
    },
    {
      "type": "header",
      "content": "Upsell"
    },
    {
      "type": "text",
      "id": "upsell_header",
      "label": "Header"
    },
    {
      "type": "collection",
      "id": "coll",
      "label": "Collection"
    }
  ],
  "blocks": [
    {
      "type": "threshold",
      "name": "Gamification Threshold",
      "settings": [
        {
          "type": "text",
          "id": "market_handle",
          "label": "Market Handle",
          "info": "Leave blank to use as the default for all markets. Enter a market handle (e.g. 'ca', 'eu') to override for a specific market. Find handles in Shopify Admin → Settings → Markets."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Amount"
        }
      ]
    }
  ]
}
{%- endschema %}
