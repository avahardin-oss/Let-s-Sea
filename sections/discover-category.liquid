    assign full_width = true
  endif
  assign content_color = section.settings.content_color
-%}

<section class="mod_discover_category_zPDFQW_DiscoverByCategory">
<h2>{{ section.settings.title }}</h2>
<div class="mod_discover_category_zPDFQW_DiscoverByCategory__accordeon js-accordeon" role="tablist" aria-orientation="vertical" data-size="{{ section.blocks | size }}">
  {%- for block in section.blocks -%}
    {%- liquid
            assign title = block.settings.collection_title
            assign desc = block.settings.description
            assign button = block.settings.button_text
            assign link = block.settings.button_url
            assign shadow_intensity = block.settings.shadow_intensity
            assign stars = block.settings.stars
            assign reviews_count = block.settings.reviews_count
            capture image_block
              render 'print-image-sizes', image: block.settings.image
            endcapture
            assign imageAlt = block.settings.image.alt | default: title
          -%}

    {% comment %} Accordeon Desktop {% endcomment %}
    <div class="mod_discover_category_zPDFQW_DiscoverByCategory__link {% if full_width == true %} mod_discover_category_zPDFQW_DiscoverByCategory__full__width {% endif %} js-discover-link"
         tabindex="0"
         id="content-{{ forloop.index0 }}"
         aria-labelledby="tab-{{ forloop.index0 }}"
         {% if link != blank %}data-location="{{ link }}"{% endif %}>
      <div class="mod_discover_category_zPDFQW_DiscoverByCategory__card__shadow" style="background-color: rgba(0, 0, 0, {{ shadow_intensity }}%)"></div>
      <div
        class="mod_discover_category_zPDFQW_DiscoverByCategory__image lazyload{% if full_width == true %} expand {% endif %}"
        data-sizes="auto"
        data-bgset="{{ image_block | strip_newlines | strip }}"
        data-alt="{{ imageAlt | escape }}"
        role="img"
        aria-label="{{ imageAlt | escape }}"></div>
      <button
        class="mod_discover_category_zPDFQW_DiscoverByCategory__short"
        id="tab-{{ forloop.index0 }}"
        aria-controls="content-{{ forloop.index0 }}"
        role="tab">
        {{ title }}
      </button>
      <div class="mod_discover_category_zPDFQW_DiscoverByCategory__full{% if full_width == true %} expand {% endif %}" role="tabpanel" aria-labelledby="tab-{{ forloop.index0 }}" tabindex="0">
        <div class="mod_discover_category_zPDFQW_DiscoverByCategory__content js-accordeon-content">
          <h3>
            {{ title }}
          </h3>
          <hr/>
