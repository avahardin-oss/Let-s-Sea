<style>
  .homepage-banner__desktop--img,
  .homepage-banner__mobile--img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .homepage-banner__desktop--slide,
  .homepage-banner__mobile--slide {
      width: 100%;
      height: 100%;
      background-size: cover;
      background-repeat: no-repeat;
  }
  .homepage-banner__desktop--shadow,
  .homepage-banner__desktop--video-shadow,
  .homepage-banner__mobile--video-shadow,
  .homepage-banner__mobile--shadow {
    position: absolute;
    inset: 0;
    background-color: {{ tint_color }};
    opacity: {{ tint_strength }};
  }
  .homepage-banner__desktop--video-shadow,
  .homepage-banner__mobile--video-shadow {
      width: 100%;
  }
  .homepage-banner-section {
    background-color: {{ tint_color }};
  }
  .homepage-banner__mobile {
    background-position: center;
  }
  .homepage-banner__content {
    position: absolute;
    top: 50%;
    left: 0;
    transform: translateY(-50%) translateZ(0);
    width: 100%;
    text-align: center;
    transition: opacity 300ms ease-in-out 300ms;
  }
  @media (min-width: 640px) {
    .homepage-banner__content[data-position~='top'] {
      top: 10%;
      transform: none;
      padding: 10px 0 0 0;
    }
    .homepage-banner__content[data-position~='bottom'] {
      top: auto;
      bottom: 10%;
      transform: none;
      padding: 0 0 10px 0;
    }
    .homepage-banner__content[data-position~='left'] {
      width: 50%;
      text-align: left;
      padding: 0 0 0 40px;
    }
    .homepage-banner__content[data-position~='right'] {
      left: 50%;
      width: 50%;
      text-align: left;
      padding: 0 10px 0 0;
    }
  }
  .homepage-banner__content .homepage-banner__content--label {
    color: {{ label_color }};
  }

  .homepage-banner__content--button.hollow {
    background-color: transparent;
    border: solid 0.125em {{ cta_bg_color }};
    color: {{ cta_bg_color }};
  }
  .homepage-banner__content--button.hollow:hover,
  .homepage-banner__content--button.hollow:focus {
    background-color: {{ cta_bg_color }};
    border-color: {{ cta_bg_color }};
    color: {{ cta_color }};
  }
</style>

{%- schema %}
{
  "name": "HP Banner",
  "class": "js-homepage-hero HpBannerSection",
  "settings": [
    {
      "type": "checkbox",
      "id": "multiple_slides",
      "label": "Slider mode: Use multiple images",
      "info": "If deactivated, shows only the image from the first block"
    },
    {
      "type": "range",
      "id": "slider_delay",
      "min": 1,
      "max": 9,
      "step": 1,
      "label": "Slider delay",
      "info": "Time between slides (expressed in seconds)",
      "default": 1
    },
    {
      "type": "color",
      "id": "tint_color",
      "label": "Tint color",
      "default": "#000000"
    },
    {
      "type": "select",
      "id": "tint_strength",
      "label": "Tint strength",
      "options": [
        { "value": "0", "label": "No tint" },
        { "value": "0.1", "label": "10%" },
        { "value": "0.2", "label": "20%" },
        { "value": "0.3", "label": "30%" },
        { "value": "0.4", "label": "40%" },
        { "value": "0.5", "label": "50%" },
        { "value": "0.6", "label": "60%" },
        { "value": "0.7", "label": "70%" },
        { "value": "0.8", "label": "80%" },
        { "value": "0.9", "label": "90%" }
      ],
      "default": "0.2"
    }
  ],
  "blocks": [
    {
      "type": "slide_image",
      "name": "Slide (image)",
      "settings": [
        {
          "type": "image_picker",
          "id": "desktop_image",
          "label": "Slide image (Desktop)",
          "info": "1920x650, Preferable 2x"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Slide image (Mobile)",
          "info": "390x400, Preferable 3x"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "40oz Trek Tumblers"
        },
        {
          "type": "text",
          "id": "sub_heading",
          "label": "Label Text",
          "default": "Back in Stock!"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Button Link"
        },
        {
          "type": "text",
          "id": "cta",
          "label": "Button text",
          "default": "Shop Trek Tumblers"
        },
        {
          "type": "select",
          "id": "cta_radiu",
          "label": "Button radius",
          "options": [
            { "value": "0", "label": "Square corners" },
            { "value": "0.125", "label": "Smoothed corners" },
            { "value": "5", "label": "Rounded" }
          ]
        },
