{%- liquid
  assign link = section.settings.link | default: '' | strip
  assign tint_color = section.settings.tint_color
  assign tint_strength = section.settings.tint_strength | default: '0.2'
  assign caption_position = section.settings.caption_position | default: 'center middle'
  assign button_text = section.settings.cta
  assign button_radius = section.settings.cta_radiu | default: '0.125'
  assign cta_color = section.settings.cta_color | default: settings.color_white
  assign cta_bg_color = section.settings.cta_bg_color | default: settings.color_button_background
  assign cta_style = section.settings.cta_style | default: 'solid'
  assign heading = section.settings.heading
  assign heading_color = section.settings.heading_color | default: settings.color_white
  assign label = section.settings.sub_heading
  assign label_color = section.settings.sub_heading_color | default: settings.color_white
  assign slider_delay = section.settings.slider_delay | times: 1000
  capture hero_image_desktop
    render 'print-image-sizes', image: section.blocks[0].settings.desktop_image
  endcapture
  capture hero_image_mobile
    render 'print-image-sizes', image: section.blocks[0].settings.mobile_image
  endcapture
-%}

<section class="mod_homepage_hero_ILaONW_HpBannerSection">
  {% unless section.settings.multiple_slides %}
