{%- comment -%}
  Section: Search Results
  Portable section with React-powered filter drawer
{%- endcomment -%}

{%- liquid
  assign smp_colors = shop.metaobjects.smp_tags.color.tags.value | split: ','
  assign products_per_page = section.settings.hits_per_page | default: 24
  assign grid_remainder = products_per_page | modulo: 4
  assign products_per_page = products_per_page | minus: grid_remainder
  if products_per_page < 4
    assign products_per_page = 4
  endif

  assign is_b2b = false
  if customer.b2b?
    assign is_b2b = true
  endif

  assign total_active_filters = 0
  for filter in search.filters
    assign total_active_filters = total_active_filters | plus: filter.active_values.size
  endfor

  comment
    Pre-build color family swatch lookup from metaobject.
    This is done once to avoid repeated metaobject access in the filter loop.
    Format: "ColorName|imageUrl,ColorName2|imageUrl2,..."
  endcomment
  assign color_family_lookup = ''
  for color_family in shop.metaobjects.product_color_families.values
    assign color_entry = color_family.handle_name | append: '|' | append: color_family.color_image | image_url: width: 128
    if color_family_lookup == ''
      assign color_family_lookup = color_entry
    else
      assign color_family_lookup = color_family_lookup | append: ',' | append: color_entry
    endif
  endfor

  assign filter_pill_blocks = section.blocks | where: 'type', 'filter_pill'

  comment
    Badge filter count: excludes filter.p.tag since tag filters are managed by pills, not the filter drawer.
  endcomment
  assign badge_filter_count = 0
  for filter in search.filters
    unless filter.param_name == 'filter.p.tag'
      assign badge_filter_count = badge_filter_count | plus: filter.active_values.size
    endunless
  endfor

  # Pre-count total products across all search results
  # This must happen before the tab buttons so the count is available
  assign total_product_count = 0
  assign total_post_count = 0

  assign is_article_search = false
  if search.types.size == 1 and search.types contains 'article'
    assign is_article_search = true
  endif

  assign is_product_search = false
  if search.types.size == 1 and search.types contains 'product'
    assign is_product_search = true
  endif

  if is_article_search
    # It's an article search, so results_count strictly equals article count
    assign total_post_count = search.results_count
  elsif is_product_search
    # It's a product search, so results_count strictly equals product count
    assign total_product_count = search.results_count
  else
    # Mixed search (or no explicit type)
    assign total_product_count = search.results_count
    for item in search.results
      if item.object_type == 'article'
        assign total_post_count = total_post_count | plus: 1
      endif
    endfor
  endif

  assign active_tab = 'products'
  if is_article_search
    assign active_tab = 'pages'
  endif

  assign is_mixed_search = false
  if search.performed and is_product_search == false and is_article_search == false
    assign is_mixed_search = true
  endif
-%}

{%- comment -%}
  Redirect mixed searches to type=product so Shopify paginates correctly.
  Without a type param, search.results mixes products and articles, causing
  the paginate block to count articles towards the per-page limit while the
  grid only renders products — resulting in fewer visible items per page.
{%- endcomment -%}
{%- if is_mixed_search -%}
  <script>
    ;(function () {
      var url = new URL(window.location.href)
      url.searchParams.set('type', 'product')
      window.location.replace(url.toString())
    })()
  </script>
{%- endif -%}

<script>
  (function() {
    window.searchHtmlCache = window.searchHtmlCache || new Map();

    var query = {{ search.terms | json }};
    if (!query) {
      return;
    }

    function fetchTypedSearch(type) {
      var url = new URL(window.location.href);
      url.searchParams.set('type', type);
      url.searchParams.delete('page');
      url.searchParams.set('section_id', '{{ section.id }}');
      var cacheKey = url.toString().replace(/%2C/g, ',');

      var htmlPromise = fetch(url.toString(), {
        headers: { 'Cache-Control': 'no-cache, no-store, must-revalidate', 'Pragma': 'no-cache' },
        cache: 'no-store'
      })
        .then(function(res) { if (!res.ok) throw new Error('HTTP error'); return res.text(); })
        .catch(function(e) { window.searchHtmlCache.delete(cacheKey); throw e; });

      window.searchHtmlCache.set(cacheKey, htmlPromise);
      return htmlPromise;
    }

    function extractCount(html, selector) {
      if (!html) return 0;
      var doc = new DOMParser().parseFromString(html, 'text/html');
      var el = doc.querySelector(selector);
      return parseInt((el && el.textContent) || '0', 10);
    }

    function applyCountsToDom(productCount, postCount) {
      if (productCount > 0) {
        document.querySelectorAll('[data-product-count]').forEach(function(el) {
          el.textContent = String(productCount);
        });
      }
      if (postCount > 0) {
        document.querySelectorAll('[data-post-count]').forEach(function(el) {
          el.textContent = String(postCount);
        });
      }
    }

    var currentType = new URLSearchParams(window.location.search).get('type');

    if (currentType === 'product') {
      fetchTypedSearch('article')
        .then(function(html) {
          // Read DOM count inside .then — by now the <section> below has been parsed
          var el = document.querySelector('[data-product-count]');
          var prodCount = parseInt((el && el.textContent) || '0', 10);
          applyCountsToDom(prodCount, extractCount(html, '[data-post-count]'));
        })
        .catch(function() {});

    } else if (currentType === 'article') {
      fetchTypedSearch('product')
        .then(function(html) {
          var el = document.querySelector('[data-post-count]');
          var postCount = parseInt((el && el.textContent) || '0', 10);
          applyCountsToDom(extractCount(html, '[data-product-count]'), postCount);
        })
        .catch(function() {});

    } else {
      // Mixed search — DOM counts are unreliable; fetch both types
      Promise.all([
        fetchTypedSearch('product').catch(function() { return ''; }),
        fetchTypedSearch('article').catch(function() { return ''; })
      ])
        .then(function(results) {
          applyCountsToDom(
            extractCount(results[0], '[data-product-count]'),
            extractCount(results[1], '[data-post-count]')
          );
        })
        .catch(function() {});
    }
  })();
</script>

<section class="SearchPage" data-section-type="search-results" data-section-id="{{ section.id }}">
  <div class="SearchPage-container">
    {%- if search.performed -%}
      {%- if total_product_count > 0 -%}
        <h1 class="SearchPage-title js-search-title">
          {{ total_product_count }}
          results for "{{ search.terms }}"
        </h1>
      {%- else -%}
        <h1 class="SearchPage-title js-search-title">No results for "{{ search.terms }}"</h1>
      {%- endif -%}
    {%- else -%}
      <h1 class="SearchPage-title">Search Results</h1>
    {%- endif -%}

    <div id="search-anchor"></div>

    {%- if total_product_count > 0 -%}
      {%- comment -%} Tabs for JS tab switching {%- endcomment -%}
      <div class="SearchPage-header js-search-header" data-hide-nav="true">
        <div class="SearchPage-tabs" role="tablist">
          <button
            id="productsTab"
            type="button"
            class="SearchPage-tabBtn{% if active_tab == 'products' %} active{% endif %}"
            role="tab"
            tabindex="0"
            data-tab="products"
          >
            Products (<span data-product-count>{{ total_product_count }}</span>)
          </button>
          <button
            id="pagesTab"
            type="button"
            class="SearchPage-tabBtn js-search-page-tab{% if active_tab == 'pages' %} active{% endif %}"
            data-page-count="{{ total_post_count }}"
            role="tab"
            tabindex="-1"
            data-tab="pages"
          >
            Posts (<span data-post-count>{{ total_post_count }}</span>)
          </button>
        </div>
      </div>

      {%- unless is_b2b -%}
        <div class="SearchPage-controlsRow">
          {%- comment -%} Tag Filter Pills — show only pills whose tag exists in current search results {%- endcomment -%}
          {%- if filter_pill_blocks.size > 0 -%}
            {%- assign visible_pill_count = 0 -%}
            {%- for block in filter_pill_blocks -%}
              {%- assign pill_tag = block.settings.tag_value -%}
              {%- if block.settings.label != blank and pill_tag != blank -%}
                {%- assign pill_visible = false -%}
                {%- assign downcase_pill_tag = pill_tag | downcase -%}
                {%- for filter in search.filters -%}
                  {%- if filter.param_name == 'filter.p.tag' -%}
                    {%- for value in filter.values -%}
                      {%- assign downcase_value = value.value | downcase -%}
                      {%- if downcase_value == downcase_pill_tag and value.count > 0 -%}
                        {%- assign pill_visible = true -%}
                      {%- endif -%}
                    {%- endfor -%}
                    {%- for active_value in filter.active_values -%}
                      {%- assign downcase_active_value = active_value.value | downcase -%}
                      {%- if downcase_active_value == downcase_pill_tag -%}
                        {%- assign pill_visible = true -%}
                      {%- endif -%}
                    {%- endfor -%}
                  {%- endif -%}
                {%- endfor -%}
                {%- if pill_visible -%}
                  {%- assign visible_pill_count = visible_pill_count | plus: 1 -%}
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}

            {%- if visible_pill_count > 0 -%}
              <div class="SearchPage-filterPills" data-filter-pills>
                {%- assign encoded_terms = search.terms | url_encode -%}
                <a
                  href="/search?q={{ encoded_terms }}&type=product"
                  class="SearchPage-filterPill{% if total_active_filters == 0 %} active{% endif %}"
                  data-filter-pill
                >
                  All
                </a>
                {%- for block in filter_pill_blocks -%}
                  {%- assign pill_label = block.settings.label -%}
                  {%- assign pill_tag = block.settings.tag_value -%}
                  {%- if pill_label != blank and pill_tag != blank -%}
                    {%- assign pill_has_results = false -%}
                    {%- assign is_pill_active = false -%}
                    {%- assign downcase_pill_tag = pill_tag | downcase -%}
                    {%- assign real_tag_value = pill_tag -%}
                    {%- for filter in search.filters -%}
                      {%- if filter.param_name == 'filter.p.tag' -%}
                        {%- for value in filter.values -%}
                          {%- assign downcase_value = value.value | downcase -%}
                          {%- if downcase_value == downcase_pill_tag and value.count > 0 -%}
                            {%- assign pill_has_results = true -%}
                            {%- assign real_tag_value = value.value -%}
                          {%- endif -%}
                        {%- endfor -%}
                      {%- endif -%}
                      {%- for active_value in filter.active_values -%}
                        {%- assign downcase_active_value = active_value.value | downcase -%}
                        {%- if downcase_active_value == downcase_pill_tag -%}
                          {%- assign is_pill_active = true -%}
                          {%- assign real_tag_value = active_value.value -%}
                        {%- endif -%}
                      {%- endfor -%}
                    {%- endfor -%}
                    {%- if pill_has_results or is_pill_active -%}
                      {%- assign pill_url = '/search?q='
                        | append: encoded_terms
                        | append: '&type=product&filter.p.tag='
                        | append: real_tag_value
                      -%}
                      <a
                        href="{{ pill_url }}"
                        class="SearchPage-filterPill{% if is_pill_active %} active{% endif %}"
                        data-filter-pill
                        {{ block.shopify_attributes }}
                      >
                        {{ pill_label }}
                      </a>
                    {%- endif -%}
                  {%- endif -%}
                {%- endfor -%}
              </div>
            {%- endif -%}
          {%- endif -%}

          {%- comment -%} Filter & Sort Controls {%- endcomment -%}
          <div class="SearchPage-controls js-search-filter-controls">
            <button
              type="button"
              class="SearchPage-filterBtn"
              data-filter-toggle
              aria-label="Filter"
              aria-expanded="false"
              aria-controls="search-filter-drawer"
            >
              <svg
                width="15"
                height="16"
                viewBox="0 0 15 16"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
              >
                <path d="M0 3H15M0 8H15M0 13H15" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="3" cy="3" r="2" fill="white" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="12" cy="8" r="2" fill="white" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="6" cy="13" r="2" fill="white" stroke="currentColor" stroke-width="1.5"/>
              </svg>
              <span>Filter</span>
              <span
                class="Collection__filters__toggle-btn__counter{% if badge_filter_count > 0 %} Collection__filters__toggle-btn__counter-active{% endif %}"
                data-filter-count
              >
                {%- if badge_filter_count > 0 -%}{{ badge_filter_count }}{%- endif -%}
              </span>
            </button>
            <div id="search-sort-root"></div>
          </div>
        </div>
      {%- endunless -%}
    {%- endif -%}

    {%- comment -%} Products Tab {%- endcomment -%}
    <div
      class="js-search-products SearchPage-tabContent{% if active_tab == 'products' %} active{% endif %}"
      role="tabpanel"
      aria-labelledby="productsTab"
      data-search-panel="products"
    >
      {%- if is_b2b -%}
        {%- comment -%} B2B customers see basic grid without filtering {%- endcomment -%}
        <div class="Grid Grid--alignLeft">
          {%- for item in search.results -%}
            {% if item.object_type == 'product' -%}
              <div class="Grid-item">
                {%- render 'product-card', product: item, smp_colors: smp_colors -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- else -%}
        {%- comment -%} Regular customers get full filtering experience {%- endcomment -%}
        <div class="Collection" id="search-main-container" data-filter-container>
          {%- if total_product_count > 0 -%}
            {%- comment -%} React filter drawer mounts here (toggle button is in SearchPage-header) {%- endcomment -%}
            <div data-filter-drawer-mount></div>
            <div class="Collection__header-filter-boubles"></div>
          {%- endif -%}

          <div class="Collection__wrapper" data-search-wrapper>
            {%- paginate search.results by products_per_page -%}
              {%- assign available_product_tags_str = '' -%}

              {%- if total_product_count > 0 -%}
                <div
                  id="Search-ajaxinate"
                  class="Grid Grid--alignLeft"
                  data-search-grid
                >
                  {%- for item in search.results -%}
                    {%- if item.object_type == 'product' -%}
                      {%- for tag in item.tags -%}
                        {%- if tag contains 'colorfamily:'
                          or tag contains 'volume:'
                          or tag contains 'Licensed:'
                          or tag contains 'lid:'
                          or tag contains 'attribute:'
                        -%}
                          {%- assign tag_check = '|||' | append: tag | append: '|||' -%}
                          {%- assign full_check = '|||' | append: available_product_tags_str | append: '|||' -%}
                          {%- unless full_check contains tag_check -%}
                            {%- if available_product_tags_str == '' -%}
                              {%- assign available_product_tags_str = tag -%}
                            {%- else -%}
                              {%- assign available_product_tags_str = available_product_tags_str
                                | append: '|||'
                                | append: tag
                              -%}
                            {%- endif -%}
                          {%- endunless -%}
                        {%- endif -%}
                      {%- endfor -%}

                      <div class="Grid-item">
                        {%- render 'product-card', product: item, smp_colors: smp_colors, title_tag: 'h2' -%}
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                </div>

                <div data-search-pagination-wrapper>
                  {%- render 'search-pagination', paginate: paginate, search_terms: search.terms -%}
                </div>
              {%- else -%}
                <div class="SearchPage-noResults">
                  {%- assign bestsellers_collection = section.settings.bestsellers_collection -%}
                  {%- if bestsellers_collection != blank and bestsellers_collection.products.size > 0 -%}
                    {%- assign bestsellers_in_stock = bestsellers_collection.products | where: 'available', true -%}
                    {%- assign bestsellers_heading = section.settings.bestsellers_heading | default: 'Bestsellers' -%}
                    {%- if bestsellers_in_stock.size > 0 -%}
                      <div class="SearchPage-bestsellers is-swiper-pending" data-bestsellers-carousel>
                        <h2 class="SearchPage-bestsellersHeader">{{ bestsellers_heading }}</h2>
                        <div
                          class="swiper js-search-bestsellers-swiper SearchPage-bestsellersSwiper"
                          role="region"
                          aria-roledescription="carousel"
                          aria-label="{{ bestsellers_heading | escape }}"
                        >
                          <div class="swiper-wrapper">
                            {%- for product in bestsellers_in_stock limit: 12 -%}
                              <div class="swiper-slide SearchPage-bestsellersSlide">
                                {%- render 'product-card', product: product, smp_colors: smp_colors -%}
                              </div>
                            {%- endfor -%}
                          </div>
                          <div class="SearchPage-bestsellersActions">
                            <div class="SearchPage-bestsellersScrollbarWrap">
                              <div class="swiper-scrollbar js-search-bestsellers-scrollbar"></div>
                            </div>
                            <button
                              type="button"
                              class="swiper-button-prev SearchPage-bestsellersNavBtn js-search-bestsellers-prev"
                              aria-label="Previous slide"
                            >
                              {%- render 'icon-arrow-prev' -%}
                            </button>
                            <button
                              type="button"
                              class="swiper-button-next SearchPage-bestsellersNavBtn js-search-bestsellers-next"
                              aria-label="Next slide"
                            >
                              {%- render 'icon-arrow-next' -%}
                            </button>
                          </div>
                        </div>
                      </div>
                    {%- endif -%}
                  {%- endif -%}
                </div>
              {%- endif -%}

              {%- comment -%} JSON data for React filter app {%- endcomment -%}
              <script id="search-filters-json" type="application/json">
                  {
                    "sectionId": {{ section.id | json }},
                    "searchTerm": {{ search.terms | json }},
                    "productCount": {{ paginate.items | json }},
                  "availableProductTags": [
                    {%- if available_product_tags_str != '' -%}
                      {%- assign available_tags_arr = available_product_tags_str | split: '|||' -%}
                      {%- for ptag in available_tags_arr -%}
                        {{ ptag | json }}{%- unless forloop.last -%},{%- endunless -%}
                      {%- endfor -%}
                    {%- endif -%}
                  ],
                  {%- assign encoded_search_terms = search.terms | url_encode -%}
                  "clearAllUrl": {{ '/search?q=' | append: encoded_search_terms | append: '&sort_by=' | append: search.sort_by | json }},
                  "sortOptions": [
                    {%- for option in search.sort_options -%}
                      {
                        "label": {{ option.name | json }},
                        "value": {{ option.value | json }},
                        "active": {% if option.value == search.sort_by %}true{% else %}false{% endif %}
                      }{% unless forloop.last %},{% endunless %}
                    {%- endfor -%}
                  ],
                  "activeFilters": [
                    {%- assign active_filter_index = 0 -%}
                    {%- for filter in search.filters -%}
                      {%- unless filter.param_name == 'filter.p.tag' -%}
                        {%- for value in filter.active_values -%}
                          {% if active_filter_index > 0 %},{% endif %}
                          {
                            "label": {{ value.label | json }},
                            "filterLabel": {{ filter.label | json }},
                            "url": {{ value.url_to_remove | json }}
                          }
                          {%- assign active_filter_index = active_filter_index | plus: 1 -%}
                        {%- endfor -%}
                      {%- endunless -%}
                    {%- endfor -%}
                  ],
                  "filters": [
                    {%- assign filter_output_index = 0 -%}
                    {%- for filter in search.filters -%}
                      {%- assign filter_param_lower = filter.param_name | downcase -%}
                      {%- assign filter_label_downcase = filter.label | downcase -%}

                      {%- comment -%}
                        Identify filter types:
                        - Generic Tags: label "Tags" with param containing "tag" - hidden in UI, data used for tag-based filters
                        - Color filters: label contains "color" OR param contains "colorfamily"
                        - Price range: Shopify type == "price_range"
                        - Default: list (checkboxes)
                      {%- endcomment -%}
                      {%- assign is_generic_tags = false -%}
                      {%- if filter.label == 'Tags' and filter_param_lower contains 'tag' -%}
                        {%- assign is_generic_tags = true -%}
                      {%- endif -%}

                      {%- assign is_color_filter = false -%}
                      {%- if filter_label_downcase contains 'color' or filter_param_lower contains 'colorfamily' -%}
                        {%- assign is_color_filter = true -%}
                      {%- endif -%}

                      {%- if filter_output_index > 0 -%},{%- endif -%}
                      {
                        "id": {{ filter.param_name | json }},
                        "label": {{ filter.label | json }},
                        "type": {%- if filter.type == 'price_range' -%}"price_range"{%- elsif is_color_filter -%}"color"{%- elsif is_generic_tags -%}"tags"{%- else -%}"list"{%- endif -%},
                        "hidden": {{ is_generic_tags | json }},
                        {%- if filter.type == 'price_range' -%}
                          "rangeMin": {{ filter.range_min | json }},
                          "rangeMax": {{ filter.range_max | json }},
                          "minValue": {{ filter.min_value.value | default: filter.range_min | json }},
                          "maxValue": {{ filter.max_value.value | default: filter.range_max | json }},
                        {%- endif -%}
                        "values": [
                          {%- assign value_output_index = 0 -%}
                          {%- comment -%}
                            For generic Tags filter, only include values matching specific prefixes.
                            This dramatically reduces JSON size and avoids hitting Shopify limits.
                            Prefixes: volume:, colorfamily:, Licensed:, lid:, attribute:
                          {%- endcomment -%}
                          {%- for value in filter.values limit: 250 -%}
                            {%- unless value.label == 'False' -%}
                              {%- assign include_value = true -%}
                              {%- if is_generic_tags -%}
                                {%- assign include_value = false -%}
                                {%- if value.label contains 'volume:' or value.label contains 'colorfamily:' or value.label contains 'Licensed:' or value.label contains 'lid:' or value.label contains 'attribute:' -%}
                                  {%- assign include_value = true -%}
                                {%- endif -%}
                              {%- endif -%}
                              {%- if include_value -%}
                                {%- if value_output_index > 0 -%},{%- endif -%}
                                {
                                  "label": {{ value.label | json }},
                                  "value": {{ value.value | json }},
                                  "count": {{ value.count | json }},
                                  "active": {{ value.active | json }},
                                  "url": {{ value.url | json }}
                                }
                                {%- assign value_output_index = value_output_index | plus: 1 -%}
                              {%- endif -%}
                            {%- endunless -%}
                          {%- endfor -%}
                          {%- for value in filter.values limit: 250 offset: 250 -%}
                            {%- unless value.label == 'False' -%}
                              {%- assign include_value = true -%}
                              {%- if is_generic_tags -%}
                                {%- assign include_value = false -%}
                                {%- if value.label contains 'volume:' or value.label contains 'colorfamily:' or value.label contains 'Licensed:' or value.label contains 'lid:' or value.label contains 'attribute:' -%}
                                  {%- assign include_value = true -%}
                                {%- endif -%}
                              {%- endif -%}
                              {%- if include_value -%}
                                {%- if value_output_index > 0 -%},{%- endif -%}
                                {
                                  "label": {{ value.label | json }},
                                  "value": {{ value.value | json }},
                                  "count": {{ value.count | json }},
                                  "active": {{ value.active | json }},
                                  "url": {{ value.url | json }}
                                }
                                {%- assign value_output_index = value_output_index | plus: 1 -%}
                              {%- endif -%}
                            {%- endunless -%}
                          {%- endfor -%}
                          {%- for value in filter.values limit: 250 offset: 500 -%}
                            {%- unless value.label == 'False' -%}
                              {%- assign include_value = true -%}
                              {%- if is_generic_tags -%}
                                {%- assign include_value = false -%}
                                {%- if value.label contains 'volume:' or value.label contains 'colorfamily:' or value.label contains 'Licensed:' or value.label contains 'lid:' or value.label contains 'attribute:' -%}
                                  {%- assign include_value = true -%}
                                {%- endif -%}
                              {%- endif -%}
                              {%- if include_value -%}
                                {%- if value_output_index > 0 -%},{%- endif -%}
                                {
                                  "label": {{ value.label | json }},
                                  "value": {{ value.value | json }},
                                  "count": {{ value.count | json }},
                                  "active": {{ value.active | json }},
                                  "url": {{ value.url | json }}
                                }
                                {%- assign value_output_index = value_output_index | plus: 1 -%}
                              {%- endif -%}
                            {%- endunless -%}
                          {%- endfor -%}
                          {%- for value in filter.values limit: 250 offset: 750 -%}
                            {%- unless value.label == 'False' -%}
                              {%- assign include_value = true -%}
                              {%- if is_generic_tags -%}
                                {%- assign include_value = false -%}
                                {%- if value.label contains 'volume:' or value.label contains 'colorfamily:' or value.label contains 'Licensed:' or value.label contains 'lid:' or value.label contains 'attribute:' -%}
                                  {%- assign include_value = true -%}
                                {%- endif -%}
                              {%- endif -%}
                              {%- if include_value -%}
                                {%- if value_output_index > 0 -%},{%- endif -%}
                                {
                                  "label": {{ value.label | json }},
                                  "value": {{ value.value | json }},
                                  "count": {{ value.count | json }},
                                  "active": {{ value.active | json }},
                                  "url": {{ value.url | json }}
                                }
                                {%- assign value_output_index = value_output_index | plus: 1 -%}
                              {%- endif -%}
                            {%- endunless -%}
                          {%- endfor -%}
                        ]
                        {%- if is_color_filter -%}
                          ,"swatchValues": [
                            {%- assign swatch_output_index = 0 -%}
                            {%- comment -%} Paginate swatchValues to handle >250 color values {%- endcomment -%}
                            {%- for value in filter.values limit: 250 -%}
                              {%- unless value.label == 'False' -%}
                                {%- assign swatch_image = '' -%}
                                {%- if value.swatch.image -%}
                                  {%- assign swatch_image = value.swatch.image | image_url: width: 128 -%}
                                {%- elsif color_family_lookup != '' -%}
                                  {%- assign lookup_entries = color_family_lookup | split: ',' -%}
                                  {%- for entry in lookup_entries -%}
                                    {%- assign entry_parts = entry | split: '|' -%}
                                    {%- if entry_parts[0] == value.label -%}
                                      {%- assign swatch_image = entry_parts[1] -%}
                                      {%- break -%}
                                    {%- endif -%}
                                  {%- endfor -%}
                                {%- endif -%}
                                {%- if swatch_output_index > 0 -%},{%- endif -%}
                                {
                                  "label": {{ value.label | json }},
                                  "value": {{ value.value | json }},
                                  "count": {{ value.count | json }},
                                  "active": {{ value.active | json }},
                                  "url": {{ value.url | json }},
                                  "swatchImage": {{ swatch_image | json }},
                                  "swatchColor": {{ value.swatch.color | default: '' | json }}
                                }
                                {%- assign swatch_output_index = swatch_output_index | plus: 1 -%}
                              {%- endunless -%}
                            {%- endfor -%}
                            {%- for value in filter.values limit: 250 offset: 250 -%}
                              {%- unless value.label == 'False' -%}
                                {%- assign swatch_image = '' -%}
                                {%- if value.swatch.image -%}
                                  {%- assign swatch_image = value.swatch.image | image_url: width: 128 -%}
                                {%- elsif color_family_lookup != '' -%}
                                  {%- assign lookup_entries = color_family_lookup | split: ',' -%}
                                  {%- for entry in lookup_entries -%}
                                    {%- assign entry_parts = entry | split: '|' -%}
                                    {%- if entry_parts[0] == value.label -%}
                                      {%- assign swatch_image = entry_parts[1] -%}
                                      {%- break -%}
                                    {%- endif -%}
                                  {%- endfor -%}
                                {%- endif -%}
                                {%- if swatch_output_index > 0 -%},{%- endif -%}
                                {
                                  "label": {{ value.label | json }},
                                  "value": {{ value.value | json }},
                                  "count": {{ value.count | json }},
                                  "active": {{ value.active | json }},
                                  "url": {{ value.url | json }},
                                  "swatchImage": {{ swatch_image | json }},
                                  "swatchColor": {{ value.swatch.color | default: '' | json }}
                                }
                                {%- assign swatch_output_index = swatch_output_index | plus: 1 -%}
                              {%- endunless -%}
                            {%- endfor -%}
                            {%- for value in filter.values limit: 250 offset: 500 -%}
                              {%- unless value.label == 'False' -%}
                                {%- assign swatch_image = '' -%}
                                {%- if value.swatch.image -%}
                                  {%- assign swatch_image = value.swatch.image | image_url: width: 128 -%}
                                {%- elsif color_family_lookup != '' -%}
                                  {%- assign lookup_entries = color_family_lookup | split: ',' -%}
                                  {%- for entry in lookup_entries -%}
                                    {%- assign entry_parts = entry | split: '|' -%}
                                    {%- if entry_parts[0] == value.label -%}
                                      {%- assign swatch_image = entry_parts[1] -%}
                                      {%- break -%}
                                    {%- endif -%}
                                  {%- endfor -%}
                                {%- endif -%}
                                {%- if swatch_output_index > 0 -%},{%- endif -%}
                                {
                                  "label": {{ value.label | json }},
                                  "value": {{ value.value | json }},
                                  "count": {{ value.count | json }},
                                  "active": {{ value.active | json }},
                                  "url": {{ value.url | json }},
                                  "swatchImage": {{ swatch_image | json }},
                                  "swatchColor": {{ value.swatch.color | default: '' | json }}
                                }
                                {%- assign swatch_output_index = swatch_output_index | plus: 1 -%}
                              {%- endunless -%}
                            {%- endfor -%}
                            {%- for value in filter.values limit: 250 offset: 750 -%}
                              {%- unless value.label == 'False' -%}
                                {%- assign swatch_image = '' -%}
                                {%- if value.swatch.image -%}
                                  {%- assign swatch_image = value.swatch.image | image_url: width: 128 -%}
                                {%- elsif color_family_lookup != '' -%}
                                  {%- assign lookup_entries = color_family_lookup | split: ',' -%}
                                  {%- for entry in lookup_entries -%}
                                    {%- assign entry_parts = entry | split: '|' -%}
                                    {%- if entry_parts[0] == value.label -%}
                                      {%- assign swatch_image = entry_parts[1] -%}
                                      {%- break -%}
                                    {%- endif -%}
                                  {%- endfor -%}
                                {%- endif -%}
                                {%- if swatch_output_index > 0 -%},{%- endif -%}
                                {
                                  "label": {{ value.label | json }},
                                  "value": {{ value.value | json }},
                                  "count": {{ value.count | json }},
                                  "active": {{ value.active | json }},
                                  "url": {{ value.url | json }},
                                  "swatchImage": {{ swatch_image | json }},
                                  "swatchColor": {{ value.swatch.color | default: '' | json }}
                                }
                                {%- assign swatch_output_index = swatch_output_index | plus: 1 -%}
                              {%- endunless -%}
                            {%- endfor -%}
                          ]
                        {%- endif -%}
                      }
                      {%- assign filter_output_index = filter_output_index | plus: 1 -%}
                    {%- endfor -%}
                  ]
                }
              </script>
            {%- endpaginate -%}
          </div>

          {%- comment -%} Static filter drawer for no-JS fallback {%- endcomment -%}
          <noscript>
            {%- render 'search-filters', search: search -%}
          </noscript>

          {%- comment -%} SMP Color Metaobject JSON for React filter drawer {%- endcomment -%}
          <script class="js-swatches-metaobject-json" type="application/json">
            {
              {%- for color_family in shop.metaobjects.product_color_families.values -%}
                {{ color_family.handle_name | json }}: [{
                  "color_icon": {{ color_family.color_image | image_url: width: 128 | json }},
                  "color_name": {{ color_family.handle_name | json }}
                }]{%- unless forloop.last -%},{%- endunless -%}
              {%- endfor -%}
            }
          </script>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} Pages/Articles Tab {%- endcomment -%}
    <div
      class="js-search-pages SearchPage-tabContent{% if active_tab == 'pages' %} active{% endif %}"
      role="tabpanel"
      aria-labelledby="pagesTab"
      data-search-panel="pages"
    >
      {%- paginate search.results by 12 -%}
        <div id="SearchPages-ajaxinate" class="Grid Grid--alignLeft view-three">
          {%- for item in search.results -%}
            {% if item.object_type == 'article' -%}
              <article class="SearchResult">
                <a href="{{ item.url }}" class="SearchResult-imageLink" title="{{ item.title | escape }}">
                  {%- if item.image -%}
                    <div class="SearchResult-image">
                      <div
                        class="SearchResult-imagePlaceholder"
                        {% if item.image %}
                          style="background-image: url('{{ item.image.src | image_url: width: 960 }}');"
                        {% endif %}
                      ></div>
                    </div>
                  {%- endif -%}
                  <div class="SearchResult-info">
                    <h4 class="SearchResult-title">
                      {{ item.title | link_to: item.url }}
                    </h4>
                    {%- assign result_excerpt = item.content | default: '' | strip_html | truncatewords: 50 -%}
                    {%- if result_excerpt != blank -%}
                      <div class="SearchResult-excerpt">
                        {{ result_excerpt }}
                      </div>
                    {% endif %}
                  </div>
                </a>
              </article>
            {% endif %}
          {%- endfor -%}
        </div>

        {%- if total_post_count > 12 -%}
          <div data-search-pagination-wrapper class="SearchPage-pagesPagination">
            {%- render 'search-pagination', paginate: paginate, search_terms: search.terms -%}
          </div>
        {% endif %}
      {%- endpaginate -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Search",
  "class": "js-section-search Search-section",
  "settings": [
    {
      "type": "range",
      "id": "hits_per_page",
      "min": 8,
      "max": 48,
      "step": 1,
      "label": "Products per page",
      "default": 24
    },
    {
      "type": "collection",
      "id": "bestsellers_collection",
      "label": "Bestsellers collection",
      "info": "Shown on the no-results page as a carousel"
    },
    {
      "type": "text",
      "id": "bestsellers_heading",
      "label": "Bestsellers heading",
      "default": "Bestsellers",
      "info": "Title above the no-results bestsellers carousel"
    }
  ],
  "blocks": [
    {
      "type": "filter_pill",
      "name": "Filter Pill",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Pill Label"
        },
        {
          "type": "text",
          "id": "tag_value",
          "label": "Product Tag",
          "info": "Exact product tag to filter by (e.g. Licensed:Disney). Must match a tag on your products."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Search",
      "settings": {}
    }
  ]
}
{% endschema %}
