{%- liquid
  assign header = section.settings.header | default: 'Product Lines'
-%}
{%- if section.blocks.size > 0 -%}
  <section class="mod_featured_products_UbFoKG_FeaturedProducts">
    {%- if header and header != blank -%}
      <h2 class="mod_featured_products_UbFoKG_FeaturedProducts__header">
        {{ header }}
      </h2>
    {%- endif -%}

    <div
      class="mod_featured_products_UbFoKG_FeaturedProducts__nav"
      data-hide-nav="{%- if section.blocks.size == 1 -%}true{%- endif -%}"
      role="tablist"
    >
      <div class="swiper js-featured-products-nav" aria-label="carousel">
        <div class="swiper-wrapper">
          {%- for block in section.blocks -%}
            {%- assign coll_help = block.settings.coll | default: '' -%}
            {%- assign coll = collections[coll_help] | default: '' -%}
            {%- assign title = block.settings.title | default: '' -%}
            <button
              id="featured-products-tab-{{ forloop.index0 }}"
              class="mod_featured_products_UbFoKG_FeaturedProducts__navItem js-featured-products-nav-item swiper-slide"
              title="Show {{ title }} collection"
              tabindex="0"
              collection-name="{{ coll.handle }}"
              collection-url="{{ coll.url }}"
              aria-selected="{{ forloop.first | json }}"
              aria-controls="featured-products-carousel-{{ forloop.index0 }}"
              role="tab"
            >
              {{ title }}
            </button>
          {%- endfor -%}
          <a
            href="{{ collections[section.blocks[0].settings.coll].url }}"
            class="mod_featured_products_UbFoKG_FeaturedProducts__navAll js-featured-products-nav-all swiper-slide"
            >discover all</a
          >
        </div>

        <div class="swiper-scrollbar"></div>
      </div>
    </div>

    <div role="tabpanel" aria-labelledby="featured-products-tab-0" tabindex="0">
      <div
        role="region"
        aria-label="{{ section.settings.header | handleize }} carousel"
        class="mod_featured_products_UbFoKG_FeaturedProducts__carousel swiper js-featured-products-carousel"
      >
        <div class="swiper-wrapper js-featured-products-carousel-content"></div>
        <div
          class="mod_featured_products_UbFoKG_FeaturedProducts__carousel__actions"
          aria-live="assertive"
          aria-atomic="true"
        >
          <div class="u-hide" id="SwiperLive"></div>
          <div class="mod_featured_products_UbFoKG_FeaturedProducts__carousel__scrollbar__wrapper">
            <div class="swiper-scrollbar"></div>
          </div>
          <button aria-label="Previous slide" class="swiper-button-prev">
            {%- render 'icon-arrow-prev' -%}
          </button>
          <button aria-label="Next slide" class="swiper-button-next">
            {%- render 'icon-arrow-next' -%}
          </button>
        </div>
      </div>
    </div>
  </section>
  <style>
    .mod_featured_products_UbFoKG_FeaturedProducts {
      --mod_featured_products_UbFoKG_arrows-color: {{ settings.arrows_color | default: '#000000' }};
      --mod_featured_products_UbFoKG_scrollbar-color: {{ section.settings.scrollbar_color }};
      --mod_featured_products_UbFoKG_scrollbar-bg-color: {{ section.settings.scrollbar_background_color }};
    }
  </style>
{%- endif -%}

