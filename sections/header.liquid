    {
      "type": "banner",
      "name": "Dropdown Banner",
      "settings": [
        {
          "type": "image_picker",
          "id": "banner_background",
          "label": "Background Image"
        },
        {
          "type": "image_picker",
          "id": "banner_logo",
          "label": "Logo"
        },
        {
          "type": "richtext",
          "id": "banner_description",
          "label": "Description"
        },
        {
          "type": "url",
          "id": "banner_link",
          "label": "Banner Link"
        },
        {
