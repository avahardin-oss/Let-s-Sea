                </svg>
              </div>
            {% endif %}
          </a>
        </div>
      </div>
      <nav aria-label="Primary" class="Header-section is-middle">
        {%- liquid
          assign main_menu = linklists[section.settings.main_linklist]
          if customer.b2b? == true
            assign main_menu = linklists[section.settings.main_b2b_linklist]
          endif
        -%}
        <div
          id="js-header-menu"
          class="HeaderMenu"
          role="navigation"
        >
          <ul class="HeaderMenu-items">
            {% liquid
              assign megamenu_threshold = section.settings.megamenu_threshold | default: 75 | times: 1
              assign third_level_percentage = 0
            %}

            {% for toplink in main_menu.links %}
              {% liquid
                assign toplink_utf_handle = toplink.title | strip | replace: ' ', '-' | url_encode | handle

                assign midlist = false
                for linklist in linklists
                  assign list_utf_handle = linklist.title | strip | replace: ' ', '-' | url_encode | handle
                  if list_utf_handle == toplink_utf_handle
                    assign midlist = linklist
                  endif
                endfor
              %}

              {% comment %}
                Calculate megamenu activation breakpoint
              {% endcomment %}
              {% liquid
                if midlist and midlist.links.size > 1
                  assign third_level_lists = 0
                  for midlink in midlist.links
                    assign midlink_utf_handle = midlink.title | strip | replace: ' ', '-' | url_encode | handle
                    if midlink_utf_handle == toplink_utf_handle
                      continue
                    endif

                    assign bottomlist = false
                    for linklist in linklists
                      assign list_utf_handle = linklist.title | strip | replace: ' ', '-' | url_encode | handle
                      if list_utf_handle == midlink_utf_handle
                        assign bottomlist = linklist
                      endif
                    endfor

                    if bottomlist and bottomlist.links.size > 0
                      assign third_level_lists = third_level_lists | plus: 1
                    endif
                  endfor
                  assign third_level_percentage = third_level_lists | times: 100 | divided_by: midlist.links.size
                endif
              %}

              <li
                class="js-header-menu-item HeaderMenu-item {% if midlist and midlist.links.size > 0 %}has-dropdown {% if third_level_percentage >= megamenu_threshold %}has-megaMenu js-mega-menu-trigger{% endif %}{% endif %}"
                data-megamenu-percentage="{{ third_level_percentage }}"
                data-mega-menu="{{ toplink.title | handleize }}"
                aria-label="{{ toplink.title | handleize }} menu"
                tabindex="0"
              >
                <a
                  class="HeaderMenu-itemLink event-navLink{% if toplink.active %} is-active{% endif %}"
                  href="{{ toplink.url }}"
                  id="header-menu-item-{{ toplink.title | handleize }}"
                >
                  {{ toplink.title }}
                  {% if midlist and midlist.links.size > 0 %}
                    <svg
                      aria-labelledby="title41-{{toplink.title}}"
                      role="img"
                      width="12"
                      height="7"
                      viewBox="0 0 12 7"
                      fill="none"
                      xmlns="http://www.w3.org/2000/svg"
                      aria-hidden="true"
                    >
                      <title id="title41-{{ toplink.title }}">Arrow down icon</title>

                      <path
                        d="M1.00195 0.813476L6.00195 5.81348L11.002 0.813476"
                        stroke="black"
                        stroke-width="1.5" />
                    </svg>
                  {% endif %}
                </a>
                {% render 'header-dropdown', toplink: toplink, themes: section.blocks %}
              </li>
            {% endfor %}
          </ul>
          {% comment %}
            <button type="button" class="js-header-menu-toggle HeaderMenu-toggle is-hidden">
              <span class="u-vhide">
              {{ 'header.menu.toggle' | t }}
              </span>
              <div class="o-placeholder">
              {% render 'svg-header-menu-toggle' %}
              </div>
              <div class="js-header-menu-toggle-dropdown HeaderDropdown"></div>
            </button>
          {% endcomment %}
        </div>
      </nav>
      <nav aria-label="Action" class="Header-section is-right">
        <div class="u-pos-static">
          {%- comment -%}
            Real search button — server-rendered, always visible from first paint.
            React attaches its click handler here; no duplicate button is rendered.
          {%- endcomment -%}
          <button
            type="button"
            class="Header__link-icon Header__link-icon--search js-search-btn"
            aria-label="Search"
          >
            <div class="Header-icon">
              <div class="o-placeholder">
                <svg width="24" height="26" viewBox="0 0 24 26" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <title>Magnifying glass icon</title>
                  <circle cx="11.6863" cy="12" r="8" transform="rotate(-45 11.6863 12)" stroke="black" fill="#fff" />
                  <path d="M16.9287 17.6569L22.5856 23.3137" stroke="black" />
                </svg>
              </div>
            </div>
            <div class="Header-iconText">Search</div>
          </button>
          {%- comment -%} React mounts only the search modal overlay here {%- endcomment -%}
          <div class="js-search-container"></div>
        </div>

        {% capture header_icons %}
          account,/account,{{ 'general.nav_icons.account' | t }};
          cart,/cart,{{ 'general.nav_icons.cart' | t }},offcanvas
        {% endcapture %}
        {% assign header_icons = header_icons | strip_newlines | strip | split: ';' %}

        {% for item in header_icons %}
          {% liquid
            assign item_parts = item | strip | split: ','
            assign item_name = item_parts[0]
            assign item_url = item_parts[1]
            assign item_text = item_parts[2]

            if item_name == 'account' and shop.customer_accounts_enabled == false
              continue
            endif
          %}

          <a
            class="Header-iconLink{% if item_name == 'cart' %} event-navCart{% elsif item_name == 'account' %} event-navAccount{% endif %}{% if item_parts[3] and settings.ajax_cart_enabled == true %} js-offcanvas-trigger{% endif %}"
            href="{{ item_url }}"
            {% if item_parts[3] %}
              data-drawer-name="{{ item_name }}"
            {% endif %}
            title="{{ item_text | escape }}"
          >
            <div class="Header-icon">
              {% if item_name == 'cart' %}
                <div
                  class="js-cart-item-count Header-cartItemCount"
                  data-item-count="{{ cart.item_count }}"
                  aria-label="{{ cart.item_count }} products in the cart"
                ></div>
              {% endif %}

              <div class="o-placeholder {% if item_name == 'cart' %}Header-iconCart{% elsif item_name == 'search' %}Header-iconSearch{% endif %}">
                {%- liquid
                  case item_name
                    when 'account'
                      render 'svg-header-nav-account'
                    when 'cart'
                      render 'svg-header-nav-cart'
                  endcase
                -%}
              </div>
            </div>
            {% if section.settings.icon_labels_enabled %}
              <div class="Header-iconText {% if item_name == 'cart' %}Header-iconText-cart{% elsif item_name == 'search' %}Header-iconText-search{% endif %}">
                {{ item_text }}
              </div>
            {% endif %}
          </a>
        {% endfor %}
      </nav>
    </div>
  </div>
</header>

{% unless template contains 'page'
  or template contains 'blog'
  or template contains 'article'
  or template contains 'product'
%}
  {% render 'breadcrumbs' %}
{% endunless %}

{% assign tab_bar_items = linklists[section.settings.featured_links] %}
{% if tab_bar_items != blank and request.page_type == 'index' %}
  <nav class="MobileTabFeatured">
    <ul class="MobileTabFeatured-items">
      {% for item in tab_bar_items.links limit: 3 %}
        <li class="MobileTabFeatured-item">
          <a
            class="MobileTabFeatured-itemLink"
            href="{{ item.url }}"
            title="{{ item.title | escape }}"
          >
            {{- item.title -}}
          </a>
        </li>
      {% endfor %}
    </ul>
  </nav>
{% endif %}
{% render 'offcanvas' %}
<div class="ProductCustomizer-wrapper js-customizer-wrapper" data-customizer-close="true">
  <div id="spectrum-customizer"></div>
</div>
