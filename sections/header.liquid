          class="Header-mobButton Header-mobileMenu Icon js-offcanvas-trigger"
          data-drawer-name="menu"
          title="{{ 'general.nav_icons.browse' | t }}"
          aria-label="Menu"
        >
          <span class="u-vhide">{{ 'general.nav_icons.browse' | t }}</span>
          <div class="Header-hamburger">
            <span></span>
            <span></span>
            <span></span>
          </div>
        </button>
        <div class="Header-logo">
          <a class="Header-logoLink" href="{{ shop.url }}">
            {% if section.settings.logo %}
              <div class="Header-logoImagePlaceholder o-placeholder">
                {% if template == 'index' %}
                  <h1 class="u-vhide">
                    {{ shop.name }}
                  </h1>
                {% else %}
                  <div class="u-vhide">
                    {{ shop.name }}
                  </div>
                {% endif %}
              </div>
              <style>
                .Header-logoImagePlaceholder {
                  background-image: url("{{ section.settings.logo | image_url: width: 640 }}");
                }
              </style>
            {% else %}
