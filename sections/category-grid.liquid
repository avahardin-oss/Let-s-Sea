        class="swiper js-category-grid-carousel mod_category_grid_hYTWoa_CategoryGrid__carousel"
      >
        <p class="sr-only">This is a carousel with scrollable slides. Use Next and Previous buttons to navigate.</p>

        <div class="swiper-wrapper mod_category_grid_hYTWoa_CategoryGrid__wrapper">
          {%- for block in section.blocks -%}
            {%- liquid
              assign block_title = block.settings.title
              assign block_subtitle = block.settings.subtitle
              assign block_image = block.settings.image
              assign block_link = block.settings.link
              assign block_cta = block.settings.cta
            -%}

            <div
              {{ block.shopify_attributes }}
              class="swiper-slide mod_category_grid_hYTWoa_CategoryGrid__slide"
              role="group"
              aria-label="category card"
            >
              {%- if block_link != blank -%}
                <a
                  href="{{ block_link }}"
                  class="mod_category_grid_hYTWoa_CategoryGrid__card mod_category_grid_hYTWoa_CategoryGrid__card--clickable"
                >
              {%- else -%}
                <div class="mod_category_grid_hYTWoa_CategoryGrid__card">
              {%- endif -%}
              {%- if block_image != blank -%}
                <div class="mod_category_grid_hYTWoa_CategoryGrid__image-wrapper">
                  <img
                    src="{{ block_image | image_url: width: 656 }}"
                    srcset="
                      {{ block_image | image_url: width: 328 }} 328w,
