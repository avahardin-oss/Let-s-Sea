              <div class="mod_category_grid_hYTWoa_CategoryGrid__content">
                <div class="mod_category_grid_hYTWoa_CategoryGrid__text">
                  {%- if block_title != blank -%}
                    <h3 class="mod_category_grid_hYTWoa_CategoryGrid__card-title">{{ block_title }}</h3>
                  {%- endif -%}
                  {%- if block_subtitle != blank -%}
                    <p class="mod_category_grid_hYTWoa_CategoryGrid__card-subtitle">{{ block_subtitle }}</p>
                  {%- endif -%}
                </div>

                {%- if block_cta != blank or block_link != blank -%}
                  <span class="mod_category_grid_hYTWoa_CategoryGrid__cta">
                    {{ block_cta | default: 'Shop now' }}
