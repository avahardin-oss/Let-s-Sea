{% liquid
  assign current_variant = product.selected_or_first_available_variant

  assign custom_type = ''
  for tag in product.tags
    if tag == 'customize:embroidery'
      assign custom_type = 'embroidery'
      assign custom_collection = collections['customizer-embroidery']
    elsif tag == 'customize:engrave'
      assign custom_type = 'engrave'
      assign custom_collection = collections['customizer-engraving']
    endif
  endfor
%}

<script class="js-customizer-data" type="application/json">
  {
    "currentSku": {{ current_variant.sku | json }},
    "productVariants": [
    {% paginate custom_collection.products by 1000 %}
      {% for prod in custom_collection.products %}
        {% assign prod_price = prod.price | money_without_currency %}
        {
          "sku": {{prod.variants[0].sku | json }},
          "name": {{prod.title | json }},
          "type":"baseProduct",
          "price":{{ prod_price | json }},
          "listPrice":{{prod_price | json }},
          "isoCurrency":"USD",
          "inStock":true,

          "options":
            {
              "stock":null,
              "discontinuedStatus":false,
              "lowestPrice":null
            }
        },
      {% endfor %}
    {% endpaginate %}
    {% if custom_type == 'engrave' %}
      {
        "sku":"SM-PERS-ENGR",
        "name":"Personalized Engraving",
        "type":"baseProduct",
        "price":8.00,
        "listPrice":8.00,
        "isoCurrency":"USD",
        "inStock":true,
        "options":
          {
            "stock":null,
            "discontinuedStatus":false,
            "lowestPrice":null
          }
      },
      {
        "sku":"SM-PERS-ENGR-2",
        "name":"Personalized Engraving - Two Sides",
        "type":"baseProduct",
        "price":12.00,
        "listPrice":12.00,
        "isoCurrency":"USD",
        "inStock":true,
        "options":
          {
            "stock":null,
            "discontinuedStatus":false,
            "lowestPrice":null
          }
      }
    {% elsif custom_type == 'embroidery' %}
      {
        "sku":"SM-PERS-STITCH",
        "name":"Personalized Embroidery",
        "type":"baseProduct",
        "price":10.00,
        "listPrice":10.00,
        "isoCurrency":"USD",
        "inStock":true,
        "options":
          {
            "stock":null,
            "discontinuedStatus":false,
            "lowestPrice":null
          }
      }
    {% endif %}
  ]
  }
</script>
