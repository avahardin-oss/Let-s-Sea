<style>
  #quiz-section-{{ section.id }} {
    --quiz-accent: {{ section.settings.accent_color }};
    background-color: {{ section.settings.bg_color }};
    padding: 3rem 1.25rem;
  }

  @media (min-width: 768px) {
    #quiz-section-{{ section.id }} {
      padding: 5rem 2rem;
    }
  }

  #quiz-section-{{ section.id }} .QuizSection-inner {
    max-width: 600px;
    margin: 0 auto;
  }

  #quiz-section-{{ section.id }} .QuizSection-progress-wrapper {
    margin-bottom: 2rem;
  }

  #quiz-section-{{ section.id }} .QuizSection-step-count {
    display: block;
    text-align: center;
    font-family: "Gilroy", sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #aaa;
    margin-bottom: 0.5rem;
  }

  #quiz-section-{{ section.id }} .QuizSection-progress {
    height: 4px;
    background: #e5e5e5;
    border-radius: 2px;
    overflow: hidden;
  }

  #quiz-section-{{ section.id }} .QuizSection-bar {
    height: 100%;
    width: 0%;
    background: var(--quiz-accent);
    border-radius: 2px;
    transition: width 0.35s ease;
  }

  #quiz-section-{{ section.id }} .QuizSection-title {
    font-family: "Gilroy", sans-serif;
    font-weight: 900;
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    text-align: center;
    margin: 0 0 0.5rem;
    line-height: 1.15;
  }

  #quiz-section-{{ section.id }} .QuizSection-intro {
    text-align: center;
    color: #555;
    margin: 0 0 2rem;
    font-size: 1rem;
    line-height: 1.5;
  }

  #quiz-section-{{ section.id }} [data-quiz-step] {
    display: none;
  }

  #quiz-section-{{ section.id }} [data-quiz-step].is-active {
    display: block;
    animation: quizFadeIn-{{ section.id }} 0.22s ease;
  }

  @keyframes quizFadeIn-{{ section.id }} {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  #quiz-section-{{ section.id }} .QuizSection-question {
    font-family: "Gilroy", sans-serif;
    font-weight: 700;
    font-size: clamp(1.1rem, 3vw, 1.35rem);
    text-align: center;
    margin: 0 0 1.5rem;
    line-height: 1.3;
  }

  #quiz-section-{{ section.id }} .QuizSection-options {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  #quiz-section-{{ section.id }} .QuizSection-option {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
    min-height: 3rem;
    padding: 0.875rem 1.25rem;
    background: #fff;
    border: 2px solid #e5e5e5;
    border-radius: 0.75rem;
    font-family: "Gilroy", sans-serif;
    font-size: 1rem;
    font-weight: 600;
    text-align: left;
    cursor: pointer;
    transition: border-color 0.15s ease, background-color 0.15s ease;
    -webkit-tap-highlight-color: transparent;
  }

  #quiz-section-{{ section.id }} .QuizSection-option:hover,
  #quiz-section-{{ section.id }} .QuizSection-option:focus-visible {
    border-color: var(--quiz-accent);
    background-color: #f5f5f5;
    outline: none;
  }

  #quiz-section-{{ section.id }} .QuizSection-option:focus-visible {
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--quiz-accent) 25%, transparent);
  }

  #quiz-section-{{ section.id }} .QuizSection-option-icon {
    font-size: 1.25rem;
    flex-shrink: 0;
    line-height: 1;
  }

  #quiz-section-{{ section.id }} .QuizSection-back {
    display: block;
    margin-top: 1.25rem;
    padding: 0.25rem 0;
    background: none;
    border: none;
    font-family: "Gilroy", sans-serif;
    font-size: 0.9rem;
    color: #888;
    cursor: pointer;
    transition: color 0.15s;
  }

  #quiz-section-{{ section.id }} .QuizSection-back:hover {
    color: #000;
  }

  #quiz-section-{{ section.id }} .QuizSection-result-label {
    font-family: "Gilroy", sans-serif;
    font-weight: 900;
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    text-align: center;
    margin: 0 0 0.5rem;
  }

  #quiz-section-{{ section.id }} .QuizSection-result-body {
    text-align: center;
    color: #555;
    margin: 0 0 1.5rem;
    font-size: 1rem;
    line-height: 1.5;
  }

  #quiz-section-{{ section.id }} .QuizSection-restart {
    display: block;
    margin: 1rem auto 0;
    padding: 0.25rem 0;
    background: none;
    border: none;
    font-family: "Gilroy", sans-serif;
    font-size: 0.875rem;
    color: #aaa;
    cursor: pointer;
    text-decoration: underline;
    transition: color 0.15s;
  }

  #quiz-section-{{ section.id }} .QuizSection-restart:hover {
    color: #000;
  }
</style>

{%- assign question_count = 0 -%}
{%- for block in section.blocks -%}
  {%- if block.type == 'question' -%}{%- assign question_count = question_count | plus: 1 -%}{%- endif -%}
{%- endfor -%}
<script id="quiz-data-{{ section.id }}" type="application/json">
  {
    "startId": {{ section.settings.start_id | json }},
    "maxDepth": {{ section.settings.max_depth | json }},
    "totalQuestions": {{ question_count }}
  }
</script>

<section id="quiz-section-{{ section.id }}" class="QuizSection">
  <div class="QuizSection-inner">
    <div class="QuizSection-header">
      {%- if section.settings.show_progress -%}
        <div class="QuizSection-progress-wrapper">
          <span class="QuizSection-step-count js-quiz-step-count" aria-live="polite"></span>
          <div
            class="QuizSection-progress"
            role="progressbar"
            aria-label="Quiz progress"
            aria-valuemin="0"
            aria-valuemax="100"
            aria-valuenow="0"
          >
            <div class="QuizSection-bar js-quiz-bar"></div>
          </div>
        </div>
      {%- endif -%}

      {%- if section.settings.quiz_title != blank -%}
        <h2 class="QuizSection-title">{{ section.settings.quiz_title }}</h2>
      {%- endif -%}

      {%- if section.settings.quiz_intro != blank -%}
        <p class="QuizSection-intro">{{ section.settings.quiz_intro }}</p>
      {%- endif -%}
    </div>

    <div class="js-quiz" data-section-id="{{ section.id }}">
      {%- for block in section.blocks -%}
        {%- if block.type == 'question' -%}
          <div
            class="QuizSection-step"
            data-quiz-step="{{ block.settings.question_id }}"
            data-step-type="question"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.question_text != blank -%}
              <p class="QuizSection-question">{{ block.settings.question_text }}</p>
            {%- endif -%}

            <ul class="QuizSection-options" role="list">
              {%- for i in (1..5) -%}
                {%- assign label_key = 'opt_' | append: i | append: '_label' -%}
                {%- assign label = block.settings[label_key] -%}
                {%- if label != blank -%}
                  {%- assign next_key = 'opt_' | append: i | append: '_next' -%}
                  {%- assign icon_key = 'opt_' | append: i | append: '_icon' -%}
                  <li>
                    <button
                      class="QuizSection-option js-quiz-answer"
                      data-next="{{ block.settings[next_key] }}"
                      type="button"
                    >
                      {%- if block.settings[icon_key] != blank -%}
                        <span class="QuizSection-option-icon" aria-hidden="true">{{ block.settings[icon_key] }}</span>
                      {%- endif -%}
                      <span>{{ label }}</span>
                    </button>
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}

      {%- for block in section.blocks -%}
        {%- if block.type == 'result' -%}
          {%- assign rp = block.settings.result_product -%}
          <div
            class="QuizSection-step QuizSection-result"
            data-quiz-step="{{ block.settings.result_id }}"
            data-step-type="result"
            {{ block.shopify_attributes }}
          >
            <p class="QuizSection-result-label">
              {{- block.settings.result_headline | default: 'Your Perfect Match' -}}
            </p>

            {%- if block.settings.result_body != blank -%}
              <p class="QuizSection-result-body">{{ block.settings.result_body }}</p>
            {%- endif -%}

            {%- if rp != blank -%}
              {%- render 'product-card', product: rp, title_tag: 'h3' -%}
            {%- endif -%}

            <button class="QuizSection-restart js-quiz-restart" type="button">Start over</button>
          </div>
        {%- endif -%}
      {%- endfor -%}

      <button class="QuizSection-back js-quiz-back" type="button" hidden>&#8592; Back</button>
    </div>
  </div>
</section>

<script src="{{ 'quiz.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Product Quiz",
  "tag": "section",
  "class": "QuizSection-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "quiz_title",
      "label": "Quiz title",
      "default": "Find Your Perfect Bottle"
    },
    {
      "type": "textarea",
      "id": "quiz_intro",
      "label": "Intro text",
      "default": "Answer a few quick questions and we'll find your match."
    },
    {
      "type": "header",
      "content": "Quiz logic"
    },
    {
      "type": "text",
      "id": "start_id",
      "label": "Starting question ID",
      "default": "q1",
      "info": "Must match the Question ID of your first question block."
    },
    {
      "type": "range",
      "id": "max_depth",
      "label": "Max questions in a path",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4,
      "info": "Used to calculate the progress bar percentage."
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "checkbox",
      "id": "show_progress",
      "label": "Show progress bar",
      "default": true
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#000000",
      "info": "Progress bar and option hover color."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section background",
      "default": "#f8f7f5"
    }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question_id",
          "label": "Question ID",
          "info": "Unique identifier, e.g. q1, q2. Other answers point to this ID to branch here."
        },
        {
          "type": "text",
          "id": "question_text",
          "label": "Question"
        },
        { "type": "header", "content": "Option 1" },
        { "type": "text", "id": "opt_1_label", "label": "Label" },
        { "type": "text", "id": "opt_1_next", "label": "Next step ID", "info": "Question ID or Result ID to go to." },
        { "type": "text", "id": "opt_1_icon", "label": "Icon (emoji)" },
        { "type": "header", "content": "Option 2" },
        { "type": "text", "id": "opt_2_label", "label": "Label" },
        { "type": "text", "id": "opt_2_next", "label": "Next step ID" },
        { "type": "text", "id": "opt_2_icon", "label": "Icon (emoji)" },
        { "type": "header", "content": "Option 3" },
        { "type": "text", "id": "opt_3_label", "label": "Label" },
        { "type": "text", "id": "opt_3_next", "label": "Next step ID" },
        { "type": "text", "id": "opt_3_icon", "label": "Icon (emoji)" },
        { "type": "header", "content": "Option 4" },
        { "type": "text", "id": "opt_4_label", "label": "Label" },
        { "type": "text", "id": "opt_4_next", "label": "Next step ID" },
        { "type": "text", "id": "opt_4_icon", "label": "Icon (emoji)" },
        { "type": "header", "content": "Option 5" },
        { "type": "text", "id": "opt_5_label", "label": "Label" },
        { "type": "text", "id": "opt_5_next", "label": "Next step ID" },
        { "type": "text", "id": "opt_5_icon", "label": "Icon (emoji)" }
      ]
    },
    {
      "type": "result",
      "name": "Result",
      "settings": [
        {
          "type": "text",
          "id": "result_id",
          "label": "Result ID",
          "info": "Unique identifier, e.g. r1, r-trek-mug. Answers point to this ID to land here."
        },
        {
          "type": "product",
          "id": "result_product",
          "label": "Recommended product"
        },
        {
          "type": "text",
          "id": "result_headline",
          "label": "Headline",
          "default": "Your Perfect Match"
        },
        {
          "type": "textarea",
          "id": "result_body",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Quiz"
    }
  ]
}
{% endschema %}
