{%- liquid
  assign description = section.settings.description
  assign heading = section.settings.heading
-%}

<section class="ContactForm">

    <div class="ContactForm-formContainer">

      {%- if description -%}
        <div class="ContactForm--description">
          {{ description }}
        </div>
      {%- endif -%}

      {%- if heading -%}
        <h2 class="ContactForm--title">
          {{ heading }}
        </h2>
      {%- endif -%}

      {%- form 'contact' -%}
        <div class="ContactForm-form">

          {%- if form.errors -%}
            <div class="o-formErrors">
              <p>{{ 'contact_form.feedback.errors' | t }}</p>
              {{ form.errors | default_errors }}
            </div>
          {%- endif -%}

          {%- if form.posted_successfully? -%}
            <div class="o-formSuccess">
              {{ 'contact_form.feedback.success_html' | t }}
            </div>
          {%- else -%}
            <p>* Required field</p>

            <label class="ContactForm--label" for="contactFormName">
              {{ 'contact_form.labels.name' | t }} <span>*</span>
            </label>
            <input type="text" name="contact[name]" id="contactFormName" class="ContactForm--field" required autocomplete="name" />

            <label class="ContactForm--label" for="contactFormEmail">
              {{ 'contact_form.labels.email' | t }} <span>*</span>
            </label>
            <input type="email" name="contact[email]" id="contactFormEmail" class="ContactForm--field" required autocomplete="email" />

            <label class="ContactForm--label" for="contactFormPhone">
              {{ 'contact_form.labels.phone' | t }} <span>*</span>
            </label>
            <input type="tel" name="contact[phone]" id="contactFormPhone" class="ContactForm--field" required autocomplete="tel" />

            <label class="ContactForm--label" for="contactFormMessage">
              {{ 'contact_form.labels.message' | t }} <span>*</span>
            </label>
            <textarea name="contact[body]" id="contactFormMessage" class="ContactForm--textarea" rows="11" required></textarea>

            <div class="ContactForm--buttonContainer">
              <button type="submit" class="ContactForm--button btn reverse">
                {{ 'contact_form.labels.send' | t }}
              </button>
            </div>
          {%- endif -%}

        </div>
      {%- endform -%}
    </div>

    <div class="ContactForm-blockContainer">

      {%- for block in section.blocks -%}
        <div class="ContactForm-blocks">
          {% if block.settings.title != blank %}
            <h3 class="ContactForm-blocks--title">{{ block.settings.title }}</h3>
          {% endif %}
          {% if block.settings.text != blank %}
            <div class="ContactForm-blocks--text">{{ block.settings.text }}</div>
          {% endif %}
          {% if block.settings.small_text != blank %}
            <div class="ContactForm-blocks--smallText">{{ block.settings.small_text }}</div>
          {% endif %}
        </div>
      {%- endfor -%}

    </div>

</section>

{% schema %}
  {
  "name": "Contact",
  "settings": [
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Leave Us a message"
    }
  ],
  "blocks": [
    {
      "name": "Block",
      "type": "block",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Email"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text"
        },
        {
          "type": "richtext",
          "id": "small_text",
          "label": "Small Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Contact"
    }
  ]
}
{% endschema %}
