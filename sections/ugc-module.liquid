          {%- endif -%}

          {%- if link != blank and link_text != blank -%}
            <a
              {% if is_open_in_new_tab %}
                target="_blank"
              {% endif %}
              href="{{- link -}}"
              class="btn reverse mod_ugc_module_ivmfda_UGCModule__link"
            >
              {{- link_text -}}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}

      <div class="swiper-wrapper mod_ugc_module_ivmfda_UGCModule__list">
        {%- for block in section.blocks -%}
          {%- assign media_type = block.settings.media_type -%}
          {%- assign image = block.settings.image -%}
          {%- assign image_url = block.settings.image_url -%}
          {%- assign video = block.settings.video -%}
          {%- assign youtube_id = block.settings.youtube_id -%}

          <div {{ block.shopify_attributes }} class="swiper-slide mod_ugc_module_ivmfda_UGCModule__slide">
            {%- if media_type == 'image' and image != blank -%}
              {%- if image_url != blank -%}
                <a class="mod_ugc_module_ivmfda_UGCModule__slide-link" href="{{- image_url -}}"></a>
              {%- endif -%}

              <img
                src="{{- image | img_url: '560x' -}}"
                alt="{{- image.alt -}}"
                width="{{- image.width -}}"
                height="{{- image.height -}}"
              >
            {%- elsif media_type == 'video' and video != blank -%}
