  {%- assign is_open_in_new_tab = section.settings.is_open_in_new_tab -%}

  <ugc-module class="mod_ugc_module_ivmfda_UGCModule">
    <div class="swiper js-init-ugc-module-slider mod_ugc_module_ivmfda_UGCModule__carousel" role="region" aria-label="carousel">
      <p class="sr-only">{{- 'accessibility.slider_text' | t -}}</p>

      {%- if title != blank or link != blank and link_text != blank -%}
