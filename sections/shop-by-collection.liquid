{%- liquid
  assign header = section.settings.header | default: 'Find your Favorite Collection'
-%}
{%- if section.blocks.size > 0 -%}
  <section class="mod_shop_by_collection_owrRya_ShopByCollection">
    {%- if header and header != blank -%}
      <h2 class="mod_shop_by_collection_owrRya_ShopByCollection__header">
        {{ header }}
      </h2>
    {%- endif -%}

    {% comment %} Navigation Slider  {% endcomment %}
    <div class="mod_shop_by_collection_owrRya_ShopByCollection__nav">
      <div class="mod_shop_by_collection_owrRya_ShopByCollection__nav__content" role="tablist">
        {%- for block in section.blocks -%}
          {%- liquid
            assign nav_image = block.settings.mainCollectionImage
            assign coll = collections[block.settings.coll] | default: ''
          -%}
          {%- if coll != '' -%}
            <div
              class="mod_shop_by_collection_owrRya_ShopByCollection__navItem js-favorite-slider-nav-item"
              id="tab-{{ coll.handle }}"
              role="tab"
              aria-controls="tabpanel-{{ coll.handle }}"
              aria-selected="{{ forloop.first | default: 'false' }}"
              tabindex="0"
              collection-name="{{ coll.handle }}"
            >
              <img
                src="{{ nav_image | image_url }}"
                width="{{ nav_image.width }}"
                height="{{ nav_image.height }}"
                alt="{{ coll.handle }} logo"
                loading="lazy"
              >
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    {% comment %} Mobile Featured Card  {% endcomment %}
    <div class="mobile featured-card-wrapper">
      {%- for block in section.blocks -%}
        {%- liquid
          assign coll_handle = collections[block.settings.coll].handle | default: ''
          assign nav_image = block.settings.mainCollectionImage
          capture featured_card_mobile
            render 'print-image-sizes', image: block.settings.featuredCard
          endcapture
        -%}
        {%- if coll_handle != '' -%}
          <div
            class="mod_shop_by_collection_owrRya_ShopByCollection__featured__wrapper js-featured-card-mobile u-hideMd__flex u-vhide"
            data-collection="{{ coll_handle }}"
            onclick="location.href='/collections/{{ coll_handle }}';"
          >
            <div class="mod_shop_by_collection_owrRya_ShopByCollection__content">
              <div class="mod_shop_by_collection_owrRya_ShopByCollection__logo block-{{ block.id }}"></div>
              <a href="{{ block.settings.link }}" class="btn">{{ block.settings.cta }}</a>
            </div>
            <div
              class="mod_shop_by_collection_owrRya_ShopByCollection__featured lazyload"
              data-sizes="auto"
              data-bgset="{{ featured_card_mobile | strip_newlines | strip }}"
            ></div>
            <div class="mod_shop_by_collection_owrRya_ShopByCollection__featured__overlay"></div>
          </div>
          <style>
            .desktopSlide__logo.block-{{ block.id }}, .mod_shop_by_collection_owrRya_ShopByCollection__logo.block-{{ block.id }} {-webkit-mask: url({{ nav_image | image_url }}) no-repeat bottom;mask: url({{ nav_image | image_url }}) no-repeat bottom;}
          </style>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {% comment %} Desktop Slider  {% endcomment %}
    {%- liquid
      assign first_block = section.blocks | first
      assign first_collection = collections[first_block.settings.coll] | default: ''
      assign first_handle = first_collection.handle | default: ''
    -%}
    <div
      role="tabpanel"
      tabindex="0"
      aria-labelledby="tab-{{ first_handle }}"
      id="tabpanel-{{ first_handle }}"
      class="mod_shop_by_collection_owrRya_ShopByCollection__carousel"
    >
      <div
        class="swiper js-favorite-slider-carousel"
        role="region"
        aria-label="{{ section.settings.header | handleize }} carousel"
      >
        <div class="swiper-wrapper js-favorite-slider-carousel-content" carousel>
          <p class="sr-only">This is a carousel with scrollable slides. Use Next and Previous buttons to navigate.</p>
        </div>
        <div class="mod_shop_by_collection_owrRya_ShopByCollection__carousel__actions">
          <div class="mod_shop_by_collection_owrRya_ShopByCollection__carousel__scrollbar__wrapper">
            <div class="swiper-scrollbar"></div>
          </div>
          <button aria-label="Previous slide" class="swiper-button-prev">{%- render 'icon-arrow-prev' -%}</button>
          <button aria-label="Next slide" class="swiper-button-next">{%- render 'icon-arrow-next' -%}</button>
        </div>
      </div>
    </div>
  </section>
  <script class="js-favorite-slider-featured-block" type="application/json">
    {
    {%- for block in section.blocks -%}
        {%- liquid
            assign coll = collections[block.settings.coll] | default: ''
            assign desc = block.settings.featuredCardDescription
            assign link = block.settings.link
            assign cta = block.settings.cta
            capture featured_card_desktop
              render 'print-image-sizes', image: block.settings.featuredCard
            endcapture
        -%}
        {%- if coll != '' -%}
          {{ coll.handle | json }}:[
              {
              "block_id": {{ block.id | json }},
              "block_desc": {{ desc | json }},
              "block_link": {{ link | json }},
              "block_cta": {{ cta | json }},
              "block_image": {{ featured_card_desktop | json }}
              }
          ]{%- unless forloop.last -%},{%- endunless -%}
        {%- endif -%}
        {%- endfor -%}
    }
  </script>
{%- endif -%}

<style>
  .mod_shop_by_collection_owrRya_ShopByCollection {
    --mod_shop_by_collection_owrRya_featured-card-text-color: {{ section.settings.featured_card_text_color }};
    --mod_shop_by_collection_owrRya_arrows-color: {{ settings.arrows_color | default: '#000000' }};
    --mod_shop_by_collection_owrRya_scrollbar-color: {{ section.settings.scrollbar_color }};
    --mod_shop_by_collection_owrRya_scrollbar-bg-color: {{ section.settings.scrollbar_background_color }};
  }
</style>

