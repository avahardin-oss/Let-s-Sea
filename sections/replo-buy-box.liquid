{% comment %}
  Replo Shoppable Buy Box (portable section source)
  - Uses product picker
  - Reuses PDP classes so existing product JS (gallery, swatches, ATC) can bind
  - Includes guarded script tags for required bundles
{% endcomment %}

{% liquid
  assign navigation_id = section.settings.navigation_id | default: section.id | handleize
  assign material_title = section.settings.material_title
  assign gallery_layout = section.settings.gallery_layout | default: 'grid'
  assign customizable = false

  comment
    When fetching via /products/{handle}?section_id=, Shopify provides the `product` object.
    Use that if available, or try to infer from URL. Otherwise fall back to section settings.
  endcomment
  assign target_product = product

  if target_product.handle == blank and request.path contains '/products/'
    assign path_handle = request.path | split: '/' | last
    assign target_product = all_products[path_handle]
  endif

  if target_product != blank
    assign product_handle = target_product.handle
  else
    assign selected_product = section.settings.product
    assign product_handle = replo_buybox_product_handle | default: selected_product.handle | default: '' | strip
    assign target_product = all_products[product_handle]
  endif

  if target_product and target_product.tags contains 'customize:engrave'
    assign customizable = true
  elsif target_product and target_product.tags contains 'customize:embroidery'
    assign customizable = true
  endif
%}

{%- comment -%}
