<section
  id="replo-buy-box-{{ section.id }}"
  class="ReploBuyBox Product {% if target_product == blank %}ReploBuyBox--empty{% endif %}"
>
  {% if product_handle == blank %}
    <div class="Product-container">
      <div class="Product-sections Product-sections--noImages">
        <p class="ReploBuyBox-message">
          {{ 'sections.replo_buy_box.missing_handle' | t }}
        </p>
      </div>
    </div>
  {% elsif target_product == blank %}
    <div class="Product-container">
      <div class="Product-sections Product-sections--noImages">
        <p class="ReploBuyBox-message">
          {{ 'sections.replo_buy_box.product_not_found' | t: handle: product_handle }}
        </p>
      </div>
    </div>
  {% else %}
    {% liquid
      assign product = target_product
      assign current_variant = product.selected_or_first_available_variant
    %}

    <div tabindex="1" id="ProductGalleryModal" class="NewProductGallery-modal js-product-gallery-modal">
      <img class="NewProductGallery-modal-content js-modal-image" id="img01" width="1024" height="1024" alt="">
    </div>

    <div class="Product-info-block pdp-info-mobile">
      {% render 'okendo-reviews-product-rating-summary', product: product %}
      <div class="Product-title-price">
        <h2 class="Product-info-title">{{ product.title }}</h2>
        <div class="Product-price-block">
          <span class="Product-price">{{- current_variant.price | money -}}</span>
        </div>
      </div>
    </div>

    <div class="Product-container js-navigation-id-{{ navigation_id }} mod_replo_buy_box_zJbjSq_container">
      <div class="Product-sections {% if product.images.size == 0 %}Product-sections--noImages{% endif %}">
        {% if product.images.size > 0 %}
          <section class="Product-section--images-new pdp_gallery_ab_test__new">
            {% if gallery_layout == 'carousel' %}
              {% render 'product-images-carousel', product: product, is_replo: true %}
            {% else %}
              {% render 'product-images-new', product: product %}
            {% endif %}
          </section>
        {% endif %}

        <section class="Product-section Product-section--details">
          <div class="Product-info-block pdp-info-desktop">
            {% render 'okendo-reviews-product-rating-summary', product: product %}
            <div class="Product-title-price">
              <h2 class="Product-info-title">{{ product.title }}</h2>
              <div class="Product-price-block">
                <span class="Product-price">{{- current_variant.price | money -}}</span>
              </div>
            </div>
            <div class="Product-shop-pay">
              {% form 'product', product %}
                {{ form | payment_terms }}
              {% endform %}
              <div class="js-product-form-error ProductForm-error"></div>
            </div>
          </div>

          {% render 'product-details',
            product: product,
            customizable: customizable,
            material_title: material_title,
            is_replo: true
          %}

          {% if section.blocks.size > 0 %}
            <ul class="ProductIcons ReploBuyBox-icons mod_replo_buy_box_zJbjSq_icons">
              {% for block in section.blocks %}
                {% if block.type == 'icon_callout' %}
                  {% assign icon_image = block.settings.icon %}
                  {% assign icon_text = block.settings.text %}
                  <li class="ProductIcons-box mod_replo_buy_box_zJbjSq_iconBox">
                    {% if icon_image != blank %}
                      {% capture icon_image_sizes %}
                        {% render 'print-image-sizes', image: icon_image %}
                      {% endcapture %}
                      <img
                        class="ProductIcons-image lazyload mod_replo_buy_box_zJbjSq_iconImage"
                        srcset="{{ icon_image_sizes | strip_newlines | strip }}"
                        alt="{{ icon_text | strip_html | escape }}"
                        loading="lazy"
                        width="{{ icon_image.width }}"
                        height="{{ icon_image.height }}"
                      >
                    {% endif %}
                    {% if icon_text != blank %}
                      <div class="ProductIcons-text">{{ icon_text }}</div>
                    {% endif %}
                  </li>
                {% endif %}
              {% endfor %}
            </ul>
          {% endif %}
        </section>
      </div>
    </div>
  {% endif %}
</section>

