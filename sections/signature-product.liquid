    <div class="mod_signature_product_9WQhSa_SignatureProduct__hero__dimmer"  style="background-color: rgba(0, 0, 0, {{ shadow_intensity }}%)"></div>
    <div class="mod_signature_product_9WQhSa_SignatureProduct__hero__overlay"></div>
    {%- if desktop_title != '' -%}
      <div class="mod_signature_product_9WQhSa_SignatureProduct__hero__title">
        {%- if hero_pretitle != ''-%}<p class="js-signature-hero-pre-title">{{ hero_pretitle }}</p>{%- endif -%}
        <h1 class="js-signature-hero-title u-showMd">{{ desktop_title | newline_to_br }}</h1>
        <h1 class="js-signature-hero-title-mobile u-hideMd">{{ mobile_title | newline_to_br }}</h1>
