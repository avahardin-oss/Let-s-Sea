<section class="">
  <div class="mod_signature_product_9WQhSa_SignatureProduct__hero {{ color_mode }}">
    <div class="mod_signature_product_9WQhSa_SignatureProduct__hero__media">
      {%- if video != blank or youtube_url != blank -%}
        <div class="mod_signature_product_9WQhSa_SignatureProduct__hero__media__video">
          {%- if video_type != 'youtube' -%}                 
              {{ video | video_tag: autoplay: true, loop: true, muted: true, controls: false, image_size: '800x' }}
          {%- else -%}
          {%- assign videoId = youtube_url | split: '?v=' | last -%}
            <iframe id="ytplayer" type="text/html"
              width="100%"
              height="100%"
              src="https://www.youtube.com/embed/{{ videoId }}?autoplay=1&mute=1&controls=0&loop=1&modestbranding=1"
              frameborder="0" allowfullscreen></iframe>
          {%- endif -%}
        </div>  
      {%- elsif hero_image != blank -%}
      {%- capture image_sizes %}{%- render 'print-image-sizes', image: hero_image -%}{% endcapture %}
      <div class="mod_signature_product_9WQhSa_SignatureProduct__hero__media__image lazyload{% if hero_image_mobile != blank %} desktop{% endif %}" data-bgset="{{ image_sizes }}" data-sizes="auto"></div>
        {%- if hero_image_mobile != blank -%}
          {%- capture mobile_image_sizes %}{%- render 'print-image-sizes', image: hero_image_mobile -%}{% endcapture %}
          <div class="mod_signature_product_9WQhSa_SignatureProduct__hero__media__image lazyload mobile" data-bgset="{{ mobile_image_sizes }}" data-sizes="auto"></div>
        {%- endif  -%}
      {%- endif -%}
