            "label": "Mobile Hero Title"
          },
          {
            "type": "image_picker",
            "id": "hero_image",
            "label": "Hero Image"
          },
          {
            "type": "image_picker",
            "id": "hero_image_mobile",
            "label": "Mobile Hero Image"
          },
          {
            "type": "text",
            "id": "hero_cta_label",
