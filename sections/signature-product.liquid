      </div>
    </div>
    <button aria-label="Previous slide"  id="prev" class="mod_signature_product_9WQhSa_SignatureProduct__sliders__arrows js-features-slideshow-arrow" data-action="prev">{%- render 'svg-icon-arrow-signature-left' -%}</button>
    <button aria-label="Next slide" id="next" class="mod_signature_product_9WQhSa_SignatureProduct__sliders__arrows js-features-slideshow-arrow" data-action="next">{%- render 'svg-icon-arrow-signature-right' -%}</button>
    <div class="mod_signature_product_9WQhSa_Pagination">
    {%- for block in section_block_slides -%}
      <div class="mod_signature_product_9WQhSa_Pagination_item">
        <input type="radio" id="slideshow-dot-{{ section.id }}-{{ block.id }}" class="js-slideshow-dot mod_signature_product_9WQhSa_Pagination_itemRadio" name="slideshow-dots-{{ section.id }}" value="Slide {{ forloop.index }}" data-slide-index="{{ forloop.index0 }}" {% if forloop.first %}checked="checked" {% endif %} />
        <label for="slideshow-dot-{{ section.id }}-{{ block.id }}" class="mod_signature_product_9WQhSa_Pagination_itemLabel">
          <span class="u-vhide">
            {{ 'general.carousel.dot_name' | t: id: forloop.index }}
          </span>
        </label>
      </div>
    {%- endfor -%}
    </div>
  </div>
</section>
{%- if background_color != '#ffffff' -%}
<style>
  .mod_signature_product_9WQhSa_SignatureProduct__products,
  .mod_signature_product_9WQhSa_SignatureProduct__features,
  .mod_signature_product_9WQhSa_SignatureProduct__sliders,
  .mod_signature_product_9WQhSa_SignatureProduct__features__feature {
  background-color: {{ background_color }}
}
</style>
{%- endif -%}
{% schema %}
  {
    "name": "Signature Product",
    "class": "SignatureProduct js-signature-product",
    "settings": [
          {
            "type": "header",
            "content": "Hero Color Mode"
