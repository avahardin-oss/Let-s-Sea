{% assign navigation_id = section.settings.navigation_id | default: section.name | handleize %}
<div class="mod_testimonials_pcxtaW_Testimonials js-navigation-id-{{ navigation_id }}">
    <section class="mod_testimonials_pcxtaW_Testimonials__wrapper">
      <div class="mod_testimonials_pcxtaW_Testimonials__carousel js-testimonial-carousel">
        <div class="swiper-wrapper">
          {%- for block in section.blocks -%}
              {%- liquid
                  assign testimonial_image = false
                  assign stars = block.settings.stars
                  unless block.settings.image == blank
                  capture testimonial_image_sizes
                      render 'print-image-sizes' with block.settings.image
                  endcapture
                  assign testimonial_image = true
              endunless
              -%}
              <div class="swiper-slide mod_testimonials_pcxtaW_Testimonials__testimonial {% if block.settings.orientation == "right" %}odd{% endif %}">
                  <div class="mod_testimonials_pcxtaW_Testimonials__content {% if testimonial_image == false %}full-width{% endif %}">
                      <h3><small>{{ block.settings.label }}</small>{{ block.settings.title }}</h3>
                      {%- unless stars == 0 -%}
                      <div class="mod_testimonials_pcxtaW_Testimonials__rating">
                        {%- for i in (1..stars) -%}
                            <svg aria-labelledby="title27"  role="img" width="14" height="13" viewBox="0 0 14 13" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                <title id="title27">Star icon</title>
                                <path d="M7.16229 0.37207L8.91686 4.59055L13.4711 4.95566L10.0012 7.92794L11.0613 12.3721L7.16229 9.99055L3.26325 12.3721L4.32334 7.92794L0.853516 4.95566L5.40772 4.59055L7.16229 0.37207Z" fill="black"/>
                                </svg>
                        {%- endfor -%}
                      </div>
                    {%- endunless -%}
                      {{ block.settings.testimonial_text }}
                      {%- if block.settings.button_link != blank and block.settings.button_label != blank -%}
                        <a href="{{ block.settings.button_link }}" class="btn reverse">{{ block.settings.button_label }}</a>
                      {%- endif -%}
                  </div>
                  {%- if testimonial_image == true -%}
                      {%- assign alt_text = '' -%}
                      {%- if block.settings.image.alt != blank -%}
                        {%- assign alt_text = block.settings.image.alt -%}
                      {%- elsif block.settings.title != blank -%}
                        {%- assign alt_text = block.settings.title -%}
                      {%- elsif block.settings.label != blank -%}
                        {%- assign alt_text = block.settings.label -%}
                      {%- endif -%}
                      <div class="mod_testimonials_pcxtaW_Testimonials__image lazyload" role="img" aria-label="{{ alt_text | escape }}" data-alt="{{ alt_text | escape }}" data-bgset="{{ testimonial_image_sizes }}" data-sizes="auto"></div>
                  {%- endif -%}
              </div>
          {%- endfor -%}
        </div>
        <div class="mod_testimonials_pcxtaW_Testimonials__carousel__actions">
          <div class="swiper-pagination"></div>
          <div class="mod_testimonials_pcxtaW_Testimonials__carousel__scrollbar__wrapper">
            <div class="swiper-scrollbar"></div>
          </div>
          <button aria-label="Previous slide" class="swiper-button-prev">{%- render 'svg-arrow-prev', class: 'testimonials' -%}</button>
          <button aria-label="Next slide" class="swiper-button-next">{%- render 'svg-arrow-next', class: 'testimonials' -%}</button>
        </div>
      </div>
    </section>
