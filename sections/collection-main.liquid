                              "swatchColor": {{ value.swatch.color | default: '' | json }}
                            }
                            {%- assign swatch_output_index = swatch_output_index | plus: 1 -%}
                          {%- endunless -%}
                        {%- endfor -%}
                      ]
                    {%- endif -%}
                  }
                  {%- assign filter_output_index = filter_output_index | plus: 1 -%}
                {%- endfor -%}
              ]
            }
          </script>
        {%- endpaginate -%}
      </div>

      {%- comment -%} Static filter drawer for no-JS fallback {%- endcomment -%}
      <noscript>
        {%- render 'collection-filters', collection: collection -%}
      </noscript>
    </div>

    {%- comment -%} SMP Color Metaobject JSON for React filter drawer {%- endcomment -%}
    <script class="js-swatches-metaobject-json" type="application/json">
      {
        {%- for color_family in shop.metaobjects.product_color_families.values -%}
          {{ color_family.handle_name | json }}: [{
            "color_icon": {{ color_family.color_image | image_url: width: 128 | json }},
            "color_name": {{ color_family.handle_name | json }}
          }]{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      }
    </script>
  {%- endif -%}
</section>

