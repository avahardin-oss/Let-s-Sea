                          {%- unless value.label == 'False' -%}
                            {%- assign swatch_image = '' -%}
                            {%- if value.swatch.image -%}
                              {%- assign swatch_image = value.swatch.image | image_url: width: 128 -%}
                            {%- elsif color_family_lookup != '' -%}
                              {%- assign lookup_entries = color_family_lookup | split: ',' -%}
                              {%- for entry in lookup_entries -%}
                                {%- assign entry_parts = entry | split: '|' -%}
