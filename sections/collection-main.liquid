{%- comment -%}
  Section: Collection Main
  Portable section with React-powered filter drawer
{%- endcomment -%}

{%- liquid
  assign show_featured_products = false
  if collection.metafields.custom.featured_products != blank and collection.metafields.custom.display_featured_products == true
    assign show_featured_products = true
  endif

  assign is_b2b = false
  if customer.b2b?
    assign is_b2b = true
  endif

  assign smp_colors_json = shop.metaobjects.smp_tags.color.tags.value

  assign total_active_filters = 0
  for filter in collection.filters
    assign total_active_filters = total_active_filters | plus: filter.active_values.size
  endfor

  assign featured_row_position = collection.metafields.custom.featured_block_row_position.value | default: section.settings.row_position
  assign featured_column_position = collection.metafields.custom.featured_block_column_position.value | default: section.settings.featured_column_position
  assign content_blocks = section.blocks | where: 'type', 'collection-grid-card'

  assign desktop_promo_slots = 0
  for block in content_blocks
    assign promo_span = block.settings.card_column_span | default: 1
    assign desktop_promo_slots = desktop_promo_slots | plus: promo_span
  endfor

  assign products_per_page = section.settings.hits_per_page | default: 24
  assign grid_total = products_per_page | plus: desktop_promo_slots
  assign grid_remainder = grid_total | modulo: 4
  assign products_per_page = products_per_page | minus: grid_remainder
  if products_per_page < 4
    assign products_per_page = 4
  endif

  comment
    Pre-build color family swatch lookup from metaobject.
    This is done once to avoid repeated metaobject access in the filter loop.
    Format: "ColorName|imageUrl,ColorName2|imageUrl2,..."
  endcomment
  assign color_family_lookup = ''
  for color_family in shop.metaobjects.product_color_families.values
    assign color_entry = color_family.handle_name | append: '|' | append: color_family.color_image | image_url: width: 128
    if color_family_lookup == ''
      assign color_family_lookup = color_entry
    else
      assign color_family_lookup = color_family_lookup | append: ',' | append: color_entry
    endif
  endfor
-%}

<section>
  {%- if show_featured_products -%}
    {%- render 'collection-featured-products', featured_products: collection.metafields.custom.featured_products -%}
  {%- elsif is_b2b -%}
    <div class="column">
      {%- render 'collection-controls' -%}
      <div class="Collection-products">
        {%- if collection.products.size > 0 -%}
          {%- render 'collection-grid', collection_settings: section.settings -%}
        {%- else -%}
          <div class="Collection--empty">
            <p>{{ 'collections.general.empty_html' | t: url: '/collections/all' }}</p>
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- else -%}
    <div id="collection-anchor"></div>
    <div
      class="Collection"
      id="collection-main-container"
      data-section-type="collection-main"
      data-section-id="{{ section.id }}"
    >
      <div class="Collection__header">
        <div class="Collection__header-title">
          <h1>{{ collection.title }}</h1>
          <div class="Collection__header-filter-group">
            <p class="Collection__header-filter-title">Filter by:</p>
            {%- comment -%} Filter toggle button - React enhances this with drawer functionality {%- endcomment -%}
            {%- render 'collection-filter-toggle', active_filter_count: total_active_filters -%}
            {%- comment -%} React filter drawer mounts here {%- endcomment -%}
            <div data-filter-drawer-mount></div>
            <div class="Collection__header-filter-boubles"></div>
          </div>
        </div>
      </div>

      <div class="Collection__wrapper" data-collection-wrapper>
        {%- assign fetch_per_page = 48 -%}
        {%- paginate collection.products by fetch_per_page -%}
          {%- assign available_product_tags_str = '' -%}

          {%- if collection.products.size > 0 -%}
            {%- assign smp_colors = shop.metaobjects.smp_tags.color.tags.value | split: ',' -%}
            <div
              id="Collection-ajaxinate"
              class="Grid Grid--alignLeft Grid--itemsPerRow-4Md Grid--itemsPerRow-2"
              data-collection-grid
            >
              {%- assign shown = 0 -%}
              {%- for product in collection.products -%}
                {%- unless product.available -%}{%- continue -%}{%- endunless -%}
                {%- if shown >= products_per_page -%}{%- break -%}{%- endif -%}
                {%- comment -%}
                  Extract tags inline while rendering to avoid iterating
                  collection.products twice (Shopify may limit total accesses
                  within a single paginate block).
                {%- endcomment -%}
                {%- for tag in product.tags -%}
                  {%- if tag contains 'colorfamily:'
                    or tag contains 'volume:'
                    or tag contains 'Licensed:'
                    or tag contains 'lid:'
                    or tag contains 'attribute:'
                  -%}
                    {%- assign tag_check = '|||' | append: tag | append: '|||' -%}
                    {%- assign full_check = '|||' | append: available_product_tags_str | append: '|||' -%}
                    {%- unless full_check contains tag_check -%}
                      {%- if available_product_tags_str == '' -%}
                        {%- assign available_product_tags_str = tag -%}
                      {%- else -%}
                        {%- assign available_product_tags_str = available_product_tags_str
                          | append: '|||'
                          | append: tag
                        -%}
                      {%- endif -%}
                    {%- endunless -%}
                  {%- endif -%}
                {%- endfor -%}

                {%- assign product_index = shown | plus: 1 -%}
                {%- comment -%}
                  shown_before_mod tracks whether an odd number of products have already
                  rendered.
                {%- endcomment -%}
                {%- assign shown_before_mod = shown | modulo: 2 -%}

                {%- comment -%} Pass 1: card before product — only when shown is even {%- endcomment -%}
                {%- for block in content_blocks -%}
                  {%- assign desktop_position = block.settings.card_position -%}
                  {%- assign mobile_position = block.settings.mobile_card_position -%}
                  {%- if mobile_position == 0 or mobile_position == blank -%}
                    {%- assign mobile_position = desktop_position -%}
                  {%- endif -%}
                  {%- assign has_different_mobile_position = false -%}
                  {%- if mobile_position != desktop_position and mobile_position > 0 -%}
                    {%- assign has_different_mobile_position = true -%}
                  {%- endif -%}

                  {%- assign show_desktop_card = false -%}
                  {%- if desktop_position == product_index and desktop_position > 0 -%}
                    {%- assign show_desktop_card = true -%}
                  {%- elsif desktop_position == 0 and product_index == 1 -%}
                    {%- assign show_desktop_card = true -%}
                  {%- endif -%}
                  {%- if show_desktop_card and shown_before_mod == 0 -%}
                    <div
                      class="Grid-item Grid-item--promo span-{{ block.settings.card_column_span }}{% if has_different_mobile_position %} u-hide-mobile{% endif %}"
                      {{ block.shopify_attributes }}
                    >
                      {%- render 'collection-grid-card', settings: block.settings -%}
                    </div>
                  {%- endif -%}

                  {%- assign mobile_position_matches = false -%}
                  {%- if mobile_position == product_index -%}
                    {%- assign mobile_position_matches = true -%}
                  {%- elsif mobile_position == 0 and product_index == 1 -%}
                    {%- assign mobile_position_matches = true -%}
                  {%- endif -%}
                  {%- if has_different_mobile_position and mobile_position_matches and shown_before_mod == 0 -%}
                    <div class="Grid-item Grid-item--promo u-hide-desktop" {{ block.shopify_attributes }}>
                      {%- render 'collection-grid-card', settings: block.settings -%}
                    </div>
                  {%- endif -%}
                {%- endfor -%}

                <div class="Grid-item">
                  {%- render 'product-card', product: product, smp_colors: smp_colors, title_tag: 'h2' -%}
                </div>
                {%- assign shown = shown | plus: 1 -%}

                {%- comment -%} Pass 2: card after product — only when shown was odd (gap would have occurred) {%- endcomment -%}
                {%- if shown_before_mod == 1 -%}
                  {%- for block in content_blocks -%}
                    {%- assign desktop_position = block.settings.card_position -%}
                    {%- assign mobile_position = block.settings.mobile_card_position -%}
                    {%- if mobile_position == 0 or mobile_position == blank -%}
                      {%- assign mobile_position = desktop_position -%}
                    {%- endif -%}
                    {%- assign has_different_mobile_position = false -%}
                    {%- if mobile_position != desktop_position and mobile_position > 0 -%}
                      {%- assign has_different_mobile_position = true -%}
                    {%- endif -%}

                    {%- assign show_desktop_card = false -%}
                    {%- if desktop_position == product_index and desktop_position > 0 -%}
                      {%- assign show_desktop_card = true -%}
                    {%- elsif desktop_position == 0 and product_index == 1 -%}
                      {%- assign show_desktop_card = true -%}
                    {%- endif -%}
                    {%- if show_desktop_card -%}
                      <div
                        class="Grid-item Grid-item--promo span-{{ block.settings.card_column_span }}{% if has_different_mobile_position %} u-hide-mobile{% endif %}"
                        {{ block.shopify_attributes }}
                      >
                        {%- render 'collection-grid-card', settings: block.settings -%}
                      </div>
                    {%- endif -%}

                    {%- assign mobile_position_matches = false -%}
                    {%- if mobile_position == product_index -%}
                      {%- assign mobile_position_matches = true -%}
                    {%- elsif mobile_position == 0 and product_index == 1 -%}
                      {%- assign mobile_position_matches = true -%}
                    {%- endif -%}
                    {%- if has_different_mobile_position and mobile_position_matches -%}
                      <div class="Grid-item Grid-item--promo u-hide-desktop" {{ block.shopify_attributes }}>
                        {%- render 'collection-grid-card', settings: block.settings -%}
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                {%- endif -%}
              {%- endfor -%}

              {%- assign featured_block_desktop = collection.metafields.custom.desktop_featured_block.value -%}
              {%- if featured_block_desktop != blank -%}
                {%- render 'collection-featured-block',
                  collection: collection,
                  section_settings: section.settings,
                  row_position: featured_row_position,
                  column_position: featured_column_position
                -%}
              {%- endif -%}
            </div>

            <div data-collection-pagination-wrapper>
              {%- render 'collection-pagination', paginate: paginate -%}
            </div>
          {%- else -%}
            <div class="Collection--empty">
              <p>{{ 'collections.general.empty_html' | t: url: '/collections/all' }}</p>
            </div>
          {%- endif -%}

