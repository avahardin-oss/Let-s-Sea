                  {%- assign effective_sort = collection.default_sort_by | default: 'manual' -%}
                {%- endif -%}
                {%- for option in collection.sort_options -%}
                  {
                    "label": {{ option.name | json }},
                    "value": {{ option.value | json }},
                    "active": {% if option.value == effective_sort %}true{% else %}false{% endif %}
