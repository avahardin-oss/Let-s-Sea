{% liquid
  assign randomNumber = "now" | date: "%N" | modulo: 100 | append: "customize_" | append: product.id
  assign customizerWidth = product.metafields.customizer.width
  assign customizerHeight = product.metafields.customizer.height
  assign isEngrave = false
  assign isEmbroidery = false
  assign fonts = 'Comfortaa Bold' | split: ','

  if product.tags contains 'customize:engrave'
    assign isEngrave = true
    assign customize_product = all_products[settings.product_engraving]
    assign fonts = 'Comfortaa Bold,Nickainley,Alex Brush,Halimun,Sofia,Rockwell Bold,Industria,Bhatoshine,Esteh,Nocturne,LunchBox Bold' | split: ','
  elsif product.tags contains 'customize:embroidery'
    assign isEmbroidery = true
    assign customize_product = all_products[settings.product_embroidery]
    assign fonts = 'Comfortaa Bold,Lunchbox Bold,Rockwell,TT Milks' | split: ','
  endif

  assign customizer_image = product.featured_image
  assign customizer_font_color = '#7b7b74'

  if product.metafields.custom.customizer_image != blank
    assign customizer_image = product.metafields.custom.customizer_image.value
  endif

  if product.metafields.custom.customizer_font_color != blank
    assign customizer_font_color = product.metafields.custom.customizer_font_color.value
  endif

  if product.metafields.custom.customizer_input_height != blank
    assign customizerInputMaxFontSize = product.metafields.custom.customizer_input_height | times: 85 | divided_by: 100 | round
    assign customizerInputHeight =  product.metafields.custom.customizer_input_height | append: 'px'
  else
    assign customizerInputMaxFontSize =  48
    assign customizerInputHeight =  '72px'
  endif

  assign customizerInputWidth = ''
  if product.metafields.custom.customizer_input_width != blank
    assign customizerInputWidth = product.metafields.custom.customizer_input_width.value
  endif
%}
