<div class="mod_customizer_mM-Erq_ProductCustomizer js-product-customizer"
  data-tag="{% if isEngrave %}engrave{% elsif isEmbroidery %}embroidery{% endif %}"
  {% if customizerWidth %}data-width="{{ customizerWidth }}"{% endif %}
  {% if customizerHeight %}data-height="{{ customizerHeight }}"{% endif %}
  data-input-max-font-size="{{ customizerInputMaxFontSize }}"
  tabindex="0"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
>
  <script type="application/json">
    {
      "currencyCode": {{ cart.currency.iso_code | json }},
      "moneyFormat": {{ shop.money_format | json }}
    }
  </script>

  <button type="button" class="mod_customizer_mM-Erq_ProductCustomizer-close js-close-modal" aria-label="Close Button for Product Customizer Modal" tabindex="0">
    {% render 'svg-close' %}
  </button>

  <div class="mod_customizer_mM-Erq_ProductCustomizer-image js-product-customizer-image">
    <div
      class="mod_customizer_mM-Erq_ProductCustomizer--textInput__wrapper js-product-customizer-input-wrapper"
      {% if customizerInputWidth != '' %}style="max-width: {{ customizerInputWidth | plus: 10 | append: 'px' }};"{% endif %}
    >
      <span role="tooltip" id="a11y-tooltip" class="js-product-customizer-tooltip">
        <span class="u-showMd__inline">Click</span>
        <span class="u-showMobile__inline">Tap</span> here to add a text.
      </span>

      <input
        class="mod_customizer_mM-Erq_ProductCustomizer--textInput js-product-customizer-input {% if isEmbroidery %}mod_customizer_mM-Erq_ProductCustomizer--textInputEmbroidery{% endif %}"
        autocomplete="off"
        aria-autocomplete="none"
        type="text"
        id="title"
        placeholder="Text Here"
        value=""
        maxlength="9"
        aria-describedby="a11y-tooltip"
        style="color: {{ customizer_font_color }}; height: {{ customizerInputHeight }};"
        tabindex="0"
      >
    </div>

    <canvas class="mod_customizer_mM-Erq_ProductCustomizer--canvas js-canvas" width="50vw" height="500" data-image="{{ customizer_image | image_url: width: 700 }}"></canvas>
  </div>

  <div class="mod_customizer_mM-Erq_ProductCustomizer-content js-product-customizer-content">
    <div
      class="mod_customizer_mM-Erq_ProductCustomizer--textInput--fitty"
      {% if customizerInputWidth != '' %}style="max-width: {{ customizerInputWidth | minus: 30 | append: 'px' }}; height: {{ customizerInputHeight }};"{% endif %}
    >
      <span class="js-product-customizer-fitty-wrapper">Text Here</span>
    </div>

    <h2 class="mod_customizer_mM-Erq_ProductCustomizer--title" tabindex="0">{{ section.settings.customizer_title }}</h2>

    <p class="mod_customizer_mM-Erq_ProductCustomizer--description" tabindex="0">{{ section.settings.customizer_desc }}</p>

    <div class="mod_customizer_mM-Erq_ProductCustomizer--options">
      <p class="mod_customizer_mM-Erq_ProductCustomizer--optionsTitle" tabindex="0">Choose Font Family</p>

      <div class="mod_customizer_mM-Erq_ProductCustomizer--selectors">
        {% for font in fonts %}
          <input
            type="radio"
            id="{{ font | handle | append: section.id }}"
            name="font-selector"
            value="{{ font }}"
            class="mod_customizer_mM-Erq_ProductCustomizer--radio"
            {% if forloop.first %}
              checked="checked"
            {% endif %}
            aria-label="Select Font Family: {{ font }}"
          >

          <label
            for="{{ font | handle | append: section.id }}"
            class="mod_customizer_mM-Erq_ProductCustomizer--label"
            style="font-family: '{{ font }}'"
            aria-hidden="true"
          >
            Ab
          </label>
        {% endfor %}
      </div>
    </div>

    <div class="mod_customizer_mM-Erq_ProductCustomizer-cta">
      <form action="/cart/add" method="post" class=" js-customizer-form-add">
        <input type="hidden" name="quantity" value="1" min="1" />
        <input type="hidden" name="id" class="js-variant-selector-dummy" data-product-id="{{ customize_product.id }}" value="{{ customize_product.first_available_variant.id }}">
        <input type="hidden" name="main_variant_id" class="js-main-variant" value="{{ product.first_available_variant.id }}">

        <input type="hidden" name="properties[_customize_product]" value="{{ product.id }}">
        <input type="hidden" name="properties[Customization_sku]" value="{{ product.first_available_variant.sku }}">
        <input type="hidden" class="js-customizer-text" name="properties[Customization_content]" value="">
        <input type="hidden" class="js-customizer-font" name="properties[Customization_text_font]" value="">
        <input type="hidden" class="js-customizer-price" name="properties[_customize_price]" value="{{ customize_product.price | money }}">
        <input type="hidden" class="js-customizer-associated" name="properties[_build_id]" value="{{ randomNumber }}">
        <input type="hidden" class="js-customizer-uniq" name="properties[_assembly_add_on_uniq]" value="{{ randomNumber }}">

        <button type="submit" class="mod_customizer_mM-Erq_ProductCustomizer-addToCart btn reverse js-product-customizer-add" name="add" disabled>{{ 'products.product.add_to_cart' | t }}</button>
      </form>
    </div>
  </div>

  <div id="leaveModal" class="mod_customizer_mM-Erq_ProductCustomizer-leaveModal js-customizer-modalLeave" tabindex="0">
    <div class="mod_customizer_mM-Erq_ProductCustomizer-leaveContent">
      <button type="button" class="mod_customizer_mM-Erq_ProductCustomizer-leaveClose js-customizer-modalLeave-close" tabindex="0">
        {% render 'svg-close' %}
      </button>

      <div class="mod_customizer_mM-Erq_ProductCustomizer-leaveInfo">
        <h3 class="mod_customizer_mM-Erq_ProductCustomizer-leaveInfo__title" tabindex="0">Are you sure you want to leave?</h3>
        <p tabindex="0">You will lose the current setup.</p>
      </div>

      <div class="mod_customizer_mM-Erq_ProductCustomizer-leaveBtns">
        <button type="button" class="mod_customizer_mM-Erq_ProductCustomizer-leaveBtn btn js-customizer-modalLeave-close" tabindex="0">Cancel</button>
        <button type="button" class="mod_customizer_mM-Erq_ProductCustomizer-leaveBtn btn reverse js-customizer-modalLeave-continue" tabindex="0">Continue</button>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Customizer",
  "class": "js-customizer",
  "settings": [
    {
      "type": "text",
      "id": "customizer_title",
      "label": "Customizer Title",
      "default": "Personalize your product"
    },
    {
      "type": "text",
      "id": "customizer_desc",
      "label": "Customizer Description",
      "default": "Making your own personalized tumbler is easy. Click on the image to add a text and create the perfect tumbler."
    }
  ]
}
{% endschema %}
