        {% endif %}
      >
        {% for source in video_mobile.sources %}
          <source
            {% if lazy_load %}
              data-src="{{ source.url }}"
            {% else %}
              src="{{ source.url }}"
            {% endif %}
            type="{{ source.mime_type }}"
          >
        {% endfor %}
      </video>
