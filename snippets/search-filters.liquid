{%- comment -%}
  Search filters drawer
  Renders the full filter drawer with all filter groups for search results

  @param {object} search - The search object
{%- endcomment -%}

{%- liquid
  # Count active filters
  assign total_active_filters = 0
  for filter in search.filters
    assign total_active_filters = total_active_filters | plus: filter.active_values.size
  endfor

  # Get product count
  assign product_count = 0
  for item in search.results
    if item.object_type == 'product'
      assign product_count = product_count | plus: 1
    endif
  endfor
-%}

<div
  id="Collection__filters"
  class="Collection__filters"
  data-search-filters
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-labelledby="search-filters-heading"
>
  {%- comment -%} Filter Header {%- endcomment -%}
  <div class="Collection__filters__header">
    <h2 id="search-filters-heading">Filters</h2>
    <button
      type="button"
      id="close_filters"
      class="Collection__filters__close-btn"
      aria-label="Close filters"
      data-filter-close
    >
      {%- render 'icon-close' -%}
    </button>
  </div>

  {%- comment -%} Filter Content {%- endcomment -%}
  <div class="Collection__filters__content">
    {%- comment -%} Sort By - always expanded {%- endcomment -%}
    {%- capture sort_content -%}
      {%- render 'search-sort', sort_options: search.sort_options, current_sort: search.sort_by -%}
    {%- endcapture -%}

    {%- render 'collection-filter-group',
      title: 'Sort By',
      is_expanded: true,
      type: 'regular',
      filter_id: 'sort-by',
      content: sort_content
    -%}

    {%- comment -%} Dynamic Filters from Shopify {%- endcomment -%}
    {%- for filter in search.filters -%}
      {%- liquid
        assign filter_type = 'checkbox'
        assign filter_label_lower = filter.label | downcase

        if filter_label_lower contains 'color'
          assign filter_type = 'swatch'
        endif

        if filter.type == 'price_range'
          assign filter_type = 'price'
        endif
      -%}

      {%- case filter_type -%}
        {%- when 'swatch' -%}
          {%- render 'collection-filter-swatch', filter: filter, title: filter.label -%}

        {%- when 'price' -%}
          {%- capture price_content -%}
            <div class="Collection__filters__price" data-price-filter>
              <div class="Collection__filters__price__inputs">
                <label for="search-filter-price-min" class="sr-only">Minimum price</label>
                <input
                  type="number"
                  id="search-filter-price-min"
                  name="{{ filter.min_value.param_name }}"
                  value="{{ filter.min_value.value | divided_by: 100.0 | floor }}"
                  min="{{ filter.range_min | divided_by: 100.0 | floor }}"
                  max="{{ filter.range_max | divided_by: 100.0 | ceil }}"
                  placeholder="{{ filter.range_min | money_without_currency }}"
                  data-price-min
                />
                <span>to</span>
                <label for="search-filter-price-max" class="sr-only">Maximum price</label>
                <input
                  type="number"
                  id="search-filter-price-max"
                  name="{{ filter.max_value.param_name }}"
                  value="{{ filter.max_value.value | divided_by: 100.0 | ceil }}"
                  min="{{ filter.range_min | divided_by: 100.0 | floor }}"
                  max="{{ filter.range_max | divided_by: 100.0 | ceil }}"
                  placeholder="{{ filter.range_max | money_without_currency }}"
                  data-price-max
                />
              </div>
            </div>
          {%- endcapture -%}

          {%- render 'collection-filter-group',
            title: filter.label,
            is_expanded: false,
            type: 'regular',
            filter_id: filter.param_name,
            content: price_content
          -%}

        {%- else -%}
          {%- if filter.values.size > 0 -%}
            {%- capture checkbox_content -%}
              <fieldset>
                <legend class="sr-only">{{ filter.label }}</legend>
                <ul>
                  {%- for value in filter.values -%}
                    {%- unless value.label == 'False' -%}
                      {%- render 'collection-filter-checkbox',
                          filter_value: value,
                          filter_param_name: filter.param_name,
                          is_active: value.active,
                          is_disabled: value.count == 0
                      -%}
                    {%- endunless -%}
                  {%- endfor -%}
                </ul>
              </fieldset>
            {%- endcapture -%}

            {%- liquid
              assign active_count = filter.active_values.size
              assign display_title = filter.label
              if active_count > 0
                assign display_title = filter.label | append: ' (' | append: active_count | append: ')'
              endif
            -%}

            {%- render 'collection-filter-group',
              title: display_title,
              is_expanded: false,
              type: 'regular',
              filter_id: filter.param_name,
              content: checkbox_content
            -%}
          {%- endif -%}
      {%- endcase -%}
    {%- endfor -%}
  </div>

  {%- comment -%} Filter Footer {%- endcomment -%}
  <div class="Collection__filters__footer">
    <div class="Collection__filters__footer-selected" data-footer-active-filters>
      {%- render 'search-active-filters' -%}
    </div>
    <button
      type="button"
      class="Collection__filters__footer-applyBtn"
      data-filter-apply
    >
      View {{ product_count }} Result{% if product_count != 1 %}s{% endif %}
    </button>
    {%- if total_active_filters > 0 -%}
      <a
        href="/search?q={{ search.terms | url_encode }}&sort_by={{ search.sort_by }}"
        class="Collection__filters__footer-clearBtn"
        data-filter-clear-all
      >
        Clear all
      </a>
    {%- endif -%}
  </div>
</div>

<div class="Collection__filters__overlay" data-filter-overlay aria-hidden="true"></div>
