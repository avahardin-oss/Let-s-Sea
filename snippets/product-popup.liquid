{% # DO NOT EDIT: This file is auto-generated and will be overwritten. [build-fingerprint:assets:source={_js/snippets/product-popup/snippet.liquid}] %}

<div id="upsellModal" class="mod_product_popup_0B1q3q_upsellModal js-upsell-modal">
  <div class="mod_product_popup_0B1q3q_upsellModal_container js-upsell-modal-container" role="dialog" aria-modal="true" aria-labelledby="upsellModalTitle" tabindex="-1">
    <button type="button" aria-label="Close modal button" id="upsellClose" class="mod_product_popup_0B1q3q_upsellModal_close">
      {% render 'svg-close' %}
    </button>

    <div class="mod_product_popup_0B1q3q_upsellModal_notification">
      <div class="mod_product_popup_0B1q3q_upsellModal_notificationImage">
        <span class="mod_product_popup_0B1q3q_upsellModal_notificationBadge">
          {% render 'svg-check' %}
        </span>

        <img
          class="js-upsellAdded-image"
          src="{{ product.featured_image | image_url: width: 40 }}"
          loading="lazy"
          width="50px"
          height="50px"
          {% comment %} Leaving alt text empty since images are decorative and it might be redundant for screen readers {% endcomment %}
          alt=""
        >
      </div>

      <div class="mod_product_popup_0B1q3q_upsellModal_notificationInfo js-upsellAdded-title">
        <p>
          <span>{{ product.title | split: "-" | first }}</span>
          <br>
          {{ 'products.upsell.notification' | t }}
        </p>
      </div>
    </div>

    <div class="mod_product_popup_0B1q3q_upsellModal_content">
      <h2 class="mod_product_popup_0B1q3q_upsellModal__title" id="upsellModalTitle">
        {{ 'products.upsell.title' | t }}
      </h2>

      <div class="js-gamification-popup gamificationPopup CartDrawer-gamification" style="padding:0"></div>

      <ul class="mod_product_popup_0B1q3q_upsellModal__upsellList js-upsell-list">
        {% assign cartItems =  cart.items | map: 'product_id' %}

        {%- if product.metafields.custom.product_upsells != blank -%}
          {%- for product in product.metafields.custom.product_upsells.value -%}
            {%- unless cartItems contains product.id -%}
              {%- if product.available -%}
                <li class="js-upsellModal__upsellCard mod_product_popup_0B1q3q_upsellModal__upsellCard" data-product-id="{{ product.id }}" role="group" aria-label="product">
                  {% render 'product-popup-card-stylesheet' %}
                  {%- render 'product-popup-card', product: product -%}
                </li>
              {%- endif -%}
            {%- endunless -%}
          {%- endfor -%}
        {%- else -%}
          {%- for product in collections['all'].products limit: 12 -%}
            {%- unless cartItems contains product.id or product.first_available_variant.sku == 'SM-PERS-STITCH' or product.first_available_variant.sku == 'SM-PERS-ENGR' -%}
              {%- if product.available -%}
                <li class="js-upsellModal__upsellCard mod_product_popup_0B1q3q_upsellModal__upsellCard" data-product-id="{{ product.id }}">
                  {% render 'product-popup-card-stylesheet' %}
                  {%- render 'product-popup-card', product: product -%}
                </li>
              {%- endif -%}
            {%- endunless -%}
          {%- endfor -%}
        {%- endif -%}
      </ul>
    </div>

    <div class="mod_product_popup_0B1q3q_upsellModal_footer">
      <div class="js-gamification-subtotal mod_product_popup_0B1q3q_upsellModal__upsellSubtotal CartDrawer-subtotalContainer clearfix"></div>

      <a href="/checkout" class="btn mod_product_popup_0B1q3q_upsellModal_footerBtn">
        {{ 'products.upsell.checkout_btn' | t }}
      </a>

      <button type="button" id="continueBtn" class="mod_product_popup_0B1q3q_upsellModal_footerContinue js-continue-button">
        {{ 'products.upsell.continue_btn' | t }}
      </button>
    </div>
  </div>
</div>
