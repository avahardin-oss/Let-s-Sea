{% doc %}
  Product card data for client-side consumers (e.g. header predictive search).

  Emits a JSON script tag with `featureHighlights` from
  `product.metafields.product_card.feature_highlight.value`, matching
  `snippets/product-card.liquid`.

  @param {product} product - required

  @example
  {% render 'product-card-data-json', product: product %}
{% enddoc %}
{%- liquid
  assign card_product = product
-%}
{%- if card_product != blank -%}
  {%- assign feature_highlight = card_product.metafields.product_card.feature_highlight.value -%}
  {%- if feature_highlight != blank -%}
    <script
      type="application/json"
      data-product-card-data
      data-product-handle="{{ card_product.handle | escape }}"
    >
      {"featureHighlights":{{- feature_highlight | json -}}}
    </script>
  {%- endif -%}
{%- endif -%}
