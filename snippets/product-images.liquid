{% assign current_variant = product.selected_or_first_available_variant %}
{% assign featured_image = current_variant.featured_image | default: product.featured_image %}

{%- assign aspect_ratio_sum = 0 -%}
{%- for image in product.images -%}
  {%- assign aspect_ratio_sum = aspect_ratio_sum | plus: image.aspect_ratio -%}
{%- endfor -%}
{%- assign avg_aspect_ratio = aspect_ratio_sum | times: 1.0 | divided_by: product.images.size -%}
{%- assign placeholder_padding = avg_aspect_ratio | times: 100 | append: '%' -%}

<!-- DESKTOP -->
<section
  class="js-product-gallery-desktop ProductGallery desktop swiper-container-images"
  id="js-pdp-gallery-desktop"
  data-product-id="{{ product.id }}"
  aria-label="Desktop Carousel"
>
  <div class="js-product-gallery-images-desktop ProductGallery-images" data-product-id="{{ product.id }}">
    {% render 'product-badges', product_tags: product.tags %}

    <div class="ProductGallery-grid">
      {%- if product.tags contains 'badge:fits-car' -%}
        {% assign badge_fits_cart = shop.metaobjects.product_badges['fits-car'].icon.value | image_url %}
        {%- capture badge_image_sizes -%}
        {%- render 'print-image-sizes' with badge_fits_cart -%}
      {%- endcapture -%}
        <div
          class="ProductGallery-badge lazyload"
          data-sizes="auto"
          data-bgset="{{ badge_image_sizes | strip_newlines | strip }}"
        ></div>
      {%- endif -%}

      <!-- thumbs -->
      <div class="js-swiper-thumbs-pdp-desktop swiper-thumbs ProductGallery-thumbs">
        <p class="sr-only">This is a carousel with scrollable slides. Use Next and Previous buttons to navigate.</p>
        <div class="swiper-wrapper">
          {%- for media in product.media -%}
            {%- if media.media_type contains 'video' -%}
              <!-- Product video images (thumbnails) -->
              <button
                tabindex="0"
                name="{{product.type}} image {{forloop.index}}"
                role="button"
                class="swiper-slide ProductGallery-videoSlide"
                {% if forloop.first %}
                  aria-current="true"
                {% endif %}
                data-slide-index="{{forloop.index}}"
              >
                <div class="ProductGallery-video">
                  {%- capture media_image_sizes -%}
                  {{ media.preview_image | image_url: width: 640 }} 320w,
                  {{ media.preview_image | image_url: width: 750 }} 375w,
                  {{ media.preview_image | image_url: width: 960 }} 480w,
                  {{ media.preview_image | image_url: width: 1024 }} 600w,
                  {{ media.preview_image | image_url: width: 2048 }} 1024w
                  {%- endcapture -%}

                  <div
                    class="ProductGallery-thumbsPlaceholder lazyload"
                    data-sizes="auto"
                    data-bgset="{{ media_image_sizes | strip_newlines | strip }}"
                    style="background-image: url('{{ media.preview_image | image_url: width: 300 }}');"
                  >
                    <div class="ProductGallery-playIcon">
                      {%- render 'svg-play-icon' -%}
                    </div>
                  </div>
                </div>
                <div class="ProductGallery-videoText"></div>
              </button>
            {%- elsif media.media_type contains 'image' -%}
              <!-- Product images (thumbnails) -->
              {%- capture media_image_sizes -%}
                {{ media.preview_image | image_url: width: 640 }} 320w,
                {{ media.preview_image | image_url: width: 750 }} 375w,
                {{ media.preview_image | image_url: width: 960 }} 480w,
                {{ media.preview_image | image_url: width: 1024 }} 600w,
                {{ media.preview_image | image_url: width: 2048 }} 1024w
              {%- endcapture -%}
              <button
                tabindex="0"
                name="image {{forloop.index}} out of {{ forloop.length }}"
                role="button"
                class="swiper-slide ProductGallery-thumbSlide"
                {% if forloop.first %}
                  aria-current="true"
                {% endif %}
                aria-label="image {{forloop.index}} out of {{ forloop.length }}"
                data-slide-index="{{forloop.index}}"
              >
                <img
                  class="ProductGallery-thumbsPlaceholder lazyload"
                  data-sizes="auto"
                  data-srcset="{{ media_image_sizes | strip_newlines | strip }}"
                  src="{{ media.preview_image | image_url: width: 320 }}"
                  loading="lazy"
                  decoding="async"
                  width="{{ media.preview_image.width }}"
                  height="{{ media.preview_image.height }}"
                  alt="{{ media.alt | default: product.title | escape }}"
                  title="{{ media.alt | escape }}"
                  style="object-fit: cover; width: 100%; height: 100%;"
                >
              </button>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

      <div class="swiper-container ProductGallery-mainContainer">
        <p class="sr-only">This is a carousel with scrollable slides. Use Next and Previous buttons to navigate.</p>
        <!-- badge -->

        <div class="swiper-wrapper">
          <!-- videos -->
          {%- for media in product.media -%}
            {%- if media.media_type contains 'video' -%}
              <div class="swiper-slide ProductGallery-mainSlide ProductGallery-video">
                {{ media | video_tag: controls: true, autoplay: true, loop: true, muted: true, preload: 'none' }}
              </div>

            {%- elsif media.media_type contains 'image' -%}
              {% capture other_image_sizes %}
              {{ media | image_url: width: 640 }} 320w,
              {{ media | image_url: width: 750 }} 375w,
              {{ media | image_url: width: 960 }} 480w,
              {{ media | image_url: width: 1024 }} 600w,
              {{ media | image_url: width: 2048 }} 1024w
            {% endcapture %}
              <div class="swiper-slide ProductGallery-mainSlide">
                <div
                  class="js-product-gallery-image ProductGallery-image"
                  data-image-variants="{{ media.variants | map: 'id' | join: ' ' | escape }}"
                >
                  <div
                    class="zoom js-zoom-img ProductGallery-zoomedPic"
                    style="background-image: url( {{ media.src | image_url: width: 2480 }});"
                  >
                    <img
                      tabindex="-1"
                      src="{{ media.src | image_url: width: 1024 }}"
                      loading="lazy"
                      alt="{{ media.alt }}"
                      title="{{ media.alt }}"
                    >
                  </div>
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
      <div class="ProductGallery-actions">
        <button aria-label="Previous slide" class="swiper-button-prev swiper-button-prev-desktop">
          {%- render 'icon-arrow-prev' -%}
        </button>
        <div class="swiper-pagination"></div>
        <button aria-label="Next slide" class="swiper-button-next swiper-button-next-desktop">
          {%- render 'icon-arrow-next' -%}
        </button>
      </div>
    </div>
  </div>
</section>
<!-- MOBILE -->
<section
  class="js-product-gallery-mobile ProductGallery mobile swiper-container-images"
  data-product-id="{{ product.id }}"
  aria-label="Mobile Carousel"
>
  <div class="js-product-gallery-images-mobile ProductGallery-images" data-product-id="{{ product.id }}">
    {% render 'product-badges', product_tags: product.tags %}

    <div class="ProductGallery-grid">
      {%- if product.tags contains 'badge:fits-car' -%}
        {% assign badge_fits_cart = shop.metaobjects.product_badges['fits-car'].icon.value | image_url %}
        {%- capture badge_image_sizes -%}
        {%- render 'print-image-sizes' with badge_fits_cart -%}
        {%- endcapture -%}
        <div
          class="ProductGallery-badge lazyload"
          data-sizes="auto"
          data-bgset="{{ badge_image_sizes | strip_newlines | strip }}"
        ></div>
      {%- endif -%}

      <div class="swiper-container swiper-container-mobile ProductGallery-mainContainer">
        <p class="sr-only">This is a carousel with scrollable slides. Use Next and Previous buttons to navigate.</p>
        <div class="swiper-wrapper">
          <!-- videos -->
          {%- for media in product.media -%}
            {%- if media.media_type contains 'video' -%}
              <div class="swiper-slide ProductGallery-mainSlide ProductGallery-video">
                {{ media | video_tag: controls: true, autoplay: true, loop: true, muted: true, preload: 'none' }}
              </div>
            {%- elsif media.media_type contains 'image' -%}
              <!-- Rest of the product images -->

              {% capture other_image_sizes %}
              {{ media | image_url: width: 640 }} 320w,
              {{ media | image_url: width: 750 }} 375w,
              {{ media | image_url: width: 960 }} 480w,
              {{ media | image_url: width: 1024 }} 600w,
              {{ media | image_url: width: 2048 }} 1024w
              {% endcapture %}
              <div class="swiper-slide ProductGallery-mainSlide js-m-slide">
                <div
                  data-swiper-zoom="2"
                  class="swiper-zoom-container js-product-gallery-image ProductGallery-image"
                  data-image-variants="{{ media.variants | map: 'id' | join: ' ' | escape }}"
                >
                  <div
                    tabindex="0"
                    class="swiper-zoom-target ProductGallery-imagePlaceholder lazyload"
                    title="{{ media.alt }}"
                    aria-label="{{ media.alt }}"
                    data-sizes="auto"
                    data-bgset="{{ other_image_sizes | strip_newlines | strip }}"
                  ></div>
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        <div class="ProductGallery-actions">
          <div class="swiper-pagination"></div>
        </div>
        <div class="ProductGallery-abTestArrows">
          <button
            aria-label="Previous slide"
            class="swiper-button-prev swiper-button-prev-mobile ab-test-arrows-show swiper-button-disabled"
          >
            {%- render 'icon-arrow-prev' -%}
          </button>
          <button aria-label="Next slide" class="swiper-button-next swiper-button-next-mobile ab-test-arrows-show">
            {%- render 'icon-arrow-next' -%}
          </button>
        </div>
      </div>
    </div>
  </div>
</section>
