{%- comment -%}
  Collection filter accordion group
  Renders an accordion section containing filter items

  @param {string} title - The accordion title
  @param {boolean} is_expanded - Whether expanded by default
  @param {string} type - Accordion type: 'regular', 'swatch', or 'volume'
  @param {string} filter_id - Unique ID for the filter
{%- endcomment -%}

{%- liquid
  assign is_expanded = is_expanded | default: false
  assign type = type | default: 'regular'
  assign accordion_id = filter_id | default: title | handle | append: '-' | append: 'accordion'
-%}

<div class="Accordion{% if is_expanded %} is-open{% endif %} {{ type }}" data-filter-accordion>
  {%- if type == 'volume' -%}
    <h3
      class="Collection__filters__volume-title"
      aria-label="{{ title }}"
      tabindex="0"
    >
      Size
    </h3>
  {%- else -%}
    <div>
      <h3 class="Accordion__header">
        <button
          type="button"
          class="Accordion__trigger h5"
          id="{{ accordion_id }}-heading"
          data-accordion-trigger
          aria-controls="{{ accordion_id }}"
          aria-expanded="{{ is_expanded }}"
        >
          {{ title }}
          {%- if type == 'swatch' -%}
            <span aria-hidden="true">
              {%- render 'icon-accordion-plus', is_expanded: is_expanded -%}
              {%- render 'icon-accordion-minus', is_expanded: is_expanded -%}
            </span>
          {%- else -%}
            <span aria-hidden="true">
              {%- render 'icon-accordion-arrow' -%}
            </span>
          {%- endif -%}
        </button>
      </h3>
    </div>
  {%- endif -%}

  <div
    class="Accordion__body"
    id="{{ accordion_id }}"
    role="region"
    aria-labelledby="{{ accordion_id }}-heading"
    {% unless is_expanded %}
      style="display: none;"
    {% endunless %}
  >
    <div class="Accordion__inner">
      {{ content }}
    </div>
  </div>
</div>
