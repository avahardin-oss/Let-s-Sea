<!-- Global site tag (gtag.js) - Google Analytics -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-VCBVXWMVEF"></script>
<script>
  window.dataLayer = window.dataLayer || []

  function gtag() {
    dataLayer.push(arguments)
  }
  gtag('js', new Date())
  gtag('config', 'G-VCBVXWMVEF')

  document.addEventListener('DOMContentLoaded', function (event) {
    // Navigation Click
    const HeaderMenuItemLink = document.querySelectorAll('.event-navLink')
    if (HeaderMenuItemLink) {
      HeaderMenuItemLink.forEach(function (element) {
        element.addEventListener('click', function (h) {
          gtag('event', 'Nav Bar Interactions', {
            Click_Text: h.target.innerText,
            Page_Path: h.target.getAttribute('href')
          })
        })
      })
    }

    // Nav Cart Icon Click
    const HeaderMenuCart = document.querySelector('.event-navCart')
    if (HeaderMenuCart) {
      HeaderMenuCart.addEventListener('click', function (h) {
        gtag('event', 'Nav Cart', {
          Page_Path: window.location.href
        })
      })
    }

    // Nav Account Icon Click
    const HeaderMenuCartAccount = document.querySelector('.event-navAccount')
    if (HeaderMenuCartAccount) {
      HeaderMenuCartAccount.addEventListener('click', function (h) {
        gtag('event', 'Nav Account', {
          Page_Path: window.location.href
        })
      })
    }

    // Slide-Out Menu Click
    const HeaderMenuSlideOut = document.querySelectorAll('.event-navMegaMenu')
    if (HeaderMenuSlideOut) {
      HeaderMenuSlideOut.forEach(function (element) {
        element.addEventListener('click', function (h) {
          gtag('event', 'Slide-out Menu Interections', {
            Click_Text: h.target.innerText,
            Page_Path: window.location.href
          })
        })
      })
    }

    // Footer Menu Click
    const FooterMenuItemLink = document.querySelectorAll('.event-footerLink')
    if (FooterMenuItemLink) {
      FooterMenuItemLink.forEach(function (element) {
        element.addEventListener('click', function (f) {
          gtag('event', 'Footer Interactions', {
            Click_Text: f.target.innerText,
            Page_Path: window.location.href
          })
        })
      })
    }

    // Home Hero CTA click
    const HomeHeroLink = document.querySelectorAll('.event-heroCTA')
    if (HomeHeroLink) {
      HomeHeroLink.forEach(function (element) {
        element.addEventListener('click', function (h) {
          gtag('event', 'Hero CTA', {
            Click_Text: h.target.innerText,
            Click_Url: h.target.getAttribute('href')
          })
        })
      })
    }

    // Home Filters click
    const HomeFiltersLink = document.querySelectorAll('.event-filtersLink')
    if (HomeFiltersLink) {
      HomeFiltersLink.forEach(function (element) {
        element.addEventListener('click', function (h) {
          gtag('event', 'Product Lines', {
            Filter_Category: h.target.getAttribute('collection-name'),
            Filter_Name: h.target.innerText
          })
        })
      })
    }

    // Go to product from Collection Page
    const collectionProduct = document.querySelectorAll('.event-productCardLink')
    if (collectionProduct) {
      collectionProduct.forEach(function (element) {
        element.addEventListener('click', function (c) {
          gtag('event', 'Entered PDP', {
            Product_Name: c.target.getAttribute('data-product'),
            Page_Path: window.location.href
          })
        })
      })
    }

    // PDP Add to cart
    const pdpAddToCart = document.querySelectorAll('.event-pdpAddToCart')
    if (pdpAddToCart) {
      const eventName = document.querySelector('.js-signature-shoppable-main')
        ? 'signature_atc_click'
        : 'PDP Add to Cart'
      pdpAddToCart.forEach(function (element) {
        element.addEventListener('click', function (c) {
          gtag('event', `${eventName}`, {
            Page_Path: window.location.href
          })
        })
      })
    }

    // pdp_upsell_atc
    const pdpUpsellAtcButtons = document.querySelectorAll('.rebuy-button, .ProductUpsell .ProductForm-submitButton')
    if (pdpUpsellAtcButtons.length) {
      pdpUpsellAtcButtons.forEach(function (element) {
        element.addEventListener('click', function () {
          // Guard: prevent double-fire within 500ms
          if (element.getAttribute('data-pdp-upsell-sent')) return
          element.setAttribute('data-pdp-upsell-sent', 'true')
          setTimeout(function () {
            element.removeAttribute('data-pdp-upsell-sent')
          }, 500)

          var productName = ''
          var rebuyApp = element.closest('.RebuyApp')
          if (rebuyApp) {
            var names = []
            rebuyApp.querySelectorAll('.rebuy-product-card[aria-selected="true"]').forEach(function (card) {
              var name = card.querySelector('.rebuy-product-title')?.innerText
              if (name) names.push(name)
            })
            productName = names.join(', ')
          } else {
            productName = element.closest('.ProductCard')?.querySelector('.ProductCard-title')?.innerText || ''
          }

          window.dataLayer.push({
            event: 'pdp_upsell_atc',
            page_path: window.location.pathname,
            product_name: productName
          })
        })
      })
    }

    // PDP Navigation
    const pdpNavigation = document.querySelectorAll('.event-pdpNavigation')
    if (pdpNavigation) {
      pdpNavigation.forEach(function (element) {
        element.addEventListener('click', function (c) {
          gtag('event', 'PDP Navigation', {
            Click_Text: c.target.getAttribute('title')
          })
        })
      })
    }

    /* //PDP select size
        const sizeSelect = document.querySelectorAll('.event-pdpSize')
        if (sizeSelect) {
            sizeSelect.forEach(function (element) {
                element.addEventListener('click', function (p) {
                    gtag('event', 'PDP Select Size', {
                        'click_text': p.target.getAttribute("size"),
                        'Page_Path': window.location.href
                    });
                })
            })
        } */

    //PDP select color
    const colorSelect = document.querySelectorAll('.event-pdpColor')
    if (colorSelect) {
      colorSelect.forEach(function (element) {
        element.addEventListener('click', function (p) {
          gtag('event', 'PDP Select Color', {
            click_text: p.target.getAttribute('color'),
            Page_Path: window.location.href
          })
        })
      })
    }

    //Slide-Out Cart Checkout
    const slideoutButton = document.querySelector('.event-checkoutBtn')
    if (slideoutButton) {
      slideoutButton.addEventListener('click', function (c) {
        gtag('event', 'Cart Proceed to Checkout', {
          Click_Text: c.target.innerText
        })
      })
    }

    //Slide-Out Cart View Product
    const slideoutProduct = document.querySelector('.event-slideoutPdp')
    if (slideoutProduct) {
      slideoutProduct.addEventListener('click', function (c) {
        gtag('event', 'Cart View Product', {
          Click_Text: c.target.innerText,
          Click_Url: c.target.getAttribute('href')
        })
      })
    }

    //Slide-Out Cart Quantity Minus
    const slideoutMinus = document.querySelector('.event-slideoutMinus')
    if (slideoutMinus) {
      slideoutMinus.addEventListener('click', function (c) {
        gtag('event', 'Cart Qty Decrease', {
          Product_Name: c.target.getAttribute('title')
        })
      })
    }

    //Slide-Out Cart Quantity Plus
    const slideoutPlus = document.querySelector('.event-slideoutPlus')
    if (slideoutPlus) {
      slideoutPlus.addEventListener('click', function (c) {
        gtag('event', 'Cart Qty Increase', {
          Product_Name: c.target.getAttribute('title')
        })
      })
    }

    //Slide-Out Cart Quantity Remove
    const slideoutRemove = document.querySelector('.event-slideoutRemove')
    if (slideoutRemove) {
      slideoutRemove.addEventListener('click', function (c) {
        gtag('event', 'Remove from cart', {
          Product_Name: targetElement.title.replace('Remove product ', '')
        })
      })
    }

    //Slide-Out Cart Upsell add
    const cartUpsellProducts = document.querySelectorAll('.event-upsellAdd')
    if (cartUpsellProducts.length) {
      cartUpsellProducts.forEach(function (element) {
        element.addEventListener('click', function (c) {
          const productName = c.target.getAttribute('data-product')
          gtag('event', 'Cross Sell Product Added', {
            Product_Name: productName
          })
          window.dataLayer.push({
            event: 'mini_cart_upsell_atc',
            page_path: window.location.pathname,
            product_name: productName
          })
        })
      })
    }

    // Account Register
    const createAccount = document.querySelector('.event-createAccount')
    if (createAccount) {
      createAccount.addEventListener('click', function (a) {
        gtag('event', 'Create an Account', {
          Click_Text: a.target.innerText
        })
      })
    }

    // Account Login
    const createAccountLogin = document.querySelector('.event-loginAccount')
    if (createAccountLogin) {
      createAccountLogin.addEventListener('click', function (a) {
        gtag('event', 'Account Sign In', {
          Click_Text: a.target.getAttribute('value')
        })
      })
    }

    // Header New Menu Click (Generic - excludes items with specific tracking)
    const headerNewMenu = document.querySelectorAll('.js-nav-item-event-click')

    if (headerNewMenu.length) {
      headerNewMenu.forEach(function (element) {
        element.addEventListener('click', function (e) {
          const target = e.currentTarget

          // Skip if this element has specific navigation tracking
          const isTopNav = target.matches('.HeaderNew-menuItem > .HeaderNew-menuLink')
          const isSubNav = target.matches('.HeaderNew-menuSublistLink')
          const isDestinationNav = target.closest('.HeaderNew-productsListItem')

          if (isTopNav || isSubNav || isDestinationNav) {
            return // Skip - will be tracked by specific event
          }

          gtag('event', 'navigation_link_click', {
            link_text: target.dataset.eventTitle,
            link_url: target.dataset.eventLink
          })
        })
      })
    }

    // Top Navigation Link Click
    const topNavLinks = document.querySelectorAll('.HeaderNew-menuItem > .HeaderNew-menuLink')
    if (topNavLinks.length) {
      topNavLinks.forEach(function (element) {
        element.addEventListener('click', function (e) {
          const target = e.currentTarget
          const navLabel = target.dataset.eventTitle || target.innerText.trim()
          gtag('event', 'top_navigation_click', {
            nav_level: 'top',
            nav_category: navLabel,
            nav_label: navLabel,
            nav_url: target.getAttribute('href') || ''
          })
        })
      })
    }

    // Sub-Navigation Link Click
    const subNavLinks = document.querySelectorAll('.HeaderNew-menuSublistLink')
    if (subNavLinks.length) {
      subNavLinks.forEach(function (element) {
        element.addEventListener('click', function (e) {
          const target = e.currentTarget
          // Find parent top-level menu item for category
          const parentMenu = target.closest('.HeaderNew-menuSublistWrapper')
          const topNavCategory = parentMenu ? parentMenu.previousElementSibling?.dataset?.eventTitle || '' : ''
          const navLabel = target.dataset.eventTitle || target.innerText.trim()

          gtag('event', 'sub_navigation_click', {
            nav_level: 'sub',
            nav_category: topNavCategory,
            nav_label: navLabel,
            nav_url: target.getAttribute('href') || ''
          })
        })
      })
    }

    // Destination / Final Navigation Link Click
    const destinationNavLinks = document.querySelectorAll('.HeaderNew-productsListItem > a')
    if (destinationNavLinks.length) {
      destinationNavLinks.forEach(function (element) {
        element.addEventListener('click', function (e) {
          const target = e.currentTarget
          // Find parent top-level menu item for category
          const parentWrapper = target.closest('.HeaderNew-menuSublistWrapper')
          const topNavCategory = parentWrapper ? parentWrapper.previousElementSibling?.dataset?.eventTitle || '' : ''
          const navLabel = target.dataset.eventTitle || target.innerText.trim()

          gtag('event', 'destination_navigation_click', {
            nav_level: 'destination',
            nav_category: topNavCategory,
            nav_label: navLabel,
            nav_url: target.getAttribute('href') || ''
          })
        })
      })
    }
  })
  //Filter Items Selector
  document.addEventListener('theme:filter_item_loaded_request', function (event) {
    const eventDetail = event.detail
    gtag('event', 'collection_filter_click', {
      Click_Text: `${eventDetail['Click_Text']}`,
      Page_Path: window.location.href
    })
  })
</script>
