{%- comment -%}
  Collection pagination with numbered pages

  @param {object} paginate - The paginate object from Shopify
{%- endcomment -%}

{%- if paginate.pages > 1 -%}
  <div class="Pagination" data-collection-pagination>
    <nav class="Pagination__items o-listUnstyled" aria-label="pagination">
      {%- if paginate.previous -%}
        <li class="Pagination__arrow">
          <a
            class="Pagination__arrowLink"
            rel="prev"
            aria-label="Previous page"
            href="{{ paginate.previous.url }}"
            data-pagination-link
          >
            {%- render 'icon-pagination-prev' -%}
            Previous
          </a>
        </li>
      {%- endif -%}

      {%- for part in paginate.parts -%}
        <li class="Pagination__item">
          {%- if part.is_link -%}
            <a
              class="Pagination__itemLink"
              href="{{ part.url }}"
              aria-label="Page {{ part.title }}"
              data-pagination-link
            >
              <span class="u-hide">{{ part.title }} - Page {{ part.title }}</span>
              <span aria-hidden="true">{{ part.title }}</span>
            </a>
          {%- else -%}
            {%- if part.title == paginate.current_page -%}
              <a
                class="Pagination__itemLink active"
                href="{{ collection.url }}?page={{ part.title }}"
                aria-current="page"
                aria-label="Page {{ part.title }}"
              >
                <span class="u-hide">{{ part.title }} - Current Page</span>
                <span aria-hidden="true">{{ part.title }}</span>
              </a>
            {%- else -%}
              <span class="Pagination__itemLink Pagination__itemLink--ellipsis">{{ part.title }}</span>
            {%- endif -%}
          {%- endif -%}
        </li>
      {%- endfor -%}

      {%- if paginate.next -%}
        <li class="Pagination__arrow">
          <a
            class="Pagination__arrowLink"
            rel="next"
            href="{{ paginate.next.url }}"
            aria-label="Next page"
            data-pagination-link
          >
            Next
            {%- render 'icon-pagination-next' -%}
          </a>
        </li>
      {%- endif -%}
    </nav>
  </div>
{%- endif -%}
