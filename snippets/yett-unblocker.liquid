{% comment %}
  Yett unblocker — releases blocked third-party scripts after page load.
  Uses requestIdleCallback when available, with a 4s hard ceiling.
{% endcomment %}
<script>
  ;(function () {
    var d = false
    function u() {
      if (d) return
      d = true
      if (window.yett && typeof window.yett.unblock === 'function') {
        window.yett.unblock()
      }
    }
    function s() {
      if (window.requestIdleCallback) {
        requestIdleCallback(u, { timeout: 500 })
      } else {
        setTimeout(u, 150)
      }
    }
    if (document.readyState === 'complete') {
      s()
    } else {
      window.addEventListener('load', s)
    }
    setTimeout(u, 4000)
  })()
</script>
