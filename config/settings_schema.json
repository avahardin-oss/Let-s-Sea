  {
    "name": "Favicon",
    "settings": [
      {
        "id": "favicon",
        "info": "Will be scaled down to 32 x 32px",
        "label": "Favicon image",
        "type": "image_picker"
      },
      {
        "id": "apple_touch_icon",
        "info": "Will be scaled down to 180 x 180px",
        "label": "Apple touch icon",
        "type": "image_picker"
      }
    ]
  },
  {
    "name": "Collection",
    "settings": [
      {
        "default": true,
        "id": "grid_item_thumbs_enabled",
        "info": "A thumbnail won't be shown if an image is not linked to an available variant. [How to add image to a variant](http://illarionvk.com/r/add_images_to_variants)",
        "label": "Show additional thumbnails in product grid item on mouse hover",
        "type": "checkbox"
      },
      {
        "default": true,
        "id": "grid_item_sale_badge_enabled",
        "label": "Show \"On Sale\" badge",
        "type": "checkbox"
      }
    ]
  },
  {
    "name": "Product",
    "settings": [
      {
        "default": true,
        "id": "ajax_cart_enabled",
        "label": "Enable AJAX cart",
        "type": "checkbox"
      },
      {
        "default": "radios",
        "id": "product_options_style",
        "label": "Show product option selectors as",
        "options": [
          {
            "label": "Radio buttons",
            "value": "radios"
          },
          {
            "label": "Dropdowns",
            "value": "dropdowns"
          }
        ],
        "type": "select"
      },
      {
        "default": true,
        "id": "product_subheading_enabled",
        "info": "Subheadings are stored as product metafields. [Click here to edit](/admin/bulk?resource_name=Product&edit=metafields.theme_extras.product_subheading:string&metafield_titles[metafields.theme_extras.product_subheading]=Product%20Subheading&limit=100&return_to=/admin/products)",
        "label": "Show product subheading",
        "type": "checkbox"
      },
      {
        "content": "Image",
        "type": "header"
      },
      {
        "content": "Product images are fitted inside a responsive placeholder box. Change width and height values below to modify placeholder dimensions.",
        "type": "paragraph"
      },
      {
        "default": "400",
        "id": "product_image_placeholder_width",
        "info": "400",
        "label": "Placeholder width",
        "type": "text"
      },
      {
        "default": "300",
        "id": "product_image_placeholder_height",
        "info": "300",
        "label": "Placeholder height",
        "type": "text"
      },
      {
        "default": "contain",
        "id": "product_image_size",
        "label": "Image size",
        "options": [
          {
            "label": "Letterboxed within placeholder",
            "value": "contain"
          },
          {
            "label": "Scaled as large as possible",
            "value": "cover"
          }
        ],
        "type": "select"
      },
      {
        "content": "Description tab 1",
        "type": "header"
      },
      {
        "default": true,
        "id": "product_desc_tab_1_enabled",
        "label": "Show tab",
        "type": "checkbox"
      },
      {
        "id": "product_desc_tab_1_title",
        "label": "Tab title",
        "type": "text"
      },
      {
        "id": "product_desc_tab_1_content",
        "info": "Use basic HTML to format text",
        "label": "Tab content",
        "type": "textarea"
      },
      {
        "content": "Description tab 2",
        "type": "header"
      },
      {
        "default": true,
        "id": "product_desc_tab_2_enabled",
