{% layout none %}
{%- paginate search.results by 5 -%}
  {%- assign first = true -%}
  {"resources":{"results":{"queries":[],"products":[
  {%- for item in search.results -%}
    {%- if item.object_type == 'product' -%}
      {%- unless first -%},{%- endunless -%}
      {"id":{{ item.id }},"title":{{ item.title | json }},"handle":{{ item.handle | json }},"url":
      {{- item.url | json -}}
      ,"image":
      {%- if item.featured_image %}{{ item.featured_image | image_url: width: 400 | json }}{% else %}null{% endif -%}
      ,"price":"{{ item.price | divided_by: 100.0 }}","compare_at_price":
      {%- if item.compare_at_price > item.price -%}
        "{{ item.compare_at_price | divided_by: 100.0 }}"
      {%- else -%}
        null
      {%- endif -%}
      ,"available":{{ item.available }},"vendor":{{ item.vendor | json }},"type":{{ item.type | json }}}
      {%- assign first = false -%}
    {%- endif -%}
  {%- endfor -%}
  ]}}}
{%- endpaginate -%}
