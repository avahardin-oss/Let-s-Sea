{% layout none %}
<!DOCTYPE html>
<html>

  <head>
    <meta charset="utf-8">

    <link rel="preconnect" href="https://cdn.shopify.com">
    <meta http-equiv="x-ua-compatible" content="ie=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Signup for Simple Modern</title>
    <script src="{{ 'fitty.min.js' | asset_url }}"></script>
    <link rel="preload"
      href="{{ 'NNRektoratWeb-Heavy.woff2' | asset_url }}"
      as="font"
      type="font/woff2"
      crossorigin>

    <!-- Custom header content -->
    {{ content_for_header }}
    <!-- End of custom header content -->

    <!-- Stylesheets -->
    <style>
      .u-showMd,
      .u-showMd--inline {
        display: none !important;
      }

      .u-hideMd {
        display: block !important;
      }

      @media only screen and (min-width: 1025px) {
        .u-showMd {
          display: block !important;
        }

        .u-showMd--inline {
          display: inline-block !important;
        }

        .u-hideMd {
          display: none !important;
        }
      }

      * {
        z-index: 1;
        box-sizing: border-box;
      }

      body {
        padding: 20px;
        margin: 0;
        color: #000000;
      }

      h1 {
        font-size: min(1.75rem, 12vw);
      }

      h2 {
        font-size: min(1.5rem, 10vw);
        line-height: 120%;
      }

      h3 {
        font-size: calc(1.25rem + 0.1vw);
        line-height: 120%;
        font-weight: 400;
      }

      .u-pSize,
      p {
        font-size: calc(0.91rem + 0.1vw);
        line-height: 150%;
        letter-spacing: 0.02em;
        margin: 0.75rem auto;
      }

      @media only screen and (min-width: 1025px) {
        .h2 {
          font-size: min(3.75rem, 12vw);
        }

        body {
          color: #000000;
        }
      }

      section {
        border-radius: 12px;
        overflow: hidden;
      }

      .section--full {
        min-height: calc(100vh - 40px);
        width: 100%;
        position: relative;
      }

      #signup-form {
        display: flex;
        align-items: flex-end;
        justify-content: center;
        align-items: flex-end;
        padding: 1rem;
        align-items: center;
      }

      @media screen and (min-width: 1025px) {
        #signup-form {
          display: flex;
          flex-direction: column;
          padding: 0 25vw;
        }
      }

      .Signup-image {
        height: 100%;
        max-height: calc(100vh - 80px);

        object-fit: contain;
        z-index: -1;
        color: #000000;
        object-position: right;
      }

      .desktop-cover--container {
        position: relative;
        z-index: -5;
        display: flex;
        justify-content: flex-end;
      }

      .Signup-title--container {
        position: relative;
        margin-bottom: 2rem;
      }

      .Signup-title {
        font-size: 7.5rem;
        line-height: 140%;
        margin: 0;
      }

      .Signup-copy {
        font-size: 2vw;
        font-family: Gilroy,sans-serif;
        text-transform: uppercase;
      }

      @media screen and (max-width: 920px) {
        .PolicyContentClose {
          top: 1rem;
          right: 1rem;
        }

        .Signup-title {
          font-size: 5.5rem;
          line-height: 140%;
          margin: 0;
        }

        label a,
        label p,
        .InputCheckbox-Container label {
          font-size: 12px;
          line-height: 110%;
        }
      }

      @media screen and (max-width: 1420px) {
        .Signup-copy {
          font-size: 1.3rem;
        }
      }

      .Signup-content--wrappper {
        width: 100%;
        height: 100%;
        position: relative;
      }

      .Signup-content {
        max-width: 900px;
      }

      .desktop-signup-image {
        height: 100%;
        z-index: -1;
        object-fit: contain;
        background-position: bottom right;
        background-repeat: no-repeat;
        object-fit: cover;
        background-size: contain;
      }

      .Signup-form {
        display: flex;
        flex-direction: column;
        align-items: center;
      }

      .Signup-form-submit--container form {
        width: 100%;
        display: flex;
        align-items: center;
      }

      @media(max-width: 1040px) {
        .Signup-form-submit--container form {
          gap: 0;
          flex-direction: column;
        }

        .Signup-content--wrappper {
          max-width: 500px;
        }
      }

      .Input {
        width: 100%;
        border-radius: 12px;
        padding: 1rem;
        box-shadow: none;
        border: 1px solid #000000;
        background: #FFFFFF4D;
        margin-bottom: 1rem;
        font-size: 1rem;
        color: #000000;
        outline-color: #000000;
      }

      .Input::placeholder {
        color: #000000;
      }

      .InputCheckbox-Container label {
        cursor: pointer;
        text-align: left;
        display: flex;
        justify-content: space-between;
      }

      label a,
      label p {
        color: inherit;
        font-size: 14px;
      }

      .InputCheckbox {
        opacity: 0;
        z-index: -5;
        top: 4px;
        position: absolute;
        left: 0;
      }

      .InputCheckbox-Indicator {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2px;
        width: 1.25rem;
        height: 1.25rem;
        border: 1px solid #000000;
        border-radius: 4px;
        transition: all 0.7s cubic-bezier(0.76, 0, 0.24, 1);
        position: relative;
        top: 3px;
      }

      .InputCheckbox-Indicator svg {
        transition: all 0.7s cubic-bezier(0.76, 0, 0.24, 1);
        transform: scale(0);
      }

      input:checked + .InputCheckbox-Indicator {
        background-color: #000000;
      }

      input:checked + .InputCheckbox-Indicator svg {
        transform: scale(1);
      }

      .InputCheckbox-Container {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin: 0 0 1rem;
        width: 100%;
      }

      .InputCheckbox-Container p {
        margin: 0;
      }

      .InputCheckbox-Container label > div {
        margin-right: 1rem;
      }

      .Signup-Footer {
        display: flex;
        align-items: center;
        flex-flow: column;
        margin-top: 1.25rem;
      }

      .Signup-Footer a {
        color: #000000;
      }

      .Signup-Footer-social-links {
        display: flex;
        align-items: center;
      }

      .Signup-Footer-social-links a {
        display: block;
        width: 1.75rem;
      }

      .Signup-Footer-social-links a svg {
        height: 100%;
        width: 100%;
      }

      .Signup-Footer-social-links a + a {
        margin-left: 0.75rem;
      }

      .Signup-Footer-content-links a {
        text-decoration: none;
      }

      .Signup-Footer-content-links a + a {
        margin-left: 1.25rem;
      }

      .Signup-Footer-content-links {
        margin: 0 1.25rem;
      }

      .SignupErrors {
        display: flex;
        width: 100%;
      }

      .SignupErrors .errors {
        width: 100%;
      }

      .SignupErrors ul {
        list-style: none;
        margin-top: 0;
        padding: 0;
      }

      .SignupErrors li {
        color: #C63931;
        background: #000000;
        width: 100%;
        display: flex;
        border-radius: 12px;
        padding: 0.5rem 1rem;
        font-size: 14px;
      }

      .Logo {
        position: absolute;
        top: 2rem;
        left: 50%;
        transform: translateX(-50%);
        width: 150px;
      }

      .Logo path,
      .Signup-Footer-social-links a path {
        fill: #000000;
      }

      .reading-width {
        max-width: 800px;
      }

      @media screen and (max-width: 1439px) {
        .SignupErrors li {
          font-size: 10px;
        }
      }

      @media screen and (max-width: 1024px) {
        .InputCheckbox-Container label {
          font-size: 0.75rem;
        }

        .ButtonContainer {
          width: 100%;
          margin-bottom: 1.25rem;
        }

        .Signup-content {
          ;
          /*           width: 100%;
          max-width: 550px;
          display: flex;
          flex-flow: column;
          justify-content: flex-end;
          bottom: 0;
          top: auto;
          transform: none;
          left: 50%;
          transform: translateX(-50%); */
        }

        .Signup-image {
          position: absolute;
          width: 100%;
          height: 100%;
          object-fit: cover;
          max-height: calc(100vh - 40px);
        }

        .Signup-Footer {
          font-size: 12px;
          margin-top: 0;
          flex-flow: row;
          justify-content: space-between;
        }

        .PolicyContent {
          padding: 1rem;
        }

        .Signup-Footer-content-links {
          margin: 0;
        }

        .Signup-Footer-social-links {
          justify-content: flex-start;
        }

        .Signup-Footer-social-links a {
          display: block;
          width: 1.25rem;
        }

        .Signup-Footer-social-links a svg {
          height: 100%;
          width: 100%;
        }

        .Signup-Footer-social-links a + a {
          margin-left: 0.75rem;
        }

        .Signup-title {
          font-size: 12.5vw;
        }

        .Signup-copy {
          position: relative;
          bottom: 0;
          text-align: center;
          margin-top: -0.2rem;
          margin-bottom: 1rem;
        }

        .Signup-title {
          font-size: 10.5vw;
          color: #000000;
        }

        .Signup-title--container {
          margin-bottom: 0;
        }

        .Signup-copy {
          color: #000000;
        }

        .Logo {
          width: 110px;
          top: 0.75rem;
        }

        .InputCheckbox-Indicator {
          width: 1rem;
          height: 1rem;
        }

        .InputCheckbox-Container label > div {
          margin-right: 0.5rem;
        }
      }

      .Button {
        font-size: 2rem;
        color: #000000;
        background: transparent;
        overflow: hidden;
        cursor: pointer;
        display: inline-block;
        padding: 0.5rem 1.9rem 0.4rem;
        border-radius: 40px;
        text-decoration: none;
        border: none;
        line-height: 150%;
        outline: transparent;
        position: relative;
        width: 100%;
        min-width: 150px;
        font-size: 1rem;
        box-shadow: inset 0 0 0 1px #000000;
      }

      .Button:hover {
        text-decoration: none;
      }

      .ButtonHoverContent {
        -webkit-clip-path: var(--clip);
        background: #000000;
        clip-path: var(--clip);
        box-shadow: inset 0 0 0 1px #000000;
        color: #000000;
        left: 50%;
        position: absolute;
        top: 50%;
        transition: -webkit-clip-path 0.25s ease;
        transform: translate(-50%, -50%);
        width: 100%;
        height: 100%;
        text-align: center;
        padding: 0.5rem 1.9rem 0.4rem;
        border: none;
      }

      .ButtonHoverContent:nth-of-type(5) {
        --clip: inset(0 0 100% 0);
      }

      .ButtonHoverContent:nth-of-type(6) {
        --clip: inset(0 0 0 100%);
      }

      .ButtonHoverContent:nth-of-type(7) {
        --clip: inset(100% 0 0 0);
      }

      .ButtonHoverContent:nth-of-type(8) {
        --clip: inset(0 100% 0 0);
      }

      .ButtonHoverHelper {
        border-radius: 40px;
        -webkit-clip-path: var(--clip);
        clip-path: var(--clip);
        position: absolute;
        z-index: 1;
        width: 100%;
        left: 0;
        height: 100%;
        top: 0;
        border: 0;
      }

      .ButtonHoverHelper:nth-of-type(1):hover,
      .ButtonHoverHelper:nth-of-type(2):hover,
      .ButtonHoverHelper:nth-of-type(3):hover,
      .ButtonHoverHelper:nth-of-type(4):hover {
        --clip: polygon(0 0, 100% 0, 100% 100%, 0 100%);
        z-index: 2;
      }

      .ButtonHoverHelper:nth-of-type(1):hover~.ButtonHoverContent:nth-of-type(5),
      .ButtonHoverHelper:nth-of-type(2):hover~.ButtonHoverContent:nth-of-type(6),
      .ButtonHoverHelper:nth-of-type(3):hover~.ButtonHoverContent:nth-of-type(7),
      .ButtonHoverHelper:nth-of-type(4):hover~.ButtonHoverContent:nth-of-type(8) {
        --clip: inset(0 0 0 0);
      }

      .success .ButtonHoverContent:nth-of-type(8) {
        --clip: inset(0 0 0 0);
      }

      .ButtonHoverHelper:nth-of-type(1) {
        --clip: polygon(0 0, 100% 0, 50% 50%, 50% 50%);
      }

      .ButtonHoverHelper:nth-of-type(2) {
        --clip: polygon(100% 0, 100% 100%, 50% 50%);
      }

      .ButtonHoverHelper:nth-of-type(3) {
        --clip: polygon(0 100%, 100% 100%, 50% 50%);
      }

      .ButtonHoverHelper:nth-of-type(4) {
        --clip: polygon(0 0, 0 100%, 50% 50%);
      }

      @media screen and (min-width: 1025px) {
        body {
          padding: 40px;
          margin: 0;
        }

        .section--full {
          min-height: calc(100vh - 80px);
        }

        .Signup-Footer {
          width: 100%;
          display: flex;
          flex-flow: row;
          position: absolute;
          bottom: 1rem;
          left: 1rem;
        }

        .Logo path,
        .Signup-Footer-social-links a path {
          fill: #000000;
        }

        .Signup-form-submit--container {
          display: flex;
          justify-content: space-between;
          align-items: center;
          width: 100%;
          margin-bottom: 1rem;
        }

        .Input {
          border-color: #000000;
          color: #000000;
          background: transparent;
          margin-bottom: 0;
          margin-right: 2rem;
        }

        .Input::placeholder {
          color: #000000;
        }

        .Signup-Footer a {
          color: #000000;
        }

        .Button {
          box-shadow: inset 0 0 0 1px #000000;
          color: #000000;
        }

        .InputCheckbox-Indicator {
          border-color: #000000;
        }

        .SignupErrors li {
          background: transparent;
          padding: 0;
        }

        .ButtonHoverContent {
          background: #000000;
          color: #000000;
          box-shadow: inset 0 0 0 1px #000000;
        }
      }

      @media screen and (max-height: 680px) {
        label a,
        label p,
        .InputCheckbox-Container label {
          font-size: 12px;
          line-height: 110%;
        }

        .Signup-content {
          padding-bottom: 0.5rem;
        }

        .ButtonContainer,
        .InputCheckbox-Container,
        .Input {
          margin-bottom: 0.75rem;
        }

        .Signup-copy {
          margin-bottom: 6px;
        }
      }
    </style>


  </head>

  <body class="u-fontSwiss">
    {% section 'signup' %}
  </body>

</html>