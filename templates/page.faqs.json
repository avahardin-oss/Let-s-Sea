        "ddc5c56f-369f-469a-bfe1-ea4072a8e42f": {
          "settings": {
            "answer": "<p>We currently offer international shipping to Canada! Orders may be subject to import taxes, customs, or duties not included at checkout. Additional time may be required for your shipment to pass through customs.</p><p>If you’re outside the U.S. or Canada, you can still shop our products through our Amazon International storefronts.</p><p>For U.S. territories (Hawaii, Alaska, Puerto Rico, and the U.S. Virgin Islands), shipping is available for a flat $10 fee. Please note that purchases shipped to these locations, as well as to Canada, aren’t eligible for returns.</p>",
            "category": "Orders",
            "question": "Do you ship internationally?"
          },
          "type": "question"
        },
        "e0c639f1-04b0-4370-b591-ac7d17c4ce97": {
