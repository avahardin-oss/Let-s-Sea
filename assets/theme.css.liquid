  display: inline-block;
  position: relative;
  vertical-align: middle;
  max-width: 100%;
  overflow: hidden;
  white-space: nowrap;
  padding: 0 1.25em 0 0;
  line-height: 1.8;
  text-overflow: ellipsis;
}
.Breadcrumbs-item::after {
  content: "";
  position: absolute;
  top: 50%;
  right: 0;
  transform: translateY(-50%) translateZ(0);
  width: 1em;
  height: 1em;
  background-size: contain;
  background-position: center;
  background-repeat: no-repeat;
  background-image: url('{{ breadcrumb_arrow | strip | url_param_escape | prepend: "data:image/svg+xml," }}');
}
.Breadcrumbs-items .Breadcrumbs-item:last-child {
  padding: 0;
  color: #a3a3a3;
}
.Breadcrumbs-items .Breadcrumbs-item:last-child::after {
  display: none;
}

.Breadcrumbs-item > a {
  color: #303030;
  border-bottom: 0.0625rem solid transparent;
  transition: border-color 200ms ease-in-out;
}
.Breadcrumbs-item > a:hover, .Breadcrumbs-item > a:focus {
  color: #303030;
  border-bottom-color: #a3a3a3;
}

