    top: auto;
    margin: 0;
    float: right;
  }
  .personalization-container h3 {
    margin-bottom: 1.5rem;
  }
  .personalization-container .__content .--block:not(:first-child) {
    margin-left: 0;
  }
  .personalization-container .__content .--block .-button {
    text-align: center;
  }
  .__content {
    grid-template-columns: 1fr;
  }
  .__content .--block {
    background-color: #e2e2db;
    padding-bottom: max(2.625rem, 2.9166666667vw);
    border-radius: max(0.625rem, 0.6944444444vw);
  }
  .desktop {
    display: none;
  }

  .mobile {
    display: block;
  }

  #container {
    height: auto;
  }

  .nav-small {
    background: #fff;
    border-radius: max(0.625rem, 0.6944444444vw);
    margin-bottom: max(0.1875rem, 0.2083333333vw);
    position: relative;
  }

  .nav-small::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.5);
    /* Adjust opacity as needed */
    z-index: 1;
    border-radius: max(0.625rem, 0.6944444444vw);
  }

  .nav-small .title {
    background: #21abb5;
    color: #fff;
    padding: 0.625rem 1.25rem;
  }

  .nav-small > .title > * {
    margin: 0 !important;
    font-size: max(1.875rem, 2.0833333333vw);
    font-weight: 400;
  }

  .nav-small .item {
    position: relative;
    z-index: 999;
  }

  .nav-small .item .input {
    position: absolute;
    visibility: hidden;
    display: block;
    width: 100%;
    height: 100%;
  }

  .nav-small .item .item-name {
    font-size: max(1.5rem, 1.6666666667vw);
    font-weight: 600;
    text-transform: uppercase;
    line-height: 120%;
    color: white;
    width: 100%;
    text-align: left;
    border: none;
    border-bottom: 1px solid #f1f1f1;
    display: block;
    padding-top: max(2rem, 2.2222222222vw);
    padding-bottom: max(2rem, 2.2222222222vw);
    padding-left: max(1.25rem, 1.3888888889vw);
  }

  .nav-small .item .desc {
    height: max(25rem, 27.7777777778vw);
    margin: 0;
    opacity: 0;
    max-height: 0;
    padding: 0.3125rem 0.625rem;
    font-size: max(0.9375rem, 1.0416666667vw);
    border-bottom: 1px solid #e6e6e6;
    transition: all 0.5s ease-in-out 0s;
    padding-left: max(1.25rem, 1.3888888889vw);
    color: white;
    font-family: "Gilroy", sans-serif;
  }

  .nav-small .item .item-name:hover ~ .desc,
.nav-small .item .desc:hover {
    opacity: 1;
    max-height: max(31.25rem, 34.7222222222vw);
    transition: all 1s ease-in-out 0s;
  }

  .nav-small .item:hover > .item-name {
    border-bottom: transparent;
  }

  .nav-small .item:last-child > .item-name,
.nav-small .item:last-child > .desc {
    border-bottom: transparent;
  }

  .accordeon-divider {
    width: 95%;
  }

  .-bottom {
    margin-left: max(1.25rem, 1.3888888889vw);
  }
}
