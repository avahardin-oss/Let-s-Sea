}
.CartDrawer-subtotalLabel {
  float: left;
}
.CartDrawer-subtotal {
  float: right;
}
.CartDrawer-shippingAtCheckout {
  font-size: max(0.75rem, 0.8333333333vw);
  margin-bottom: max(1rem, 1.6666666667vw);
  text-align: left;
}
.CartDrawer-checkoutButton {
  box-sizing: border-box;
  font-size: max(1rem, 1.1111111111vw);
