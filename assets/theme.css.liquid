.BlogListItem-illustrationPlaceholder {
  width: 100%;
  height: 100%;
  padding: 0;
  background-size: cover;
}
.BlogListItem-title {
  margin-bottom: 0;
}
.BlogListItem-titleLink {
  display: inline-block;
