  background: #aaaaaa;
}
.CartDrawerUpsell .Upsell-carousel .swiper-scrollbar .swiper-scrollbar-drag {
  background: #000;
  height: 100%;
}

.gamificationPopup .CartDrawer-gamification-steps-wrapper {
  margin: 0;
  padding-top: max(0.3125rem, 0.3472222222vw);
  border-top: 0 !important;
}
.gamificationPopup .CartDrawer-gamification-steps-wrapper .CartDrawer-shippingTxt {
  font-weight: 400;
  margin-bottom: max(1.375rem, 1.5277777778vw);
}
.gamificationPopup .CartDrawer-gamification-steps-wrapper .CartDrawer-shippingTxt span {
  font-weight: 600;
}

/*------------------------------------------------
* Blog Page
