/* {% capture breadcrumb_arrow %}<svg width="6" height="11" viewBox="0 0 6 11" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M0.99 10.7274L5.39 0.827441H4.84L0.44 10.7274H0.99Z" fill="#7B7B74"/></svg>{% endcapture %} */
.Breadcrumbs {
  margin: max(1.5rem, 1.6666666667vw) 0;
  font-size: max(0.625rem, 0.7638888889vw);
  text-transform: capitalize;
