  border-bottom: 1px solid #000000;
  padding-bottom: max(0.5rem, 1.1111111111vw);
}
.CartDrawer-secure span {
  display: inline-block;
  margin-right: max(0.625rem, 0.6944444444vw);
  vertical-align: middle;
}
.CartDrawer-subtotalContainer {
  margin: max(1rem, 1.6666666667vw) 0 max(0.5rem, 0.5555555556vw);
}
.CartDrawer-subtotalLabel, .CartDrawer-subtotal {
  font-size: max(0.875rem, 1.1111111111vw);
