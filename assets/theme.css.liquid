}
.CartDrawerUpsell .Upsell-carousel .swiper-button-prev,
.CartDrawerUpsell .Upsell-carousel .swiper-button-next {
  position: relative;
  margin: 0;
  border: 0;
  left: 0;
  background-color: transparent;
  color: #13294b;
  transition: opacity ease-in-out 0.25s;
  width: max(1.25rem, 1.3888888889vw);
  height: max(1.25rem, 1.3888888889vw);
}
.CartDrawerUpsell .Upsell-carousel .swiper-button-prev::after,
.CartDrawerUpsell .Upsell-carousel .swiper-button-next::after {
  display: none;
}
.CartDrawerUpsell .Upsell-carousel .swiper-button-next {
  right: 0;
