}
.CartDrawerUpsell .Upsell-controls {
  margin-top: max(0.5rem, 0.5555555556vw);
}
.CartDrawerUpsell .Upsell-carousel-wrapper {
  padding-right: max(12.5rem, 13.8888888889vw);
}
.CartDrawerUpsell .Upsell-carousel-actions {
  margin-top: max(1rem, 1.6666666667vw);
