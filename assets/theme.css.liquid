}
.CartDrawerUpsell .CartDrawer-items .CartItem-section.is-image .CartItem-imageLink {
  padding-bottom: 0;
}
.CartDrawerUpsell .CartItem-title {
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
}
.CartDrawerUpsell .CartItem-variantTitle {
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
}
.CartDrawerUpsell .swiper-slide {
  width: max(20rem, 22.2222222222vw);
}
.CartDrawerUpsell .Upsell-image {
  padding-bottom: 100%;
