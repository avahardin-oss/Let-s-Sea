}
.BlogListItem:first-child {
  grid-column-start: span 2;
  grid-row-start: span 2;
  min-height: max(25rem, 55.5555555556vw);
}
.BlogListItem:first-child .BlogListItem-titleLink {
  font-size: max(1.5rem, 2.2222222222vw);
