}
.CartDrawer-message {
  margin: 1em 0;
  font-size: 0.875rem;
}
.CartDrawer-gamification {
  padding: 0 max(1rem, 2.2222222222vw);
}
.CartDrawer-gamification p {
  font-size: max(0.875rem, 0.9722222222vw);
  font-weight: 600;
  line-height: 1.4;
  text-align: center;
  letter-spacing: max(0.004375rem, 0.0048611111vw);
  margin-bottom: max(1.25rem, 1.3888888889vw);
}
.CartDrawer-gamification-steps-wrapper {
  margin-top: max(0.5rem, 0.5555555556vw);
  padding: max(0.875rem, 0.9722222222vw) 0 max(1.125rem, 1.25vw);
  border-top: 1px solid #000000;
  border-bottom: 1px solid #000000;
}
.CartDrawer-gamification-progress {
  background-color: #e2e2db;
  height: max(0.5rem, 0.5555555556vw);
  width: calc(100% - max(5rem, 5.5555555556vw));
  margin: 0 auto;
}
.CartDrawer-gamification-progress-bar {
  background-color: #219653;
  height: max(0.5rem, 0.5555555556vw);
  transition: width ease-in-out 0.25s;
  border-radius: 0 max(0.5rem, 0.5555555556vw) max(0.5rem, 0.5555555556vw) 0;
}
.CartDrawer-gamification-steps {
  position: relative;
  height: max(1.5rem, 1.6666666667vw);
  width: calc(100% - max(3.75rem, 4.1666666667vw));
}
.CartDrawer-gamification-step {
  width: -moz-fit-content;
  width: fit-content;
  position: absolute;
  top: max(-4rem, -4.4444444444vw);
}
.CartDrawer-gamification-step-content {
  font-size: max(0.625rem, 0.6944444444vw);
  font-weight: 700;
  white-space: nowrap;
}
.CartDrawer-gamification-step-content::before {
  width: max(1.875rem, 2.0833333333vw);
  height: max(1.875rem, 2.0833333333vw);
  font-size: max(0.75rem, 0.8333333333vw);
  font-style: normal;
  font-weight: 600;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 100%;
  background-color: #e2e2db;
  margin: 0 auto;
  content: attr(title);
}
.CartDrawer-gamification-step-content.active {
  color: #219653;
}
.CartDrawer-gamification-step-content.active::before {
  background-color: #219653;
  color: #fff;
}

.CartDrawerUpsell {
  padding: 0 max(0.75rem, 2.2222222222vw) max(1rem, 1.6666666667vw);
}
.CartDrawerUpsell-header {
  padding-top: max(1.5rem, 1.6666666667vw);
