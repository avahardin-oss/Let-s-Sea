/*------------------------------------------------
* Offcanvas
------------------------------------------------*/
.has-open-offcanvas {
  position: fixed !important;
  width: 100%;
}
.has-open-offcanvas #recently-notification {
  z-index: 1 !important;
}
.has-open-offcanvas #ju_bbox {
  display: none !important;
}
.has-open-offcanvas #ju_custom_open_btn {
  display: none !important;
}

.Offcanvas {
  position: fixed;
  top: 0;
  left: 0;
  z-index: 9999;
  width: 100%;
  height: 100vh;
  margin: 0;
  padding: 0;
  transform: translateX(-100%) translateZ(0);
  transition: transform 300ms ease-in-out;
  background-color: #f5f5f1;
}
.Offcanvas--right {
  left: auto;
  right: 0;
  transform: translateX(100%) translateZ(0);
}
.Offcanvas--menu, .Offcanvas.MegamenuMobileSubmenu {
  max-height: calc(100vh - 76px);
  top: max(4.6875rem, 5.2083333333vw);
  overflow: scroll;
}
.Offcanvas.MegamenuMobileSubmenu {
  top: max(4.625rem, 5.1388888889vw);
}
.Offcanvas--menu.scrollBlock {
  overflow: hidden;
}
.Offcanvas.MegamenuMobileSubmenu {
  top: 0;
}
.Offcanvas.MegamenuMobileSubmenu.is-expanded {
  position: sticky;
  bottom: 0;
}
.Offcanvas.is-expanded {
  transform: translateX(0%) translateZ(0);
}
.Offcanvas-bgDimmer {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  z-index: 9999;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0);
}
.Offcanvas-bgDimmer.cart-drawer {
  background-color: rgba(0, 0, 0, 0.2);
}
.has-open-offcanvas .Offcanvas-bgDimmer {
  display: block;
}

.u-no-scroll .Offcanvas-bgDimmer {
  display: block;
  background-color: rgba(0, 0, 0, 0.6);
  z-index: 99;
  top: max(4.6875rem, 11.1111111111vw);
}

.Offcanvas-content {
  width: 100%;
  height: 100%;
  overflow-y: scroll;
  margin: 0;
  padding: 1.25rem;
}

.OffcanvasSearch form {
  margin: 0 0 1rem 0;
}
.OffcanvasSearch input[type=text] {
  margin: 0;
  padding-left: 2.5rem;
  background-size: auto 45%;
  background-position: 0.75rem center;
  background-repeat: no-repeat;
  background-image: url("{{ 'icon-search.png' | asset_url }}");
}
